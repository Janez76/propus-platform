# Propus Assistant — ENV-Vorlage
# In bestehende .env (oder ENV-Provider) übernehmen.

# === AI ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7      # optional, Default in claude.ts
OPENAI_API_KEY=sk-...

# === Microsoft Graph (existieren bereits in deiner App) ===
MS_GRAPH_TENANT_ID=8aee6efb-b620-459d-95b1-0ea7ff434458
MS_GRAPH_CLIENT_ID=e23a0d84-9f8d-47ce-9a1c-73be8809d787
MS_GRAPH_CLIENT_SECRET=

# === MailerLite ===
MAILERLITE_API_KEY=

# === Home Assistant ===
HA_BASE_URL=https://smartzh.janez.ch
HA_LONG_LIVED_TOKEN=

# === Paperless-ngx (optional) ===
PAPERLESS_BASE_URL=
PAPERLESS_API_TOKEN=

# Datenbank ist bereits via DATABASE_URL gesetzt, kein zusätzlicher Eintrag nötig.
