# Propus Assistant — ENV-Vorlage
# Kopiere als .env.local in dein propus-platform Repo

# === AI ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === Microsoft Graph (existieren bereits) ===
