---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { site, seo } from '../content/site';
import Header from '../components/Header.astro';
import { loadSiteBranding, type SiteBranding } from '../lib/cms/resolve';
import { serverEnv } from '../lib/serverEnv';
import Footer from '../components/Footer.astro';
import { loadSiteSeoLinks, type SeoNavLink } from '../lib/seo';

type SiteLinksBundle = { navItems: SeoNavLink[]; footerLegalItems: SeoNavLink[] };

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogTitle?: string;
	ogDescription?: string;
	keywords?: string;
	noIndex?: boolean;
	/** Wenn gesetzt: kein zweites `readCms` (z. B. Startseite mit `loadHomePageData`). */
	branding?: SiteBranding;
	siteLinks?: SiteLinksBundle;
	/** LCP-Bild-URL: wird als <link rel="preload"> im <head> ausgegeben. */
	preloadImage?: string;
}

const {
	title = seo.defaultTitle,
	description = seo.defaultDescription,
	ogImage = seo.defaultOgImage,
	ogTitle = title,
	ogDescription = description,
	keywords = '',
	noIndex = false,
	branding: brandingProp,
	siteLinks: siteLinksProp,
	preloadImage,
} = Astro.props;

function normalizeCanonicalPath(pathname: string): string {
	if (!pathname || pathname === '/') return '/';
	const clean = pathname.replace(/\/{2,}/g, '/');
	if (/\/[^/]+\.[a-z0-9]+$/i.test(clean)) return clean;
	return clean.endsWith('/') ? clean : `${clean}/`;
}
const canonicalURL = new URL(normalizeCanonicalPath(Astro.url.pathname), Astro.site);
const absoluteOg =
	ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;

const branding = brandingProp ?? (await loadSiteBranding());
const siteLinks = siteLinksProp ?? (await loadSiteSeoLinks());

let supabaseOrigin = '';
try {
	const su = (serverEnv('SUPABASE_URL') || '').trim();
	if (su) supabaseOrigin = new URL(su).origin;
} catch {
	/* ignore */
}
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline>
			(function () {
				try {
					var k = 'propus-color-scheme';
					var s = localStorage.getItem(k);
					var dark =
						s === 'dark' ||
						(s !== 'light' &&
							typeof matchMedia !== 'undefined' &&
							matchMedia('(prefers-color-scheme: dark)').matches);
					document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
				} catch {
					document.documentElement.setAttribute('data-theme', 'light');
				}
			})();
		</script>
		{preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
		<link rel="preload" href="/fonts/inter-400-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/inter-700-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="icon" type={branding.faviconType} href={branding.faviconHref} />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="ikI2qDaCeLbMKhTAvyw2WLmJPzZ7xhW2x6BVgiCcuVc" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		{noIndex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalURL.href} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={site.locale} />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:image" content={absoluteOg} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={absoluteOg} />
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@graph': [
					{
						'@type': ['LocalBusiness', 'ProfessionalService'],
						'@id': `${site.url}/#organization`,
						name: site.legalName,
						alternateName: site.name,
						url: site.url,
						logo: {
							'@type': 'ImageObject',
							url: `${site.url}/images/propus-logo.png`,
							width: 300,
							height: 80,
						},
						image: absoluteOg,
						description: site.description,
						telephone: site.phone,
						email: site.email,
						address: {
							'@type': 'PostalAddress',
							streetAddress: site.addressLines[0],
							addressLocality: 'Zug',
							postalCode: '6300',
							addressCountry: 'CH',
						},
						areaServed: {
							'@type': 'Country',
							name: 'Schweiz',
						},
						knowsLanguage: ['de', 'de-CH'],
						openingHoursSpecification: [
							{
								'@type': 'OpeningHoursSpecification',
								dayOfWeek: [
									'Monday',
									'Tuesday',
									'Wednesday',
									'Thursday',
									'Friday',
									'Saturday',
								],
								opens: '08:00',
								closes: '17:00',
							},
						],
						sameAs: [
							'https://www.instagram.com/propus.ch/',
							'https://ch.linkedin.com/company/propusgmbh',
							'https://www.google.com/maps/place/Propus+GmbH/@47.1566619,8.5120229,17z',
						],
						priceRange: '$$',
						hasOfferCatalog: {
							'@type': 'OfferCatalog',
							name: 'Immobilienpräsentation',
							itemListElement: [
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Immobilienfotografie' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Drohnenaufnahmen' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: '360°-Rundgang' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Grundrisse' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Immobilienvideo' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Home Staging' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Visualisierung' } },
								{ '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Retusche' } },
							],
						},
					},
					{
						'@type': 'WebSite',
						'@id': `${site.url}/#website`,
						url: site.url,
						name: site.name,
						description: site.description,
						publisher: { '@id': `${site.url}/#organization` },
						inLanguage: 'de-CH',
						potentialAction: {
							'@type': 'SearchAction',
							target: {
								'@type': 'EntryPoint',
								urlTemplate: `${site.url}/?s={search_term_string}`,
							},
							'query-input': 'required name=search_term_string',
						},
					},
				],
			})}
		/>
		<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://www.google-analytics.com" />
		<link rel="dns-prefetch" href="https://images.unsplash.com" />
		<link rel="preconnect" href="https://images.unsplash.com" crossorigin />
		<link rel="dns-prefetch" href="https://www.youtube-nocookie.com" />
		<link rel="dns-prefetch" href="https://www.youtube.com" />
		<link rel="dns-prefetch" href="https://my.matterport.com" />
		{
			supabaseOrigin && (
				<>
					<link rel="dns-prefetch" href={supabaseOrigin} />
					<link rel="preconnect" href={supabaseOrigin} crossorigin />
				</>
			)
		}
		<!-- Google Analytics 4 -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-VTBSQMZ3CK"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-VTBSQMZ3CK', { anonymize_ip: true });
		</script>
		<ClientRouter />
	</head>
	<body>
		<Header logoSrc={branding.logoSrc} logoSrcDark={branding.logoSrcDark} navItems={siteLinks.navItems} />
		<main id="main">
			<slot />
		</main>
		<Footer footerLegalItems={siteLinks.footerLegalItems} />
	</body>
</html>

<style is:global>
	main#main {
		min-height: calc(100vh - var(--header-h) - 10rem);
	}
</style>
