---
import { Image } from 'astro:assets';
import type { PortfolioItem } from '../content/portfolio';
import { isNativeCmsImageSrc } from '../lib/nativeCmsImage';
import BeforeAfterSlider from './BeforeAfterSlider.astro';

interface Props {
	items: PortfolioItem[];
}

const { items } = Astro.props;

const sizes =
	'(min-width: 1100px) min(28vw, 22rem), (min-width: 640px) min(45vw, 28rem), 92vw';
---

{
	items.length > 0 ? (
		<ul class="home-featured" aria-label="Ausgewählte Referenzen">
			{items.map((item, idx) => (
				<li class="home-featured__cell">
					<figure class="home-featured__figure">
						<div class="home-featured__inner">
							{item.kind === 'compare' ? (
								<BeforeAfterSlider
									beforeSrc={item.compare.beforeSrc}
									afterSrc={item.compare.afterSrc}
									beforeAlt={item.compare.beforeAlt}
									afterAlt={item.compare.afterAlt}
									width={item.width}
									height={item.height}
									sizes={sizes}
									loading={idx < 2 ? 'eager' : 'lazy'}
								/>
							) : (
								<div class="home-featured__frame">
									{isNativeCmsImageSrc(item.src) ? (
										<img
											src={item.src}
											alt={item.alt}
											width={item.width}
											height={item.height}
											sizes={sizes}
											loading={idx < 2 ? 'eager' : 'lazy'}
											decoding={idx < 2 ? 'sync' : 'async'}
											{...(idx === 0 ? { fetchpriority: 'high' as const } : {})}
										/>
									) : (
										<Image
											src={item.src}
											alt={item.alt}
											width={item.width}
											height={item.height}
											sizes={sizes}
											loading={idx < 2 ? 'eager' : 'lazy'}
											decoding={idx < 2 ? 'sync' : 'async'}
											{...(idx === 0 ? { fetchpriority: 'high' as const } : {})}
										/>
									)}
								</div>
							)}
						</div>
					</figure>
				</li>
			))}
		</ul>
	) : (
		<p class="home-featured__empty">
			Hier erscheint in Kürze eine Auswahl aus unserem Portfolio. Bis dahin finden Sie alle Arbeiten über den
			Link zur Portfolio-Übersicht unter dieser Sektion.
		</p>
	)
}

<style>
	.home-featured {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1rem, 2.5vw, 1.35rem);
		width: 100%;
		max-width: min(100%, 88rem);
		margin-inline: auto;
	}

	@media (min-width: 520px) {
		.home-featured {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 900px) {
		.home-featured {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: clamp(1.1rem, 2.2vw, 1.5rem);
		}
	}

	.home-featured__cell {
		margin: 0;
		min-width: 0;
	}

	.home-featured__figure {
		margin: 0;
		height: 100%;
	}

	.home-featured__inner {
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-border);
		height: 100%;
	}

	.home-featured__frame {
		aspect-ratio: 3 / 2;
		overflow: hidden;
	}

	.home-featured__frame :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.home-featured__inner :global(.ba) {
		border-radius: 0;
	}

	.home-featured__empty {
		margin: 0;
		text-align: center;
		color: var(--color-text-muted);
		font-size: 0.9375rem;
		line-height: 1.55;
		max-width: 32rem;
		margin-inline: auto;
	}
</style>
