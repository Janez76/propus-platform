---
import type { ChecklistItem } from '../content/checklisten';

interface Props {
	item: ChecklistItem;
}

const { item } = Astro.props;
const href = `/checklisten/${item.slug}/`;
---

<article class="checklist-card" aria-labelledby={`cl-${item.slug}`}>
	<a class="checklist-card__link" href={href} aria-label={`${item.title} öffnen`}>
		<div class="checklist-card__head">
			<p class="checklist-card__eyebrow">{item.eyebrow}</p>
			<h2 class="checklist-card__title" id={`cl-${item.slug}`}>{item.title}</h2>
		</div>
		<p class="checklist-card__text">{item.subtitle}</p>
		<div class="checklist-card__foot">
			<span class="checklist-card__cta">Checkliste lesen →</span>
			<span class="checklist-card__pages">PDF · {item.pdfPages} S.</span>
		</div>
	</a>
</article>

<style>
	.checklist-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		border-radius: var(--radius-md);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-soft);
		transition:
			border-color var(--transition-med),
			transform var(--transition-med);
	}

	.checklist-card:hover {
		border-color: rgb(184 149 106 / 0.35);
		transform: translateY(-2px);
	}

	.checklist-card__link {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		height: 100%;
		padding: clamp(1.1rem, 2.4vw, 1.5rem);
		color: inherit;
		text-decoration: none;
	}

	.checklist-card__head {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.checklist-card__eyebrow {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-gold-muted);
		line-height: 1.3;
	}

	.checklist-card__title {
		margin: 0;
		font-family: var(--font-sans);
		font-size: clamp(1.05rem, 1.8vw, 1.2rem);
		font-weight: 650;
		letter-spacing: -0.02em;
		line-height: 1.25;
		color: var(--color-text);
	}

	.checklist-card__text {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.6;
		color: var(--color-text-muted);
		flex: 1;
	}

	.checklist-card__foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding-top: 0.65rem;
		margin-top: 0.25rem;
		border-top: 1px solid var(--color-border);
	}

	.checklist-card__cta {
		font-size: 0.8125rem;
		font-weight: 650;
		letter-spacing: -0.01em;
		color: var(--color-gold-muted);
	}

	.checklist-card__pages {
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
</style>
