---
/** Footer: Newsletter mit 10 %-Gutschein-Versprechen (Mailchimp + optional Code aus Env). */
---

<div class="newsletter-signup" data-newsletter-root>
	<p class="newsletter-signup__eyebrow">Newsletter</p>
	<p class="newsletter-signup__lead">
		<strong>10&nbsp;% Rabatt</strong> auf Ihre nächste Online-Buchung — melden Sie sich an und sichern Sie sich den Gutscheincode.
	</p>
	<form class="newsletter-signup__form" id="newsletter-form" novalidate>
		<label class="visually-hidden" for="newsletter-email">E-Mail</label>
		<input
			id="newsletter-email"
			name="email"
			type="email"
			inputmode="email"
			autocomplete="email"
			required
			maxlength="254"
			class="newsletter-signup__input"
			placeholder="ihre@email.ch"
			aria-describedby="newsletter-status"
		/>
		<input
			class="newsletter-signup__hp"
			type="text"
			name="website"
			tabindex="-1"
			autocomplete="off"
			aria-hidden="true"
		/>
		<button class="newsletter-signup__btn btn btn--primary" type="submit">Anmelden</button>
	</form>
	<p
		class="newsletter-signup__status"
		id="newsletter-status"
		role="status"
		aria-live="polite"
	></p>
	<p class="newsletter-signup__legal">
		Mit der Anmeldung willigen Sie ein, gelegentlich News zu Propus per E-Mail zu erhalten. Abmeldung jederzeit möglich.
		<a href="/datenschutz/">Datenschutz</a>
	</p>
</div>

<script>
	(() => {
		const root = document.querySelector('[data-newsletter-root]');
		const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
		const statusEl = document.getElementById('newsletter-status');
		if (!root || !form || !statusEl) return;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			statusEl.textContent = '';
			const fd = new FormData(form);
			const email = String(fd.get('email') ?? '').trim();
			const hp = String(fd.get('website') ?? '');
			if (!email) {
				statusEl.textContent = 'Bitte E-Mail-Adresse eingeben.';
				return;
			}
			try {
				const res = await fetch('/api/newsletter/subscribe', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, hp }),
				});
				const data = (await res.json()) as {
					ok?: boolean;
					error?: string;
					voucherCode?: string;
					voucherPercent?: number;
				};
				if (!res.ok || !data.ok) {
					if (data.error === 'newsletter_not_configured') {
						statusEl.textContent = 'Newsletter ist momentan nicht verfügbar.';
					} else if (data.error === 'invalid_email') {
						statusEl.textContent = 'Bitte gültige E-Mail-Adresse eingeben.';
					} else {
						statusEl.textContent = 'Anmeldung fehlgeschlagen. Bitte später erneut versuchen.';
					}
					return;
				}
				form.reset();
				const pct = data.voucherPercent ?? 10;
				if (data.voucherCode) {
					statusEl.innerHTML = `Vielen Dank! Ihr <strong>${pct}&nbsp;%</strong>-Code: <strong class="newsletter-signup__code">${escapeHtml(data.voucherCode)}</strong> — bei der Buchung im Feld «Rabattcode» einlösen.`;
				} else {
					statusEl.textContent = `Vielen Dank für Ihre Anmeldung! Sie erhalten den ${pct}-%-Rabattcode in Kürze per E-Mail.`;
				}
			} catch {
				statusEl.textContent = 'Netzwerkfehler. Bitte später erneut versuchen.';
			}
		});

		function escapeHtml(s: string): string {
			const d = document.createElement('div');
			d.textContent = s;
			return d.innerHTML;
		}
	})();
</script>

<style>
	.newsletter-signup {
		width: 100%;
		max-width: 22rem;
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		text-align: center;
	}

	.newsletter-signup__eyebrow {
		margin: 0 0 0.35rem;
		font-size: 0.625rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.newsletter-signup__lead {
		margin: 0 0 0.65rem;
		font-size: 0.8125rem;
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.newsletter-signup__lead strong {
		color: var(--color-text);
		font-weight: 650;
	}

	.newsletter-signup__form {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 0.5rem;
	}

	.newsletter-signup__input {
		flex: 1 1 10rem;
		min-width: 0;
		padding: 0.45rem 0.65rem;
		font-size: 0.8125rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		color: var(--color-text);
	}

	.newsletter-signup__input:focus-visible {
		outline: 2px solid var(--color-gold);
		outline-offset: 2px;
	}

	.newsletter-signup__btn {
		flex: 0 0 auto;
		padding-inline: 1rem;
		font-size: 0.8125rem;
	}

	.newsletter-signup__hp {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
	}

	.newsletter-signup__status {
		min-height: 1.25rem;
		margin: 0.5rem 0 0;
		font-size: 0.8125rem;
		line-height: 1.45;
		color: var(--color-text);
	}

	.newsletter-signup__status :global(.newsletter-signup__code) {
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.04em;
		color: var(--color-gold-muted);
	}

	.newsletter-signup__legal {
		margin: 0.65rem 0 0;
		font-size: 0.6875rem;
		line-height: 1.45;
		color: var(--color-text-muted);
		opacity: 0.92;
	}

	.newsletter-signup__legal a {
		color: var(--color-text-muted);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.newsletter-signup__legal a:hover {
		color: var(--color-gold-muted);
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
