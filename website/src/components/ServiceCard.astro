---
import type { ServiceDetailSection } from '../content/services-detail';

type Props = ServiceDetailSection & { loading?: 'lazy' | 'eager' };

const {
	id,
	title,
	slogan,
	body,
	imageSrc,
	imageAlt,
	width,
	height,
	loading = 'lazy',
} = Astro.props;
---

<article class="service-card" aria-labelledby={`svc-${id}`}>
	<div class="service-card__media">
		<img
			class="service-card__img"
			src={imageSrc}
			alt={imageAlt}
			width={width}
			height={height}
			loading={loading}
			decoding="async"
			sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
			{...(loading === 'eager' ? { fetchpriority: 'high' as const } : {})}
		/>
	</div>
	<div class="service-card__body">
		<p class="service-card__category">{title}</p>
		<h2 class="service-card__slogan" id={`svc-${id}`}>{slogan}</h2>
		<p class="service-card__text">{body}</p>
	</div>
</article>

<style>
	.service-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-soft);
	}

	.service-card__media {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--color-bg-muted);
	}

	.service-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.service-card__body {
		padding: clamp(0.95rem, 2.2vw, 1.25rem);
		display: flex;
		flex-direction: column;
		flex: 1;
		align-items: center;
		text-align: center;
		gap: 0.45rem;
	}

	.service-card__category {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-gold-muted);
		line-height: 1.3;
	}

	.service-card__slogan {
		margin: 0;
		font-family: var(--font-sans);
		font-size: clamp(0.75rem, 1.2vw, 0.875rem);
		font-weight: 700;
		letter-spacing: 0.06em;
		line-height: 1.35;
		text-transform: uppercase;
		color: var(--color-text);
		max-width: 20rem;
	}

	.service-card__text {
		margin: 0;
		width: 100%;
		max-width: 24rem;
		font-size: 0.8125rem;
		line-height: 1.55;
		color: var(--color-text-muted);
	}
</style>
