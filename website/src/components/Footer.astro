---
import FooterSocialIcon from './FooterSocialIcon.astro';
import NewsletterSignup from './NewsletterSignup.astro';
import { site, footerCredit, footerSocialLinks } from '../content/site';
import type { SeoNavLink } from '../lib/seo';
import { serverEnv } from '../lib/serverEnv';

interface Props {
	footerLegalItems: SeoNavLink[];
}

const { footerLegalItems } = Astro.props;
const newsletterEnabled = Boolean(
	serverEnv('MAILCHIMP_API_KEY')?.trim() && serverEnv('MAILCHIMP_NEWSLETTER_LIST_ID')?.trim(),
);
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<div class="site-footer__stack">
			<p class="site-footer__name">{site.legalName}</p>
			<address class="site-footer__address">{site.addressLines.join(', ')}</address>
			<div class="site-footer__hours-wrap">
				<p class="site-footer__hours-eyebrow">Öffnungszeiten</p>
				<p
					class="site-footer__hours"
					aria-label={`Öffnungszeiten ${site.officeHoursDays}, ${site.officeHoursTime}`}
				>
					<span class="site-footer__hours-days">{site.officeHoursDays}</span>
					<span class="site-footer__hours-pipe" aria-hidden="true">|</span>
					<span class="site-footer__hours-time">{site.officeHoursTime}</span>
				</p>
			</div>
			<p class="site-footer__contact">
				<a
					class="site-footer__contact-link"
					href={`mailto:${site.email}`}
					aria-label={`E-Mail an ${site.email}`}
				>
					<svg
						class="site-footer__contact-icon"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.65"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<rect x="2.5" y="5" width="19" height="14" rx="2" />
						<path d="M3 7l8.2 5.5a2 2 0 0 0 2.2 0L21 7" />
					</svg>
					<span class="site-footer__contact-text">E-Mail</span>
				</a>
				<span class="site-footer__dot" aria-hidden="true">·</span>
				<a
					class="site-footer__contact-link"
					href={`tel:${site.phone}`}
					aria-label={`Anrufen: ${site.phoneDisplay}`}
				>
					<svg
						class="site-footer__contact-icon"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.65"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path
							d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92z"
						/>
					</svg>
					<span class="site-footer__contact-text">Telefon</span>
				</a>
			</p>

			<div class="site-footer__social" role="list" aria-label="Social Media">
				{
					footerSocialLinks.map((item) => (
						<span role="listitem">
							{item.href ? (
								<a
									href={item.href}
									class="site-footer__icon-link"
									target="_blank"
									rel="noopener noreferrer"
									aria-label={item.label}
								>
									<FooterSocialIcon network={item.network} />
								</a>
							) : (
								<span class="site-footer__icon-link site-footer__icon-link--off" aria-hidden="true">
									<FooterSocialIcon network={item.network} />
								</span>
							)}
						</span>
					))
				}
			</div>

			{newsletterEnabled && <NewsletterSignup />}

			<nav class="site-footer__legal" aria-label="Rechtliche Hinweise">
				<ul class="site-footer__legal-list">
					{
						footerLegalItems.flatMap((item, i) => [
							...(i > 0
								? [
										<li class="site-footer__legal-sep" role="presentation" aria-hidden="true">
											<span class="site-footer__legal-pipe">|</span>
										</li>,
									]
								: []),
							<li class="site-footer__legal-item">
								<a href={item.href}>{item.label}</a>
							</li>,
						])
					}
				</ul>
			</nav>

			<p class="site-footer__copy">
				© {year} {site.legalName}
				<span class="site-footer__copy-sep" aria-hidden="true">|</span>
				<span class="site-footer__credit-note">{footerCredit.replace(/^[^|]*\|\s*/, '')}</span>
			</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 0;
		background: var(--color-bg-muted);
		border-top: 1px solid var(--color-border);
		color: var(--color-text);
	}

	.site-footer__inner {
		--footer-rail-max: 87.5rem;
		--footer-rail-gutter: clamp(1.5rem, 5vw, 3.25rem);
		width: min(100% - 2 * var(--footer-rail-gutter), var(--footer-rail-max));
		max-width: var(--footer-rail-max);
		margin-inline: auto;
		box-sizing: border-box;
		padding-block: clamp(2rem, 5vw, 2.75rem);
	}

	.site-footer__stack {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.4rem;
		max-width: 32rem;
		margin-inline: auto;
	}

	.site-footer__name {
		margin: 0 0 0.15rem;
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.site-footer__address {
		margin: 0;
		font-size: 0.8125rem;
		line-height: 1.55;
		font-style: normal;
		color: var(--color-text-muted);
	}

	.site-footer__hours-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		margin-top: 0.5rem;
	}

	.site-footer__hours-eyebrow {
		margin: 0;
		font-size: 0.625rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		opacity: 0.9;
	}

	.site-footer__hours {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		margin: 0;
		padding: 0;
		font-size: 0.8125rem;
		line-height: 1.5;
		color: var(--color-text-muted);
		background: none;
		border: none;
		box-shadow: none;
		border-radius: 0;
	}

	.site-footer__hours-days {
		font-weight: 650;
		letter-spacing: 0.06em;
		font-size: 0.6875rem;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.site-footer__hours-pipe {
		color: var(--color-text-muted);
		font-weight: 600;
		opacity: 0.65;
		user-select: none;
	}

	.site-footer__hours-time {
		font-weight: 500;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.02em;
		color: var(--color-text-muted);
	}

	.site-footer__contact {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.25rem 0.35rem;
		margin: 0.35rem 0 0;
		font-size: 0.8125rem;
		line-height: 1.5;
	}

	.site-footer__contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.25rem 0.35rem;
		margin: -0.25rem -0.35rem;
		color: var(--color-text-muted);
		text-decoration: none;
		border-radius: var(--radius-sm);
		transition:
			color var(--transition-fast),
			background var(--transition-fast);
	}

	.site-footer__contact-text {
		font-weight: 500;
		letter-spacing: 0.01em;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.2em;
	}

	.site-footer__contact-link:hover {
		color: var(--color-gold-muted);
	}

	.site-footer__contact-link:focus-visible {
		outline: 2px solid var(--color-gold);
		outline-offset: 2px;
	}

	.site-footer__contact-icon {
		display: block;
		flex-shrink: 0;
	}

	.site-footer__dot {
		display: inline-block;
		margin-inline: 0.45rem;
		color: var(--color-text-muted);
		font-weight: 700;
		font-size: 1.25em;
		line-height: 1;
		opacity: 0.88;
		user-select: none;
		vertical-align: -0.05em;
	}

	.site-footer__social {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.125rem;
		margin-top: 0.65rem;
		padding: 0;
		list-style: none;
	}

	.site-footer__icon-link {
		display: inline-flex;
		color: var(--color-text-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.site-footer__icon-link:hover {
		color: var(--color-gold-muted);
	}

	.site-footer__icon-link:focus-visible {
		outline: 2px solid var(--color-gold);
		outline-offset: 2px;
	}

	.site-footer__icon-link--off {
		color: var(--color-text-muted);
		opacity: 0.4;
		pointer-events: none;
	}

	:global(.site-footer__social-svg) {
		display: block;
	}

	.site-footer__legal {
		margin-top: 1.25rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--color-border);
		width: 100%;
		display: flex;
		justify-content: center;
	}

	/* Link | Link | Link — Trennstrich mittig im Freiraum zwischen den Spalten */
	.site-footer__legal-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		width: 100%;
		max-width: min(28rem, 100%);
		column-gap: clamp(0.35rem, 2.5vw, 0.85rem);
		font-size: 0.8125rem;
	}

	.site-footer__legal-item {
		margin: 0;
		min-width: 0;
	}

	.site-footer__legal-item:nth-child(1) {
		justify-self: end;
		text-align: right;
	}

	.site-footer__legal-item:nth-child(3) {
		justify-self: center;
		text-align: center;
	}

	.site-footer__legal-item:nth-child(5) {
		justify-self: start;
		text-align: left;
	}

	.site-footer__legal-sep {
		margin: 0;
		padding: 0;
		justify-self: center;
		align-self: center;
		list-style: none;
	}

	.site-footer__legal-pipe {
		display: block;
		color: var(--color-text-muted);
		opacity: 0.55;
		font-weight: 400;
		line-height: 1;
		user-select: none;
	}

	.site-footer__legal-list a {
		display: inline-block;
		padding: 0.2rem 0;
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 600;
		letter-spacing: 0.02em;
		transition: color var(--transition-fast);
	}

	.site-footer__legal-list a:hover {
		color: var(--color-text);
	}

	.site-footer__copy {
		margin: 1rem 0 0;
		width: 100%;
		text-align: center;
		font-size: 0.6875rem;
		line-height: 1.65;
		letter-spacing: 0.03em;
		color: rgb(130 130 130 / 0.9);
		font-weight: 400;
		max-width: none;
	}

	.site-footer__copy-sep {
		display: inline-block;
		margin-inline: 0.5rem 0.65rem;
		color: var(--color-text-muted);
		font-weight: 500;
		font-size: 1em;
		opacity: 0.7;
		user-select: none;
	}

	.site-footer__credit-note {
		white-space: nowrap;
	}

	@media (max-width: 480px) {
		.site-footer__credit-note {
			white-space: normal;
		}
	}
</style>
