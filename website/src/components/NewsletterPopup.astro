---
/** Einmaliges Modal (localStorage `propus_nl_popup_v1`) — MailerLite Subscriber API. */
---

<dialog id="newsletter-popup-dialog" class="newsletter-popup__dialog" aria-labelledby="newsletter-popup-title">
	<div class="newsletter-popup__panel">
		<button type="button" class="newsletter-popup__close" aria-label="Schließen">&times;</button>
		<p class="newsletter-popup__eyebrow" id="newsletter-popup-title">Newsletter</p>
		<p class="newsletter-popup__lead">
			<strong>10&nbsp;% Rabatt</strong> auf Ihre nächste Online-Buchung — E-Mail eintragen und Gutscheincode sichern.
		</p>
		<form class="newsletter-popup__form" id="newsletter-popup-form" novalidate>
			<label class="visually-hidden" for="newsletter-popup-email">E-Mail</label>
			<input
				id="newsletter-popup-email"
				name="email"
				type="email"
				inputmode="email"
				autocomplete="email"
				required
				maxlength="254"
				class="newsletter-popup__input"
				placeholder="ihre@email.ch"
				aria-describedby="newsletter-popup-status"
			/>
			<input class="newsletter-popup__hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
			<button class="newsletter-popup__btn btn btn--primary" type="submit">Anmelden</button>
		</form>
		<p class="newsletter-popup__status" id="newsletter-popup-status" role="status" aria-live="polite"></p>
		<p class="newsletter-popup__legal">
			Mit der Anmeldung erhalten Sie gelegentlich News per E-Mail. Abmeldung jederzeit möglich.
			<a href="/datenschutz/">Datenschutz</a>
		</p>
	</div>
</dialog>

<script>
	(() => {
		const STORAGE_KEY = 'propus_nl_popup_v1';
		const DELAY_MS = 4200;

		function dismissPermanently() {
			try {
				localStorage.setItem(STORAGE_KEY, '1');
			} catch (_) {
				/* Private mode */
			}
		}

		function escapeHtml(s) {
			const d = document.createElement('div');
			d.textContent = s;
			return d.innerHTML;
		}

		const dialog = document.getElementById('newsletter-popup-dialog');
		const form = document.getElementById('newsletter-popup-form');
		const statusEl = document.getElementById('newsletter-popup-status');
		const closeBtn = document.querySelector('.newsletter-popup__close');

		if (!dialog || !form || !statusEl) return;

		let suppressDismissOnClose = false;

		dialog.addEventListener('close', () => {
			document.body.style.overflow = '';
			if (!suppressDismissOnClose) dismissPermanently();
			suppressDismissOnClose = false;
		});

		closeBtn?.addEventListener('click', () => dialog.close());

		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) dialog.close();
		});

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			statusEl.textContent = '';
			const fd = new FormData(form);
			const email = String(fd.get('email') ?? '').trim();
			const hp = String(fd.get('website') ?? '');
			if (!email) {
				statusEl.textContent = 'Bitte E-Mail-Adresse eingeben.';
				return;
			}
			try {
				const res = await fetch('/api/newsletter/subscribe', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, hp }),
				});
				const data = await res.json();
				if (!res.ok || !data.ok) {
					if (data.error === 'newsletter_not_configured') {
						statusEl.textContent = 'Newsletter ist momentan nicht verfügbar.';
					} else if (data.error === 'invalid_email') {
						statusEl.textContent = 'Bitte gültige E-Mail-Adresse eingeben.';
					} else {
						statusEl.textContent = 'Anmeldung fehlgeschlagen. Bitte später erneut versuchen.';
					}
					return;
				}
				form.reset();
				const pct = data.voucherPercent ?? 10;
				if (data.voucherCode) {
					statusEl.innerHTML =
						'Vielen Dank! Ihr <strong>' +
						pct +
						'&nbsp;%</strong>-Code: <strong class="newsletter-popup__code">' +
						escapeHtml(data.voucherCode) +
						'</strong>';
				} else {
					statusEl.textContent =
						'Vielen Dank! Sie erhalten den ' + pct + '-%-Code in Kürze per E-Mail.';
				}
				window.setTimeout(() => dialog.close(), 4200);
			} catch (_) {
				statusEl.textContent = 'Netzwerkfehler. Bitte später erneut versuchen.';
			}
		});

		function maybeOpen() {
			try {
				if (localStorage.getItem(STORAGE_KEY)) return;
			} catch (_) {
				return;
			}
			window.setTimeout(() => {
				try {
					if (localStorage.getItem(STORAGE_KEY)) return;
				} catch (_) {
					return;
				}
				if (!dialog.open) {
					dialog.showModal();
					document.body.style.overflow = 'hidden';
				}
			}, DELAY_MS);
		}

		maybeOpen();

		document.addEventListener('astro:page-load', () => {
			if (dialog.open) {
				suppressDismissOnClose = true;
				dialog.close();
			}
		});
	})();
</script>

<style>
	.newsletter-popup__dialog {
		max-width: calc(100vw - 2rem);
		width: min(22rem, 100%);
		padding: 0;
		border: none;
		border-radius: var(--radius-md);
		background: transparent;
		box-shadow: none;
	}

	.newsletter-popup__dialog::backdrop {
		background: rgba(15, 18, 22, 0.55);
		backdrop-filter: blur(3px);
	}

	html[data-theme='dark'] .newsletter-popup__dialog::backdrop {
		background: rgba(0, 0, 0, 0.65);
	}

	.newsletter-popup__panel {
		position: relative;
		padding: clamp(1.25rem, 4vw, 1.75rem);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-soft);
		text-align: center;
	}

	.newsletter-popup__close {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		font-size: 1.35rem;
		line-height: 1;
		color: var(--color-text-muted);
		background: transparent;
		border: none;
		border-radius: var(--radius-sm);
		cursor: pointer;
		transition:
			color var(--transition-fast),
			background var(--transition-fast);
	}

	.newsletter-popup__close:hover {
		color: var(--color-text);
		background: var(--color-bg-muted);
	}

	.newsletter-popup__close:focus-visible {
		outline: 2px solid var(--color-gold);
		outline-offset: 2px;
	}

	.newsletter-popup__eyebrow {
		margin: 0 0 0.35rem;
		font-size: 0.625rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.newsletter-popup__lead {
		margin: 0 0 0.85rem;
		font-size: 0.875rem;
		line-height: 1.45;
		color: var(--color-text-muted);
	}

	.newsletter-popup__lead strong {
		color: var(--color-text);
		font-weight: 650;
	}

	.newsletter-popup__form {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 0.5rem;
	}

	.newsletter-popup__input {
		flex: 1 1 10rem;
		min-width: 0;
		padding: 0.5rem 0.65rem;
		font-size: 0.875rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg-muted);
		color: var(--color-text);
	}

	.newsletter-popup__input:focus-visible {
		outline: 2px solid var(--color-gold);
		outline-offset: 2px;
	}

	.newsletter-popup__btn {
		flex: 0 0 auto;
		padding-inline: 1rem;
		font-size: 0.8125rem;
	}

	.newsletter-popup__hp {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	.newsletter-popup__status {
		min-height: 1.25rem;
		margin: 0.65rem 0 0;
		font-size: 0.8125rem;
		line-height: 1.45;
		color: var(--color-text);
	}

	.newsletter-popup__status :global(.newsletter-popup__code) {
		font-variant-numeric: tabular-nums;
		color: var(--color-gold-muted);
	}

	.newsletter-popup__legal {
		margin: 0.75rem 0 0;
		font-size: 0.6875rem;
		line-height: 1.45;
		color: var(--color-text-muted);
		opacity: 0.92;
	}

	.newsletter-popup__legal a {
		color: var(--color-text-muted);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.newsletter-popup__legal a:hover {
		color: var(--color-gold-muted);
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
