---
export const prerender = false;

import '../../styles/admin.css';
import { ADMIN_COOKIE, verifySessionToken } from '../../lib/cms/auth';
import { loadSiteBranding } from '../../lib/cms/resolve';

const branding = await loadSiteBranding();

const token = Astro.cookies.get(ADMIN_COOKIE)?.value;
if (verifySessionToken(token)) {
	/* 302 statt 301: sonst cached der Browser dauerhaft → ERR_TOO_MANY_REDIRECTS ohne Session */
	return Astro.redirect('/admin/portfolio', 302);
}
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Anmelden · Verwaltung</title>
		<link rel="icon" href={branding.faviconHref} type={branding.faviconType} />
	</head>
	<body class="admin-body admin-body--login">
		<div class="admin-login">
			<div class="admin-login__panel">
				<header class="admin-login__masthead">
					<a href="/" class="admin-login__brand">
						<img src={branding.logoSrc} alt="" class="admin-login__logo" />
						<span class="admin-login__brand-label">Backpanel</span>
					</a>
					<h1 class="admin-login__title">Anmelden</h1>
				</header>
				<div class="admin-msg admin-msg--err" id="login-err" hidden></div>
				<form id="login-form" class="admin-login__form">
					<div class="admin-field">
						<label for="user">Benutzername</label>
						<input id="user" name="username" type="text" autocomplete="username" required />
					</div>
					<div class="admin-field">
						<label for="pw">Passwort</label>
						<input id="pw" name="password" type="password" autocomplete="current-password" required />
					</div>
					<button type="submit" class="admin-btn admin-btn--primary admin-login__submit">Anmelden</button>
				</form>
			</div>
		</div>
		<script>
			document.getElementById('login-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const err = document.getElementById('login-err');
				const fd = new FormData(e.target as HTMLFormElement);
				const username = fd.get('username') as string;
				const password = fd.get('password') as string;
				if (err) {
					err.textContent = '';
					err.setAttribute('hidden', '');
				}
				const r = await fetch('/api/admin/login', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'same-origin',
					body: JSON.stringify({ username, password }),
				});
				if (r.ok) {
					window.location.href = '/admin/portfolio';
					return;
				}
				const j = await r.json().catch(() => ({}));
				if (err) {
					err.textContent = (j as { error?: string }).error || 'Anmeldung fehlgeschlagen.';
					err.removeAttribute('hidden');
				}
			});
		</script>
	</body>
</html>
