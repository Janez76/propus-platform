---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, impressum } from '../../content/site';
import { loadSeoPage } from '../../lib/seo';

const seoPage = await loadSeoPage('impressum');
const title = seoPage.title;

const websiteLabel = new URL(site.url).hostname.replace(/^www\./, '');
const websiteHref = site.url.replace(/\/$/, '') || site.url;
---

<BaseLayout
	{title}
	description={seoPage.description}
	ogImage={seoPage.ogImage}
	ogTitle={seoPage.ogTitle}
	ogDescription={seoPage.ogDescription}
	keywords={seoPage.keywords}
	noIndex={!seoPage.index}
>
	<section class="impressum u-container u-section" aria-labelledby="impressum-title">
		<header class="impressum__intro u-animate" style="--delay: 0ms">
			<h1 id="impressum-title">Impressum</h1>
			<p class="impressum__operator">
				Betreiberin der Marke <strong>{site.legalName}</strong>
			</p>
		</header>

		<div class="impressum__grid">
			<div class="impressum__col impressum__col--primary u-animate" style="--delay: 80ms">
				<address class="impressum__address">
					<span class="impressum__address-line">{site.addressLines[0]}</span>
					<span class="impressum__address-line">{impressum.addressLine2}</span>
				</address>

				<h2 class="impressum__section-title">Kontakt</h2>
				<ul class="impressum__contacts">
					<li>
						<span class="impressum__ico" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
								<path
									d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92z"
								/>
							</svg>
						</span>
						<a href={`tel:${site.phone}`}>{site.phoneDisplay}</a>
					</li>
					<li>
						<span class="impressum__ico" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2.5" y="5" width="19" height="14" rx="2" />
								<path d="M3 7l8.2 5.5a2 2 0 0 0 2.2 0L21 7" />
							</svg>
						</span>
						<a href={`mailto:${site.email}`}>{site.email}</a>
					</li>
					<li>
						<span class="impressum__ico" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10" />
								<path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
							</svg>
						</span>
						<a href={websiteHref} rel="noopener noreferrer">{websiteLabel}</a>
					</li>
				</ul>

				<p class="impressum__mgmt">
					<strong>Geschäftsführung:</strong>
					{impressum.management}
				</p>
			</div>

			<div class="impressum__col impressum__col--secondary u-animate" style="--delay: 140ms">
				<aside class="impressum__card" aria-labelledby="impressum-reg-heading">
					<h2 id="impressum-reg-heading" class="impressum__card-title">Registrierungsdetails</h2>
					<dl class="impressum__dl">
						<div class="impressum__dl-row">
							<dt>UID</dt>
							<dd>{impressum.uid}</dd>
						</div>
						<div class="impressum__dl-row">
							<dt>CH-ID</dt>
							<dd>{impressum.chId}</dd>
						</div>
					</dl>
				</aside>

				<section class="impressum__block" aria-labelledby="impressum-hr-heading">
					<h2 id="impressum-hr-heading" class="impressum__section-title">Handelsregistereintrag</h2>
					<p class="impressum__text">{impressum.registerIntro}</p>
					<p class="impressum__meta">
						<span class="impressum__meta-label">Registernummer</span>
						<span class="impressum__meta-value">{impressum.registerNumber}</span>
					</p>
					<p class="impressum__meta">
						<span class="impressum__meta-label">MwSt.-Nummer</span>
						<span class="impressum__meta-value">{impressum.vatNumber}</span>
					</p>
				</section>

				<section class="impressum__block impressum__block--disclaimer" aria-labelledby="impressum-disclaimer-heading">
					<h2 id="impressum-disclaimer-heading" class="impressum__section-title">Haftungsausschluss</h2>

					<h3 class="impressum__subhead">Haftung für Inhalte</h3>
					<p class="impressum__text">
						Wir bemühen uns, die Inhalte dieser Website richtig und aktuell zu halten. Für die
						Richtigkeit, Vollständigkeit und Aktualität übernehmen wir jedoch keine Gewähr. Als
						Diensteanbieter sind wir für eigene Inhalte nach den einschlägigen gesetzlichen
						Bestimmungen verantwortlich.
					</p>

					<h3 class="impressum__subhead">Haftung für Links</h3>
					<p class="impressum__text">
						Unsere Website kann Links zu externen Websites Dritter enthalten. Auf deren Inhalte haben
						wir keinen Einfluss; deshalb können wir für diese fremden Inhalte keine Gewähr
						übernehmen. Für die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter
						verantwortlich.
					</p>

					<h3 class="impressum__subhead">Urheberrecht</h3>
					<p class="impressum__text">
						Die durch uns erstellten Inhalte und Werke auf dieser Website unterliegen dem schweizerischen
						Urheberrecht. Vervielfältigung, Bearbeitung oder Verwertung ausserhalb der gesetzlichen
						Grenzen bedürfen der schriftlichen Zustimmung der {site.legalName}.
					</p>
				</section>
			</div>
		</div>

		<aside class="impressum__card impressum__card--wide u-animate" style="--delay: 200ms" aria-labelledby="impressum-legal-heading">
			<h2 id="impressum-legal-heading" class="impressum__card-title">Rechtliche Hinweise</h2>
			<p class="impressum__legal-lead">
				Diese Website und alle ihre Inhalte sind urheberrechtlich geschützt. Alle Rechte vorbehalten.
				Die Vervielfältigung, Bearbeitung, Verbreitung und jede Art der Verwertung ausserhalb der Grenzen
				des Urheberrechts bedürfen der schriftlichen Zustimmung der {site.legalName}.
			</p>
		</aside>
	</section>
</BaseLayout>

<style>
	.impressum {
		max-width: var(--content-max);
	}

	.impressum__intro {
		margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
		padding-bottom: clamp(1.25rem, 3vw, 1.75rem);
		border-bottom: 1px solid var(--color-border);
	}

	.impressum h1 {
		margin-bottom: 0.65rem;
		letter-spacing: -0.04em;
	}

	.impressum__operator {
		margin: 0;
		font-size: clamp(1.05rem, 2vw, 1.2rem);
		line-height: 1.45;
		color: var(--color-text-muted);
		font-weight: 500;
	}

	.impressum__operator strong {
		color: var(--color-text);
		font-weight: 650;
	}

	.impressum__grid {
		display: grid;
		gap: clamp(1.75rem, 4vw, 2.75rem);
		align-items: start;
	}

	@media (min-width: 900px) {
		.impressum__grid {
			grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
			gap: clamp(2rem, 5vw, 3.5rem);
		}
	}

	.impressum__address {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		margin: 0 0 1.5rem;
		font-size: 0.9375rem;
		line-height: 1.6;
		font-style: normal;
		color: var(--color-text-muted);
	}

	.impressum__address-line {
		display: block;
	}

	.impressum__section-title {
		margin: 0 0 0.85rem;
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-gold-muted);
	}

	.impressum__contacts {
		list-style: none;
		margin: 0 0 1.75rem;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.impressum__contacts li {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		font-size: 0.9375rem;
	}

	.impressum__contacts a {
		color: var(--color-text);
		font-weight: 500;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
		transition: color var(--transition-fast);
	}

	.impressum__contacts a:hover {
		color: var(--color-gold-muted);
	}

	.impressum__ico {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: var(--radius-sm);
		color: var(--color-gold-muted);
		background: rgb(184 149 106 / 0.1);
	}

	.impressum__mgmt {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.65;
		color: var(--color-text-muted);
		max-width: 28rem;
	}

	.impressum__mgmt strong {
		color: var(--color-text);
		font-weight: 600;
	}

	.impressum__card {
		padding: clamp(1.25rem, 3vw, 1.65rem) clamp(1.35rem, 3.2vw, 1.85rem);
		border-radius: 1rem;
		background: linear-gradient(165deg, rgb(252 252 252), rgb(247 246 244));
		border: 1px solid rgb(0 0 0 / 0.06);
		box-shadow: var(--shadow-border), 0 1px 0 rgb(255 255 255 / 0.9) inset;
	}

	.impressum__card--wide {
		margin-top: clamp(1.75rem, 4vw, 2.5rem);
	}

	.impressum__card-title {
		margin: 0 0 1.1rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid rgb(0 0 0 / 0.07);
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.impressum__dl {
		margin: 0;
		padding: 0;
	}

	.impressum__dl-row {
		display: grid;
		grid-template-columns: 5.5rem minmax(0, 1fr);
		gap: 0.75rem 1rem;
		padding: 0.7rem 0;
		border-bottom: 1px solid rgb(0 0 0 / 0.06);
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.impressum__dl-row:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.impressum__dl-row:first-child {
		padding-top: 0;
	}

	.impressum__dl dt {
		margin: 0;
		font-weight: 600;
		color: var(--color-text-muted);
	}

	.impressum__dl dd {
		margin: 0;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.02em;
		color: var(--color-text);
	}

	.impressum__block {
		margin-top: clamp(1.35rem, 3vw, 1.75rem);
	}

	.impressum__col--secondary .impressum__card + .impressum__block {
		margin-top: clamp(1.5rem, 3.5vw, 2rem);
	}

	.impressum__text {
		margin: 0 0 1rem;
		font-size: 0.875rem;
		line-height: 1.72;
		color: var(--color-text-muted);
	}

	.impressum__text:last-child {
		margin-bottom: 0;
	}

	.impressum__meta {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		margin: 0 0 0.65rem;
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.impressum__meta:last-of-type {
		margin-bottom: 0;
	}

	.impressum__meta-label {
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.impressum__meta-value {
		font-weight: 600;
		color: var(--color-text);
	}

	.impressum__subhead {
		margin: 1.25rem 0 0.5rem;
		font-size: 0.9375rem;
		font-weight: 650;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.impressum__subhead:first-of-type {
		margin-top: 0.35rem;
	}

	.impressum__block--disclaimer .impressum__section-title {
		margin-bottom: 0.5rem;
	}

	.impressum__legal-lead {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.75;
		color: var(--color-text-muted);
	}

	@media (max-width: 599px) {
		.impressum__dl-row {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
