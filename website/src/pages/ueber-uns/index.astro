---
export const prerender = false;

import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { site } from '../../content/site';
import { companyStory, behindTheScenesImage, type TeamMember } from '../../content/team';
import { loadSiteTeam } from '../../lib/cms/resolve';
import { loadSeoPage } from '../../lib/seo';

const seoPage = await loadSeoPage('ueber-uns');
const title = seoPage.title;
const description = seoPage.description;

const teamMembers = await loadSiteTeam();

const teamForScript = teamMembers.map((m) => ({
	id: m.id,
	name: m.name,
	role: m.role,
	email: m.email,
	bio: [...m.bio],
	imageSrc: m.imageSrc ?? null,
	imageAlt: m.imageAlt ?? m.name,
}));

const companyForScript = {
	eyebrow: companyStory.eyebrow,
	title: companyStory.title,
	paragraphs: [...companyStory.paragraphs],
};
---

<BaseLayout
	{title}
	{description}
	ogImage={seoPage.ogImage}
	ogTitle={seoPage.ogTitle}
	ogDescription={seoPage.ogDescription}
	keywords={seoPage.keywords}
	noIndex={!seoPage.index}
>
	<section class="about-page-intro u-container">
		<div class="about-page-intro__inner u-animate" style="--delay: 40ms">
			<SectionHeading
				eyebrow="Unternehmen"
				title="Über uns"
				subtitle="Familiengeführt, mit Sitz in Zug – für die visuelle Vermarktung Ihrer Immobilien schweizweit im Einsatz."
				align="center"
				titleAs="h1"
				titleSize="display"
			/>
		</div>
	</section>

	<section class="about-signature" aria-labelledby="about-signature-heading">
		<div class="about-signature__glow" aria-hidden="true"></div>
		<div class="u-container about-signature__wrap">
			<div class="about-signature__grid">
				<div class="about-signature__text u-animate" style="--delay: 100ms">
					<p class="u-eyebrow about-signature__eyebrow">Was uns ausmacht</p>
					<h2 id="about-signature-heading" class="about-signature__title">Klar. Ruhig. Überzeugend.</h2>
					<div class="divider-gold about-signature__divider" aria-hidden="true"></div>
					<p class="about-signature__lead">
						Die {site.legalName} widmet sich ausschliesslich hochwertiger, visueller Immobilienvermarktung. Wir
						kombinieren bewährte Methoden mit aktueller Technik – von Fotografie und Drohnenaufnahmen über 360°-Touren
						bis zu fotorealistischen Visualisierungen.
					</p>
					<p class="about-signature__body">
						Zuverlässigkeit, Qualität und persönliche Betreuung stehen bei uns im Mittelpunkt. Unser Anspruch: jede
						Immobilie klar, ruhig und überzeugend zu zeigen – damit sie zum Blickfang wird, ohne aufdringlich zu wirken.
					</p>
					<button
						type="button"
						class="about-link-cta about-link-cta--on-dark about-signature__cta"
						data-about-open="company"
						aria-haspopup="dialog"
					>
						<span>Unternehmensgeschichte</span>
						<span class="about-link-cta__arrow" aria-hidden="true">→</span>
					</button>
				</div>
				<button
					type="button"
					class="about-signature__visual u-animate"
					style="--delay: 160ms"
					data-about-open="company"
					aria-haspopup="dialog"
					aria-label="Unternehmensgeschichte öffnen"
				>
					<span class="about-signature__frame">
						<Image
							src={behindTheScenesImage.src}
							alt=""
							role="presentation"
							width={behindTheScenesImage.width}
							height={behindTheScenesImage.height}
							loading="lazy"
							class="about-signature__img"
						/>
						<span class="about-signature__shine" aria-hidden="true"></span>
						<span class="about-signature__vignette" aria-hidden="true"></span>
					</span>
				</button>
			</div>
		</div>
	</section>

	<section class="u-section about-page-team">
		<div class="u-container">
			<header class="about-page-team__head u-animate" style="--delay: 200ms">
				<h2 class="about-page-team__title">Unser Team</h2>
				<div class="divider-gold about-page-team__divider" aria-hidden="true"></div>
				<p class="about-page-team__lede">
					Lernen Sie unser Team besser kennen – mit Hintergrund und Rollen hinter Propus.
				</p>
			</header>
			<div class="team-grid">
				{
					teamMembers.map((member: TeamMember, index: number) => (
						<article class:list={['team-card', 'u-animate']} style={`--delay: ${220 + index * 40}ms`}>
							<div
								class:list={[
									'team-card__frame',
									!member.imageSrc && 'team-card__frame--placeholder',
								]}
							>
								{member.imageSrc ? (
									<Image
										src={member.imageSrc}
										alt=""
										role="presentation"
										width={member.width ?? 640}
										height={member.height ?? 800}
										loading="lazy"
										class="team-card__img"
									/>
								) : (
									<span class="team-card__initials" aria-hidden="true">
										{member.name
											.split(' ')
											.map((p) => p[0])
											.join('')}
									</span>
								)}
								<div class="team-card__overlay">
									<div class="team-card__caption">
										<span class="team-card__name">{member.name}</span>
										<span class="team-card__role">{member.role}</span>
										<a
											class="team-card__email"
											href={`mailto:${member.email}`}
											aria-label={`E-Mail an ${member.name}, ${member.email}`}
										>
											<svg
												class="team-card__email-icon"
												width="16"
												height="16"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="1.75"
												stroke-linecap="round"
												stroke-linejoin="round"
												aria-hidden="true"
											>
												<rect width="20" height="14" x="2" y="5" rx="2"></rect>
												<path d="m2 5 10 7 10-7"></path>
											</svg>
											<span>E-Mail</span>
										</a>
									</div>
								</div>
							</div>
							<button
								type="button"
								class="about-link-cta about-link-cta--on-light team-card__cta"
								data-about-open="member"
								data-member-id={member.id}
								aria-haspopup="dialog"
							>
								<span>Mehr über mich</span>
								<span class="about-link-cta__arrow" aria-hidden="true">→</span>
							</button>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<dialog id="about-dialog" class="about-dialog" aria-labelledby="about-dialog-title">
		<div class="about-dialog__panel">
			<button type="button" class="about-dialog__close" data-about-close aria-label="Schliessen">
				<span aria-hidden="true">×</span>
			</button>
			<div class="about-dialog__layout">
				<div class="about-dialog__visual" data-about-dialog-visual hidden>
					<img class="about-dialog__photo" src="" alt="" width="640" height="800" loading="lazy" />
				</div>
				<div class="about-dialog__copy">
					<p class="u-eyebrow about-dialog__eyebrow" data-about-dialog-eyebrow></p>
					<h2 id="about-dialog-title" class="about-dialog__title" data-about-dialog-title></h2>
					<p class="about-dialog__role" data-about-dialog-role hidden></p>
					<div class="about-dialog__rule" aria-hidden="true"></div>
					<div class="about-dialog__bio" data-about-dialog-bio></div>
				</div>
			</div>
		</div>
	</dialog>
</BaseLayout>

<script
	define:vars={{
		teamForScript,
		companyForScript,
	}}
>
	const teamById = Object.fromEntries(teamForScript.map((m) => [m.id, m]));

	function qs(sel, root = document) {
		return root.querySelector(sel);
	}

	function openAboutDialog() {
		const dialog = qs('#about-dialog');
		if (dialog && typeof dialog.showModal === 'function') {
			dialog.showModal();
			queueMicrotask(() => qs('[data-about-close]', dialog)?.focus());
		}
	}

	function setBio(container, paragraphs) {
		container.textContent = '';
		for (const text of paragraphs) {
			const p = document.createElement('p');
			p.textContent = text;
			container.appendChild(p);
		}
	}

	function showMember(id) {
		const m = teamById[id];
		if (!m) return;
		const dialog = qs('#about-dialog');
		dialog?.classList.remove('about-dialog--company');
		dialog?.classList.add('about-dialog--member');
		const visual = qs('[data-about-dialog-visual]', dialog);
		const img = qs('.about-dialog__photo', dialog);
		const eyebrow = qs('[data-about-dialog-eyebrow]', dialog);
		const titleEl = qs('[data-about-dialog-title]', dialog);
		const roleEl = qs('[data-about-dialog-role]', dialog);
		const bio = qs('[data-about-dialog-bio]', dialog);

		eyebrow.textContent = 'Team';
		titleEl.textContent = m.name;
		roleEl.textContent = m.role;
		roleEl.hidden = false;
		setBio(bio, m.bio);

		if (visual) visual.hidden = true;
		if (img) {
			img.removeAttribute('src');
			img.alt = '';
		}

		openAboutDialog();
	}

	function showCompany() {
		const dialog = qs('#about-dialog');
		dialog?.classList.add('about-dialog--company');
		dialog?.classList.remove('about-dialog--member');
		const visual = qs('[data-about-dialog-visual]', dialog);
		const img = qs('.about-dialog__photo', dialog);
		const eyebrow = qs('[data-about-dialog-eyebrow]', dialog);
		const titleEl = qs('[data-about-dialog-title]', dialog);
		const roleEl = qs('[data-about-dialog-role]', dialog);
		const bio = qs('[data-about-dialog-bio]', dialog);

		eyebrow.textContent = companyForScript.eyebrow;
		titleEl.textContent = companyForScript.title;
		roleEl.hidden = true;
		setBio(bio, companyForScript.paragraphs);

		if (visual) visual.hidden = true;
		if (img) {
			img.removeAttribute('src');
			img.alt = '';
		}

		openAboutDialog();
	}

	function onDocClick(e) {
		/* Ohne Dialog (andere Seite oder noch nicht im DOM): ignorieren – verhindert auch Leaks bei View Transitions */
		if (!document.getElementById('about-dialog')) return;
		const t = e.target;
		if (!(t instanceof Element)) return;
		const closeBtn = t.closest('[data-about-close]');
		if (closeBtn) {
			const dialog = qs('#about-dialog');
			dialog?.close();
			return;
		}
		const openEl = t.closest('[data-about-open]');
		if (!openEl) return;
		const mode = openEl.getAttribute('data-about-open');
		if (mode === 'company') {
			e.preventDefault();
			showCompany();
			return;
		}
		if (mode === 'member') {
			const id = openEl.getAttribute('data-member-id');
			if (id) {
				e.preventDefault();
				showMember(id);
			}
		}
	}

	function onDialogClick(e) {
		const dialog = qs('#about-dialog');
		if (e.target === dialog) dialog?.close();
	}

	function bindDialog() {
		const dialog = qs('#about-dialog');
		if (!dialog) return;
		dialog.removeEventListener('click', onDialogClick);
		dialog.addEventListener('click', onDialogClick);
	}

	function initAboutPage() {
		document.removeEventListener('click', onDocClick);
		document.addEventListener('click', onDocClick);
		bindDialog();
	}

	function teardownAboutPage() {
		document.removeEventListener('click', onDocClick);
		const dialog = qs('#about-dialog');
		dialog?.removeEventListener('click', onDialogClick);
	}

	function setupAboutModals() {
		teardownAboutPage();
		if (!document.getElementById('about-dialog')) return;
		initAboutPage();
	}

	document.addEventListener('astro:page-load', setupAboutModals);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupAboutModals, { once: true });
	} else {
		queueMicrotask(setupAboutModals);
	}
</script>

<style>
	/* Wie Portfolio / Dienstleistungen */
	.about-page-intro {
		padding-top: calc(var(--space-xl) + var(--space-md));
		padding-bottom: clamp(1.5rem, 3vw, 2.25rem);
	}

	.about-page-intro :global(.section-heading) {
		margin-bottom: 0;
	}

	.about-page-intro :global(.section-heading__inner) {
		max-width: 44rem;
	}

	.about-page-intro :global(.section-heading--center .section-heading__inner) {
		max-width: 46rem;
	}

	/* Editorial-Block im Duktus von Hero + Schluss-CTA: dunkel, Gold, grosses Bild */
	.about-signature {
		position: relative;
		padding-block: clamp(3.25rem, 9vw, 5.75rem);
		background: linear-gradient(168deg, #161616 0%, #0a0a0a 45%, #111 100%);
		color: #fff;
		overflow: hidden;
		border-block: 1px solid rgb(255 255 255 / 0.06);
	}

	/* Dark Mode: gleicher Hintergrund wie Footer (`--color-bg-muted` in global.css) */
	:global(html[data-theme='dark']) .about-signature {
		background: var(--color-bg-muted);
		color: var(--color-text);
		border-block-color: var(--color-border);
	}

	:global(html[data-theme='dark']) .about-signature__title {
		color: var(--color-text);
	}

	:global(html[data-theme='dark']) .about-signature__lead {
		color: var(--color-text);
	}

	:global(html[data-theme='dark']) .about-signature__body {
		color: var(--color-text-muted);
	}

	.about-signature__glow {
		position: absolute;
		inset: auto;
		pointer-events: none;
		width: min(52rem, 90vw);
		height: min(28rem, 55vh);
		top: -18%;
		right: -12%;
		background: radial-gradient(ellipse at 45% 45%, rgb(180 180 175 / 0.10) 0%, transparent 62%);
		filter: blur(36px);
		opacity: 0.9;
	}

	.about-signature__wrap {
		position: relative;
		z-index: 1;
	}

	.about-signature__grid {
		display: grid;
		gap: clamp(2.25rem, 5vw, 3.25rem);
		align-items: center;
	}

	@media (min-width: 960px) {
		.about-signature__grid {
			grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
			gap: clamp(2.5rem, 6vw, 5rem);
		}
	}

	.about-signature__eyebrow {
		color: var(--color-gold-line);
		margin-bottom: var(--space-sm);
	}

	.about-signature__title {
		margin: 0 0 var(--space-sm);
		font-size: clamp(1.85rem, 4.2vw, 2.75rem);
		font-weight: 600;
		letter-spacing: -0.038em;
		line-height: 1.07;
		color: #fff;
		max-width: 15ch;
	}

	.about-signature__divider {
		margin-block: var(--space-md) var(--space-lg);
	}

	.about-signature__lead,
	.about-signature__body {
		font-size: 1.0625rem;
		line-height: 1.68;
		margin: 0 0 var(--space-md);
		max-width: 38rem;
		color: rgb(255 255 255 / 0.74);
	}

	.about-signature__lead {
		color: rgb(255 255 255 / 0.92);
		font-weight: 500;
	}

	.about-signature__body {
		margin-bottom: 0;
	}

	/**
	 * Text-CTA mit Pfeil (wie Link-CTA der Site, ohne Button-Fläche).
	 * --on-dark: Signatur-Sektion | --on-light: Team unter hellem Grund
	 */
	/* Wie globale `.link-cta` (Startseite „Leistungen ansehen →“): keine Kapitälchen */
	.about-link-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0;
		border: none;
		background: none;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		cursor: pointer;
		text-decoration: none;
		border-bottom: 1px solid currentColor;
		padding-bottom: 0.2rem;
		transition:
			color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.about-link-cta--on-dark {
		color: var(--color-gold-line);
		border-bottom-color: rgb(197 160 115 / 0.5);
	}

	.about-link-cta--on-dark:hover,
	.about-link-cta--on-dark:focus-visible {
		color: rgb(232 210 170);
		border-bottom-color: rgb(232 210 170 / 0.85);
	}

	.about-link-cta--on-light {
		color: var(--color-text);
		border-bottom-color: var(--color-border);
	}

	.about-link-cta--on-light:hover,
	.about-link-cta--on-light:focus-visible {
		color: var(--color-gold-muted);
		border-bottom-color: var(--color-gold);
	}

	.about-link-cta:focus-visible {
		outline: 2px solid var(--color-gold);
		outline-offset: 4px;
		border-radius: 1px;
	}

	.about-signature__cta {
		margin-top: var(--space-lg);
	}

	.about-link-cta__arrow {
		transition: transform 0.35s var(--btn-motion-ease);
	}

	@media (prefers-reduced-motion: no-preference) {
		.about-link-cta:hover .about-link-cta__arrow,
		.about-link-cta:focus-visible .about-link-cta__arrow {
			transform: translateX(4px);
		}
	}

	.about-signature__visual {
		display: block;
		width: 100%;
		padding: 0;
		margin: 0;
		border: none;
		background: none;
		cursor: pointer;
		text-align: left;
		border-radius: calc(var(--radius-md) + 1px);
	}

	.about-signature__visual:focus-visible {
		outline: 2px solid var(--color-gold-line);
		outline-offset: 5px;
	}

	.about-signature__frame {
		position: relative;
		display: block;
		border-radius: var(--radius-md);
		overflow: hidden;
		aspect-ratio: 16 / 10;
		box-shadow:
			0 0 0 1px rgb(255 255 255 / 0.1),
			0 32px 100px -28px rgb(0 0 0 / 0.92),
			inset 0 1px 0 rgb(255 255 255 / 0.07);
	}

	.about-signature__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transform: scale(1.06);
		transform-origin: 50% 42%;
		transition: transform 0.85s var(--btn-motion-ease);
	}

	.about-signature__shine {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(
			118deg,
			transparent 38%,
			rgb(255 255 255 / 0.055) 48%,
			transparent 58%
		);
	}

	.about-signature__vignette {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: radial-gradient(ellipse 90% 88% at 50% 48%, transparent 35%, rgb(0 0 0 / 0.42) 100%);
	}

	@media (prefers-reduced-motion: no-preference) {
		.about-signature__visual:hover .about-signature__img,
		.about-signature__visual:focus-visible .about-signature__img {
			transform: scale(1.1);
		}
	}

	@media (max-width: 959px) {
		.about-signature__visual {
			order: -1;
		}
	}

	.about-page-team {
		padding-top: clamp(2rem, 4vw, var(--space-xl));
	}

	.about-page-team__head {
		text-align: center;
		max-width: 32rem;
		margin-inline: auto;
		margin-bottom: clamp(2rem, 4vw, var(--space-lg));
	}

	.about-page-team__title {
		font-size: clamp(1.5rem, 2.8vw, 2.125rem);
		margin-bottom: var(--space-sm);
		color: var(--color-text);
	}

	.about-page-team__divider {
		margin-inline: auto;
		margin-bottom: var(--space-sm);
	}

	.about-page-team__lede {
		font-size: 0.9375rem;
		margin: 0;
		color: var(--color-text-muted);
	}

	.team-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.75rem, 4vw, 2.5rem);
		max-width: 58rem;
		margin-inline: auto;
	}

	@media (min-width: 520px) {
		.team-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 900px) {
		.team-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: clamp(2rem, 4vw, 2.75rem);
			max-width: 72rem;
		}
	}

	.team-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0;
	}

	/* Flach, nur feine Linie: ein Border, kein Schatten → keine Ecken-Artefakte. */
	.team-card__frame {
		position: relative;
		width: 100%;
		aspect-ratio: 4 / 5;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-bg-muted);
		border: 1px solid var(--color-border);
		box-shadow: none;
	}

	/* Neutrales Grau statt Token-Mischung an den Rundungen (wirkt sonst leicht warm/goldig). */
	:global(html[data-theme='dark']) .team-card__frame {
		border-color: rgb(255 255 255 / 0.1);
	}

	.team-card__frame--placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.team-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.55s var(--btn-motion-ease);
	}

	@media (prefers-reduced-motion: no-preference) {
		.team-card:hover .team-card__img {
			transform: scale(1.02);
		}
	}

	.team-card__initials {
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		color: var(--color-text-muted);
	}

	.team-card__overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		pointer-events: none;
	}

	.team-card__caption {
		width: 100%;
		padding: 0.75rem 1rem 0.8rem;
		background: var(--color-surface);
		/* Kein border-top: trifft den linken Kartenrand → in der Ecke oft gold/warm wirkender Miter. */
		border-radius: 0;
		display: flex;
		flex-direction: column;
