---
export const prerender = false;

import GuidelineLayout from '../../layouts/GuidelineLayout.astro';
---

<GuidelineLayout title="Willkommen">
	<a href="/guideline/" slot="actions" class="guideline-btn guideline-btn--ghost">Übersicht</a>
	<button
		slot="actions"
		type="button"
		class="guideline-btn guideline-btn--ghost"
		id="guideline-logout">Abmelden</button>

	<article class="guideline-prose">
		<h2>Interne Guidelines</h2>
		<p>
			Diese Seiten sind nur für das Propus-Team bestimmt. Inhalte werden direkt im Repo unter{' '}
			<code>website/src/pages/guideline/</code> gepflegt (statische Astro-Seiten).
		</p>
		<p>
			<strong>Downloads:</strong> Einträge und Dateien unter{' '}
			<code>website/src/lib/guideline-static.ts</code> bzw.{' '}
			<code>private-guideline-assets/files/</code>.
		</p>
	</article>

	<script>
		document.getElementById('guideline-logout')?.addEventListener('click', async () => {
			await fetch('/api/guideline/logout', {
				method: 'POST',
				credentials: 'same-origin',
			});
			window.location.href = '/guideline/login';
		});
	</script>
</GuidelineLayout>
