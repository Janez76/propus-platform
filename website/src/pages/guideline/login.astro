---
export const prerender = false;

import '../../styles/guideline.css';
import { GUIDELINE_COOKIE, verifyGuidelineSessionToken } from '../../lib/guideline-auth';

const token = Astro.cookies.get(GUIDELINE_COOKIE)?.value;
if (verifyGuidelineSessionToken(token)) {
	const redir = Astro.url.searchParams.get('redirect');
	const safe =
		redir &&
		redir.startsWith('/') &&
		!redir.startsWith('//') &&
		redir.startsWith('/guideline')
			? redir
			: '/guideline/';
	return Astro.redirect(safe, 302);
}
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Anmelden · Guideline</title>
	</head>
	<body class="guideline-body">
		<div class="guideline-login-panel">
			<h1>Interne Guidelines</h1>
			<p class="guideline-empty">Passwort erforderlich.</p>
			<div class="guideline-msg--err" id="guideline-login-err" hidden></div>
			<form id="guideline-login-form">
				<div class="guideline-field">
					<label for="guideline-pw">Passwort</label>
					<div class="guideline-input-wrap">
						<input
							id="guideline-pw"
							name="password"
							type="password"
							autocomplete="current-password"
							required
						/>
						<button
							type="button"
							class="guideline-toggle-pw"
							id="guideline-toggle-pw"
							aria-label="Passwort anzeigen"
							aria-pressed="false"
						>
							<span class="guideline-eye-show" aria-hidden="true">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
							</span>
							<span class="guideline-eye-hide" hidden aria-hidden="true">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.182 4.182L12 12m0 0l.375-.375" />
								</svg>
							</span>
						</button>
					</div>
				</div>
				<button type="submit" class="guideline-btn">Anmelden</button>
			</form>
		</div>
		<script>
			function safeRedirect(raw) {
				if (!raw || !raw.startsWith('/') || raw.startsWith('//')) return '/guideline/';
				if (!raw.startsWith('/guideline')) return '/guideline/';
				return raw;
			}

			(function initPwToggle() {
				const input = document.getElementById('guideline-pw');
				const btn = document.getElementById('guideline-toggle-pw');
				const showIcon = document.querySelector('.guideline-eye-show');
				const hideIcon = document.querySelector('.guideline-eye-hide');
				if (!input || !btn || !showIcon || !hideIcon) return;

				btn.addEventListener('click', () => {
					const plain = input.type === 'text';
					if (plain) {
						input.type = 'password';
						btn.setAttribute('aria-pressed', 'false');
						btn.setAttribute('aria-label', 'Passwort anzeigen');
						showIcon.hidden = false;
						hideIcon.hidden = true;
					} else {
						input.type = 'text';
						btn.setAttribute('aria-pressed', 'true');
						btn.setAttribute('aria-label', 'Passwort verbergen');
						showIcon.hidden = true;
						hideIcon.hidden = false;
					}
				});
			})();

			document.getElementById('guideline-login-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const errEl = document.getElementById('guideline-login-err');
				const fd = new FormData(/** @type {HTMLFormElement} */ (e.target));
				const password = fd.get('password');
				if (errEl) {
					errEl.textContent = '';
					errEl.setAttribute('hidden', '');
				}
				const r = await fetch('/api/guideline/login', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'same-origin',
					body: JSON.stringify({ password }),
				});
				if (r.ok) {
					const params = new URLSearchParams(window.location.search);
					window.location.href = safeRedirect(params.get('redirect'));
					return;
				}
				const j = await r.json().catch(() => ({}));
				if (errEl) {
					errEl.textContent = j.error || 'Anmeldung fehlgeschlagen.';
					errEl.removeAttribute('hidden');
				}
			});
		</script>
	</body>
</html>
