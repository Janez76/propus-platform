---
export const prerender = false;

import GuidelineLayout from '../../layouts/GuidelineLayout.astro';
import { GUIDELINE_DOWNLOADS, GUIDELINE_PAGES } from '../../lib/guideline-static';
---

<GuidelineLayout title="Übersicht">
	<button
		slot="actions"
		type="button"
		class="guideline-btn guideline-btn--ghost"
		id="guideline-logout">Abmelden</button>

	<section>
		<h2 class="guideline-section-title">Anleitungen</h2>
		{
			GUIDELINE_PAGES.length === 0 ? (
				<p class="guideline-empty">Noch keine Einträge in guideline-static.ts.</p>
			) : (
				<ul class="guideline-list">
					{GUIDELINE_PAGES.map((p) => (
						<li>
							<a href={p.href}>{p.title}</a>
							{p.category && <span class="guideline-meta">· {p.category}</span>}
						</li>
					))}
				</ul>
			)
		}
	</section>

	<section>
		<h2 class="guideline-section-title">Downloads</h2>
		{
			GUIDELINE_DOWNLOADS.length === 0 ? (
				<p class="guideline-empty">
					Keine Downloads eingetragen — in{' '}
					<code>website/src/lib/guideline-static.ts</code> ergänzen.
				</p>
			) : (
				<ul class="guideline-list">
					{GUIDELINE_DOWNLOADS.map((f) => (
						<li>
							<a href={`/api/guideline/download?id=${encodeURIComponent(f.id)}`}>
								{f.title}
							</a>
							<span class="guideline-meta">({f.id})</span>
						</li>
					))}
				</ul>
			)
		}
	</section>

	<script>
		document.getElementById('guideline-logout')?.addEventListener('click', async () => {
			await fetch('/api/guideline/logout', {
				method: 'POST',
				credentials: 'same-origin',
			});
			window.location.href = '/guideline/login';
		});
	</script>
</GuidelineLayout>
