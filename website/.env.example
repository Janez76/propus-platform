# Kopieren nach .env und Werte eintragen (nie committen).

# Pflicht für Build, SSR und Admin: Supabase (CMS + Storage). Ohne diese Variablen schlägt readCms/writeCms fehl.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Supabase Image Transform ausschalten, falls URLs 404 liefern (Projekt ohne Transform).
# PUBLIC_SUPABASE_IMG_TRANSFORM=0

# Optional: Branding ohne lokale Dateien unter public/ (öffentliche URLs, z. B. Supabase Storage „cms“).
# PUBLIC_SITE_LOGO_URL=
# PUBLIC_SITE_FAVICON_URL=

# Optional: URL des Buchungs-Katalogs (JSON). Standard: https://api-booking.propus.ch/api/catalog/products
# PUBLIC_BOOKING_CATALOG_URL=

# Newsletter (Footer): Mailchimp Audience — API-Key wie im Mailchimp-Dashboard (Marketing API)
MAILCHIMP_API_KEY=
MAILCHIMP_DC=us22
MAILCHIMP_NEWSLETTER_LIST_ID=
# Optional: Mailchimp-Tag für neue Abonnenten (Audience → nach Tag filtern). Standard: «Newsletter Website — 10% Gutschein»
# MAILCHIMP_NEWSLETTER_TAG=
# Optional: Nach Anmeldung im Browser anzeigen — gleicher Code muss als Rabattcode im Buchungstool angelegt sein (z. B. 10 %).
# NEWSLETTER_VOUCHER_CODE=

# SQL im Editor ausführen: 001_cms_state.sql, 002_storage_cms_bucket.sql, optional 003_storage_cms_bucket_limit.sql (grosses Video).
# Einmalig lokale Uploads: npm run migrate:uploads
# Komplettimport data/cms.json → Supabase + Storage: npm run import:cms
