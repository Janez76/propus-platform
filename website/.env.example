# Kopieren nach .env und Werte eintragen (nie committen).

# Pflicht für Build, SSR und Admin: Supabase (CMS + Storage). Ohne diese Variablen schlägt readCms/writeCms fehl.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Supabase Image Transform ausschalten, falls URLs 404 liefern (Projekt ohne Transform).
# PUBLIC_SUPABASE_IMG_TRANSFORM=0

# Optional: Branding ohne lokale Dateien unter public/ (öffentliche URLs, z. B. Supabase Storage „cms“).
# PUBLIC_SITE_LOGO_URL=
# PUBLIC_SITE_FAVICON_URL=

# Optional: URL des Buchungs-Katalogs (JSON). Standard: https://api-booking.propus.ch/api/catalog/products
# PUBLIC_BOOKING_CATALOG_URL=

# Interner Guideline-Bereich (/guideline, nur mit Session-Cookie)
# GUIDELINE_SECRET=
# GUIDELINE_PASSWORD=
# Optional bei eigenem Hostnamen (Login-POST): kommagetrennt
# GUIDELINE_CSRF_ORIGINS=https://guideline.propus.ch

# Newsletter-Popup (MailerLite): API-Token + Gruppen-ID(n), Komma-getrennt bei mehreren Gruppen
MAILERLITE_API_KEY=
MAILERLITE_NEWSLETTER_GROUP_ID=
# Optional: Rabattcode nach Anmeldung im Popup (gleicher Code im Buchungstool als Rabattcode anlegen)
# NEWSLETTER_VOUCHER_CODE=

# Kontaktformular (/kontakt) — Cloudflare Turnstile + SMTP-Versand
# Site-Key in Cloudflare Dashboard → Turnstile anlegen (Hostnames: propus.ch, www.propus.ch)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# SMTP-Versand. Default: Microsoft 365 (smtp.office365.com:587 STARTTLS).
# Für M365 ggf. App-Password anlegen (SMTP-Auth muss im Tenant erlaubt sein).
# Alternative: lokales Postfix auf dem VPS → CONTACT_SMTP_HOST=localhost CONTACT_SMTP_PORT=25 (USER/PASS leer lassen)
CONTACT_SMTP_HOST=smtp.office365.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
# Absender (sollte zum SMTP_USER passen bzw. Send-As-Berechtigung haben) und Empfänger
CONTACT_FROM="Propus Website <office@propus.ch>"
CONTACT_TO=office@propus.ch

# SQL im Editor ausführen: 001_cms_state.sql, 002_storage_cms_bucket.sql, optional 003_storage_cms_bucket_limit.sql (grosses Video).
# Einmalig lokale Uploads: npm run migrate:uploads
# Komplettimport data/cms.json → Supabase + Storage: npm run import:cms
