# Kopie nach .env.logto und Werte aus Logto Admin Console eintragen.
# Nicht committen: .env.logto ist in .gitignore.
#
# Login-Oberfläche im Propus-Stil (Farben, Logo, Custom CSS): docs/VPS-BETRIEB.md
# → Abschnitt „Logto-Apps (SSO)“ / „Sign-in im Propus-Stil (Branding)“.
# Automatisierung (Management API): node auth/apply-logto-propus-branding.js

# Propus Booking
PROPUS_BOOKING_LOGTO_APP_ID=
PROPUS_BOOKING_LOGTO_APP_SECRET=

# Propus Tours Admin
PROPUS_TOURS_ADMIN_LOGTO_APP_ID=
PROPUS_TOURS_ADMIN_LOGTO_APP_SECRET=

# Propus Tours Portal
PROPUS_TOURS_PORTAL_LOGTO_APP_ID=
PROPUS_TOURS_PORTAL_LOGTO_APP_SECRET=

# Propus Management (M2M – Firmen/Logto Management API)
PROPUS_MANAGEMENT_LOGTO_APP_ID=
PROPUS_MANAGEMENT_LOGTO_APP_SECRET=

# Optionale Overrides für "Anmeldung & Konto" / Sign-in Experience
PROPUS_LOGTO_BRAND_PRIMARY=#B68E20
PROPUS_LOGTO_BRAND_DARK=#d4b860
PROPUS_LOGTO_BRAND_LOGO_URL=https://booking.propus.ch/assets/brand/logopropus.png
PROPUS_LOGTO_BRAND_FAVICON_URL=
PROPUS_LOGTO_BRAND_CSS_FILE=auth/logto-propus-branding.css
PROPUS_LOGTO_DISPLAY_NAME=
PROPUS_LOGTO_TERMS_URL=
PROPUS_LOGTO_PRIVACY_URL=
# z. B. EmailVerificationCode oder EmailVerificationCode,PhoneVerificationCode
PROPUS_LOGTO_FORGOT_PASSWORD_METHODS=
PROPUS_LOGTO_FALLBACK_LANGUAGE=
# true / false
PROPUS_LOGTO_LANGUAGE_AUTO_DETECT=
PROPUS_LOGTO_AGREE_TO_TERMS_POLICY=
PROPUS_LOGTO_HIDE_BRANDING=
