# Kopie nach /etc/propus/nas-upload-worker.env (oder EnvironmentFile in systemd).
# Auf dem NAS: gleiche Postgres-URL wie die Platform (ggf. über SSH-Tunnel erreichbar).

DATABASE_URL=postgresql://USER:PASS@HOST:5435/propus

# Lokale NAS-Pfade (entsprechen den VPS-Container-Pfaden /booking_upload_*)
NAS_BOOKING_UPLOAD_RAW_ROOT=/volume1/PROPUS DRIVE/Bilder zum Zusammenstellen
NAS_BOOKING_UPLOAD_CUSTOMER_ROOT=/volume1/PROPUS DRIVE/Immobilien Fotografie Propusimmo/Kunden

# VPS: rsync/ssh Pull-Quelle
NAS_VPS_SSH_HOST=root@87.106.24.107
NAS_VPS_STAGING_HOST_PATH=/opt/propus-upload-staging
BOOKING_UPLOAD_STAGING_ROOT=/upload_staging

# Optional
# NAS_UPLOAD_WORKER_POLL_MS=1000
# NAS_UPLOAD_WORKER_ID=nas-upload-worker-1
