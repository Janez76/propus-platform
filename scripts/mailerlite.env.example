# Kopieren nach scripts/mailerlite.env und ausfüllen (Datei ist gitignored).
# Für Produktion: dieselben Werte in /opt/propus-platform/.env.vps (MAILERLITE_*),
# danach: docker compose -p propus-platform -f docker-compose.vps.yml --env-file .env.vps up -d --force-recreate website

MAILERLITE_API_KEY=
# Mehrere Gruppen: kommagetrennte IDs (z. B. BKBN,Kunden,LinkedIn)
MAILERLITE_NEWSLETTER_GROUP_ID=
NEWSLETTER_VOUCHER_CODE=
