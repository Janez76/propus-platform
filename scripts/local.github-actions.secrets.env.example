# Kopiere diese Datei nach scripts/local.github-actions.secrets.env und fuelle die Werte.
# local.github-actions.secrets.env ist gitignored — niemals committen.
#
# Enthaelt u.a. Zugangsdaten fuer: SSH-Ziel (VPS_HOST), Cloudflare Cache-Purge nach Deploy,
# Playwright-Smoke. SSH-Key und .env.vps kommen separat per push-github-production-secrets.ps1.

# Workflow „Deploy to VPS“: Hostname oder IP fuer ssh / ssh-keyscan
VPS_HOST=

# Cloudflare API (gleiche Werte wie booking/.env: CF_ZONE, CF_EMAIL, CF_KEY — Zone-ID, nicht Domain)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_AUTH_EMAIL=
CLOUDFLARE_AUTH_KEY=

PLAYWRIGHT_BASE_URL=https://booking.propus.ch
PLAYWRIGHT_LIVE_BOOKING=1

PLAYWRIGHT_BOOKING_ADDRESS_QUERY=
PLAYWRIGHT_BOOKING_PACKAGE_KEY=
PLAYWRIGHT_BOOKING_DATE=
PLAYWRIGHT_BOOKING_SLOT=

PLAYWRIGHT_BOOKING_COMPANY=Propus Test AG
PLAYWRIGHT_BOOKING_NAME=Playwright CI
PLAYWRIGHT_BOOKING_EMAIL=
PLAYWRIGHT_BOOKING_PHONE=+41 79 000 00 00
PLAYWRIGHT_BOOKING_STREET=Musterstrasse 1
PLAYWRIGHT_BOOKING_ZIP=8001
PLAYWRIGHT_BOOKING_CITY=Zürich

PLAYWRIGHT_BOOKING_OBJECT_TYPE=apartment
PLAYWRIGHT_BOOKING_AREA=120
PLAYWRIGHT_BOOKING_ONSITE_NAME=Playwright Vor Ort
PLAYWRIGHT_BOOKING_ONSITE_PHONE=
