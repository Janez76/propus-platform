{
    "name":  "propus-assistant-mobile",
    "version":  "1.0.0",
    "main":  "expo-router/entry",
    "scripts":  {
                    "start":  "node ./node_modules/expo/bin/cli start",
                    "android":  "node ./node_modules/expo/bin/cli run:android",
                    "ios":  "node ./node_modules/expo/bin/cli run:ios",
                    "web":  "node ./node_modules/expo/bin/cli start --web",
                    "build:ios":  "eas build --platform ios",
                    "build:android":  "eas build --platform android",
                    "build:android:preview":  "eas build --platform android --profile preview",
                    "prebuild:android":  "node ./node_modules/expo/bin/cli prebuild --platform android",
                    "eas:android:preview":  "eas build --platform android --profile preview",
                    "eas:android:preview:env":  "dotenv-cli -e .env.expo.local -- eas build --platform android --profile preview",
                    "eas-build-pre-install":  "echo \u0027EAS PRE-INSTALL: node version:\u0027 && node --version && echo \u0027pwd:\u0027 && pwd && ls -la"
                },
    "dependencies":  {
                         "expo":  "~52.0.0",
                         "expo-asset":  "~11.0.5",
                         "expo-av":  "~15.0.0",
                         "expo-constants":  "~17.0.8",
                         "expo-haptics":  "~14.0.0",
                         "expo-linking":  "~7.0.5",
                         "expo-router":  "~4.0.0",
                         "expo-secure-store":  "~14.0.0",
                         "expo-speech":  "~13.0.0",
                         "expo-splash-screen":  "~0.29.0",
                         "expo-status-bar":  "~2.0.0",
                         "expo-system-ui":  "~4.0.9",
                         "react":  "18.3.1",
                         "react-native":  "0.76.9",
                         "react-native-safe-area-context":  "~4.12.0",
                         "react-native-screens":  "~4.4.0"
                     },
    "devDependencies":  {
                            "@types/react":  "~18.3.12",
                            "dotenv-cli":  "^8.0.0",
                            "typescript":  "~5.3.3"
                        },
    "private":  true
}