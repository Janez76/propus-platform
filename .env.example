# ─── PostgreSQL (gemeinsame DB für alle Module) ─────────────────────────────
POSTGRES_USER=propus
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=propus
# Host-Port für externe Verbindungen (z.B. TablePlus, DBeaver)
# 5435 = konfliktfrei auf VPS (15432 belegt) und lokal
PROPUS_PG_PORT=5435
LOGTO_PG_PORT=5436

# ─── Logto (Self-Hosted Auth) ────────────────────────────────────────────────
LOGTO_DB=logto
LOGTO_ENDPOINT=http://localhost:3301
LOGTO_ADMIN_ENDPOINT=http://localhost:3302

# ─── Zentrale Plattform (docker compose service: platform) ───────────────────
# Legacy-Kundenlogin (Passwort) im Booking-Backend: 1 = an, 0 = aus (nur Logto)
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=1

# ─── Booking-Modul ──────────────────────────────────────────────────────────
BOOKING_PORT=3100
BOOKING_SESSION_SECRET=booking-session-secret-change-me

# ─── Tours-Modul ─────────────────────────────────────────────────────────────
TOURS_PORT=3200
TOURS_SESSION_SECRET=tours-session-secret-change-me
ADMIN_EMAIL=admin@propus.ch
ADMIN_PASSWORD=admin

# ─── Exxas API ────────────────────────────────────────────────────────────────
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net

# ─── Matterport Model API (Spaces listen/verknüpfen) ─────────────────────────
# my.matterport.com → API-Token (Token-ID + Secret, Basic Auth). Kein SDK-Schlüssel.
MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=

# ─── E-Mail (SMTP via Nodemailer) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@propus.ch

# ─── Microsoft Graph (E-Mail-Sync Tours) ─────────────────────────────────────
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
