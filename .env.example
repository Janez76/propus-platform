# Propus Platform – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und fülle alle Felder aus.
# NIEMALS .env ins Git committen!

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=propus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=propus
PROPUS_PG_PORT=5435

# ─── Session Secrets (lange Zufallsstrings) ───────────────────────────────────
BOOKING_SESSION_SECRET=CHANGE_ME_RANDOM_64_CHARS
TOURS_SESSION_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ─── Admin-Zugangsdaten (Erstbetrieb, danach via Logto) ───────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Logto OIDC ───────────────────────────────────────────────────────────────
LOGTO_ENDPOINT=https://logto.example.com
LOGTO_INTERNAL_ENDPOINT=http://logto:3001
LOGTO_PORT=3301
LOGTO_ADMIN_PORT=3302
LOGTO_PG_PORT=5436

# Logto App-Credentials (aus Logto Admin Console)
PROPUS_BOOKING_LOGTO_APP_ID=
PROPUS_BOOKING_LOGTO_APP_SECRET=
PROPUS_TOURS_ADMIN_LOGTO_APP_ID=
PROPUS_TOURS_ADMIN_LOGTO_APP_SECRET=
PROPUS_TOURS_PORTAL_LOGTO_APP_ID=
PROPUS_TOURS_PORTAL_LOGTO_APP_SECRET=
PROPUS_MANAGEMENT_LOGTO_APP_ID=
PROPUS_MANAGEMENT_LOGTO_APP_SECRET=

# ─── Ports ────────────────────────────────────────────────────────────────────
BOOKING_PORT=3100
NEXTJS_PORT=3001
TOURS_PORT=3200

# ─── Externe Integrationen ────────────────────────────────────────────────────
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net

MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=

PAYREXX_INSTANCE=
PAYREXX_API_SECRET=

# Microsoft Graph (für E-Mail / OneDrive)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Google Maps (für Adress-Autocomplete)
GOOGLE_MAPS_API_KEY=

# ─── Next.js Public-Variablen (werden im Build eingebettet) ───────────────────
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_PUBLIC_BOOKING_HOSTNAME=booking.propus.ch
NEXT_PUBLIC_CUSTOMER_PORTAL_URL=https://tour.propus.ch
NEXT_PUBLIC_LOGTO_ADMIN_URL=https://logto.propus.ch
NEXT_PUBLIC_BASE_URL=/

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/app/logs
LOG_FILE_ENABLED=true
LOG_RETENTION_DAYS=30

# ─── Feature Flags ────────────────────────────────────────────────────────────
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=0
NODE_ENV=production
