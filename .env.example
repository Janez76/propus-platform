# Propus Platform – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und fülle alle Felder aus.
# NIEMALS .env ins Git committen!

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=propus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=propus
PROPUS_PG_PORT=5435

# ─── Session Secrets (lange Zufallsstrings) ───────────────────────────────────
BOOKING_SESSION_SECRET=CHANGE_ME_RANDOM_64_CHARS
TOURS_SESSION_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ─── Admin-Hauptbenutzer (Bootstrap beim Start) ───────────────────────────────
# Wird beim ersten Start angelegt. Bestehende admin_users-Eintraege erhalten nur
# Stammdaten-Updates; Passwortaenderungen bitte direkt in admin_users oder ueber
# das interne Admin-Tool.
ADMIN_USER=janez
ADMIN_PASS=CHANGE_ME_STRONG_PASSWORD
ADMIN_EMAIL=js@propus.ch
ADMIN_NAME=Janez
ADMIN_ROLE=super_admin

# ─── Ports ────────────────────────────────────────────────────────────────────
BOOKING_PORT=3100
NEXTJS_PORT=3001
TOURS_PORT=3200

# ─── Externe Integrationen ────────────────────────────────────────────────────
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net

MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=

PAYREXX_INSTANCE=
PAYREXX_API_SECRET=
# Webhook Signing-Key (im Payrexx-Dashboard unter Webhooks generiert — einmalig sichtbar!)
# Separater Key vom API-Secret. Falls leer: Fallback auf PAYREXX_API_SECRET.
PAYREXX_WEBHOOK_SECRET=
# Optional: curated (default) | all | visa,mastercard,twint,...
PAYREXX_PAYMENT_METHODS=curated

# Microsoft Graph (für E-Mail / OneDrive)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Google Maps (Autocomplete) — dient auch als technischer Fallback-Key für Places/Reviews
GOOGLE_MAPS_API_KEY=
# Reviews-Fallback (Places API): Place-ID + API-Key erforderlich.
# API-Key: bevorzugt GOOGLE_PLACES_API_KEY, sonst GOOGLE_MAPS_API_KEY als Fallback.
# In Google Cloud die "Places API (New)" aktivieren (inkl. Billing).
GOOGLE_PLACES_API_KEY=
# Öffentliche Place ID (Unternehmen)
GOOGLE_REVIEWS_PLACE_ID=ChIJCXJ70_ZCiisRJDlGdaYk66Y

# ─── Next.js Public-Variablen (werden im Build eingebettet) ───────────────────
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_PUBLIC_BOOKING_HOSTNAME=booking.propus.ch
NEXT_PUBLIC_CUSTOMER_PORTAL_URL=https://portal.propus.ch
NEXT_PUBLIC_BASE_URL=/

# Öffentliche Basis-URL für Kunden-Galerie-Links (nur Server, z. B. Order »Verknüpfungen«)
# Default in Code: https://fotos.propus.ch
GALLERY_BASE_URL=https://fotos.propus.ch

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/app/logs
LOG_FILE_ENABLED=true
LOG_RETENTION_DAYS=30

# ─── Nextcloud-Integration (für automatische Freigabelinks bei Kundenordnern) ─
# Nextcloud-Instanz URL (ohne abschließenden Slash)
NEXTCLOUD_URL=https://cloud.propus.ch
# Nextcloud-Benutzer mit Lesezugriff auf den Kunden-Share-Ordner
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
# Nextcloud-Pfad der dem BOOKING_UPLOAD_CUSTOMER_ROOT entspricht
# Beispiel: /Immobilien Fotografie Propusimmo/Kunden
NEXTCLOUD_CUSTOMER_FOLDER_PATH=

# ─── Feature Flags ────────────────────────────────────────────────────────────
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=0
NODE_ENV=production
