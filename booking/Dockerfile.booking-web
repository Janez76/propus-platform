# Statische Buchungsseite + Nginx (Proxy /api und /auth zum Backend-Container).
# Build-Kontext: Repo-Root (siehe docker-compose.desktop.yml).
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY docker-nginx-fallback-index.html /usr/share/nginx/html/index.html
COPY anleitung.html verify-email.html version.js photographers.config.js discount-codes.js /usr/share/nginx/html/
COPY assets /usr/share/nginx/html/assets
