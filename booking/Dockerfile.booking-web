# Statische Buchungsseite + Nginx (Proxy /api und /auth zum Backend-Container).
# Build-Kontext: Repo-Root (siehe docker-compose.desktop.yml).
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY index.html anleitung.html verify-email.html app.css script.js version.js photographers.config.js discount-codes.js /usr/share/nginx/html/
COPY assets /usr/share/nginx/html/assets
