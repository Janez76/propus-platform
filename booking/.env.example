# ─── Buchungstool: lokale Vorlage für Deploy & Geheimnisse ───────────────────
# Kopieren: cp .env.example .env  (Windows: copy .env.example .env)
# Niemals echte Secrets committen. .env ist in .gitignore.

# ─── Cloudflare (für scripts/deploy-prod.ps1: Cache-Purge) ───────────────────
# Pflicht für Deploy; Zone-ID und E-Mail ggf. aus dem Cloudflare-Dashboard.
CF_KEY=
CF_ZONE=
CF_EMAIL=

# ─── VPS / SSH (deploy-prod.ps1) ─────────────────────────────────────────────
# VPS_IP=87.106.24.107
# VPS_USER=root
# Erwarteter Host-Key (ssh-keyscan liefert z. B. SHA256:...):
# VPS_HOST_KEY=

# Passwort-Login: PuTTY (plink.exe / pscp.exe) muss installiert sein.
# Wenn VPS_USE_OPENSSH=true gesetzt ist, wird VPS_SSH_PW ignoriert (nur SSH-Key).
VPS_SSH_PW=
# VPS_USE_OPENSSH=true

# Optional: explizite Pfade zu PuTTY
# VPS_PLINK_EXE=C:\Program Files\PuTTY\plink.exe
# VPS_PSCP_EXE=C:\Program Files\PuTTY\pscp.exe

# Ziel auf dem Server
# VPS_PROJECT_ROOT=/opt/buchungstool
# VPS_COMPOSE_FILE=/opt/buchungstool/docker-compose.prod.yml
# VPS_COMPOSE_PROJECT=buchungstool_prod
# VPS_ENV_FILE=/opt/buchungstool/.env.prod

# ─── Google Reviews (Places API) ─────────────────────────────────────────────
# Admin-Panel (Reviews) und Website: booking/server + Astro. Cloud: „Places API (New)“ ggf. aktivieren.
# Wenn GOOGLE_PLACES_API_KEY leer ist, nutzt der Code GOOGLE_MAPS_API_KEY (oft derselbe String).
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
# Google Place ID des Unternehmens (für max. 5 öffentliche Reviews)
# https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_REVIEWS_PLACE_ID=ChIJCXJ70_ZCiisRJDlGdaYk66Y

# ─── Google Business Profile API – OAuth 2.0 (Admin Review-Panel) ────────────
# Erlaubt: alle Reviews laden (nicht nur 5), direkt aus dem Admin-Panel antworten.
#
# Setup-Anleitung: booking/docs/GBP_OAUTH_SETUP.md
#
# 1. Google Cloud Console → Projekt → APIs aktivieren:
#    - Google Business Profile API
#    - Google My Business Account Management API
# 2. Credentials → OAuth 2.0 Client ID (Typ: Webanwendung) erstellen
#    Redirect URI: https://admin-booking.propus.ch/api/admin/gbp/callback
# 3. Werte hier eintragen:
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REDIRECT_URI=https://admin-booking.propus.ch/api/admin/gbp/callback
# GBP_ACCOUNT_ID und GBP_LOCATION_ID werden nach dem ersten Login automatisch in der DB gespeichert.

# ─── Rate-Limits (booking/rate-limiters.js) ─────────────────────────────────
# Defaults sind konservativ und für Produktion ausreichend; nur überschreiben,
# wenn legitime Clients geblockt werden.
# RATE_LIMIT_AUTH_MAX=5                 # Versuche pro Fenster für /auth/login + /api/admin/login
# RATE_LIMIT_AUTH_WINDOW_MS=900000      # 15 min
# RATE_LIMIT_CONFIRM_MAX=10             # Token-Versuche pro Fenster für /api/booking/confirm/:token
# RATE_LIMIT_CONFIRM_WINDOW_MS=900000   # 15 min
# RATE_LIMIT_BOOKING_MAX=10             # Submits pro Fenster für /api/booking
# RATE_LIMIT_BOOKING_WINDOW_MS=3600000  # 60 min

# ─── Admin-Panel (Vite) – nur nötig, wenn du .env für den Build nutzt ───────
# VITE_API_BASE=https://api.example.com
