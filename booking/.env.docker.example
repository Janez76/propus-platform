# Optional: als Umgebungsdatei fuer docker compose nutzen, z. B.:
#   docker compose --env-file .env.docker -f docker-compose.desktop.yml up --build
#
# Nur setzen, was von den Defaults abweichen soll:

# SESSION_SECRET=starker-zufaelliger-string
# BUCHUNGSTOOL_DESKTOP_ADMIN_USER=admin
# BUCHUNGSTOOL_DESKTOP_ADMIN_PASS=mindestens8zeichen

# Echte Microsoft-Graph-App (Kalender/E-Mail via Graph); sonst nutzt compose Platzhalter — Server startet, Graph schlaegt zur Laufzeit fehl
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
