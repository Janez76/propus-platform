# ---------------------------------------------------------------------------
# Propus Platform — LAN-Staging auf UGREEN NAS (Debian 12, 192.168.1.5)
#
# Verwendung:
#   1) Kopiere diese Datei zu ".env.staging" auf dem NAS (nicht ins Git!)
#   2) Ergänze die leeren Felder mit Staging-Werten (Test-DB, Mailtrap,
#      Payrexx-Sandbox, eigene Admin-Credentials).
#   3) Starte mit:
#        docker compose -p propus-staging \
#          -f docker-compose.vps.yml \
#          -f docker-compose.staging.nas.yml \
#          --env-file .env.staging up -d --build
#
# WICHTIG: niemals Werte aus .env.vps (Prod) hier einsetzen. Staging soll
# keine echten Mails / Zahlungen / Kundendaten berühren.
# ---------------------------------------------------------------------------

# --- Staging-Metadaten ------------------------------------------------------
VPS_COMPOSE_PROJECT=propus-staging

# --- Host-Ports auf dem NAS (müssen lokal frei sein!) -----------------------
# Bind-Adresse: 0.0.0.0 = erreichbar aus dem ganzen LAN.
#              127.0.0.1 = nur auf dem NAS selbst (dann via SSH-Tunnel).
STAGING_PLATFORM_BIND=0.0.0.0
STAGING_PLATFORM_PORT=13100
STAGING_WEBSITE_BIND=0.0.0.0
STAGING_WEBSITE_PORT=14343

# Postgres ist im Override NICHT ans Host-Netzwerk gebunden (nur Docker-intern
# erreichbar). Falls du DB-Zugriff vom LAN willst, setze im Override file:
#   postgres:
#     ports: !override
#       - "0.0.0.0:${PROPUS_PG_PORT:-55435}:5432"
PROPUS_PG_PORT=55435

# --- URLs im LAN (HTTP, keine Cloudflare-Domain für Staging) ----------------
# Müssen zu STAGING_PLATFORM_PORT / STAGING_WEBSITE_PORT passen.
FRONTEND_URL=http://192.168.1.5:13100
ADMIN_PANEL_URL=http://192.168.1.5:13100

# --- Session-Cookies über HTTP im LAN ---------------------------------------
# Prod setzt SESSION_COOKIE_SECURE=true hart; der Override erlaubt "false",
# damit der Browser das Cookie überhaupt annimmt, wenn kein HTTPS davor steht.
# Bei späterem Cloudflare-Tunnel (z. B. staging.propus.ch) wieder auf "true".
STAGING_SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# --- Staging-Postgres -------------------------------------------------------
# Eigene DB, eigenes Passwort. KEINE Prod-Credentials.
POSTGRES_USER=propus_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=propus_staging

# --- Session-Secrets (Staging-eigene, zufällige Werte) ----------------------
BOOKING_SESSION_SECRET=CHANGE_ME_STAGING_BOOKING_SESSION_SECRET
TOURS_SESSION_SECRET=CHANGE_ME_STAGING_TOURS_SESSION_SECRET
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=0

# --- Staging-Admin (Bootstrap beim ersten Start) ---------------------------
ADMIN_USER=staging
ADMIN_PASS=CHANGE_ME_STAGING_ADMIN_PASSWORD
ADMIN_EMAIL=staging@example.invalid
ADMIN_NAME=Staging-Admin
ADMIN_ROLE=super_admin
ADMIN_SETUP_TOKEN=

# --- Mail: Mailtrap oder ähnliche Test-Inbox --------------------------------
# Niemals echte SMTP-Zugänge. Mailtrap.io, MailHog, o. ä. für Staging.
MAIL_FROM=staging@example.invalid
OFFICE_EMAIL=staging@example.invalid
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Microsoft Graph (falls getestet): separate Test-App-Registrierung verwenden
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# --- Exxas / Payrexx Sandboxes ---------------------------------------------
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net
# Payrexx-Sandbox / deaktivierte Webhooks im Staging verwenden
PAYREXX_INSTANCE=
PAYREXX_API_SECRET=
PAYREXX_WEBHOOK_SECRET=

# --- Matterport / Google (Test-Keys oder leer lassen) ----------------------
MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=
GOOGLE_PLACES_API_KEY=
GOOGLE_REVIEWS_PLACE_ID=

# --- Website (Astro) — eigene Supabase-Test-Instanz ------------------------
WEBSITE_SUPABASE_URL=
WEBSITE_SUPABASE_SERVICE_ROLE_KEY=
WEBSITE_ADMIN_USER=staging
WEBSITE_ADMIN_PASSWORD=CHANGE_ME_STAGING_WEBSITE_ADMIN_PASSWORD
WEBSITE_ADMIN_SECRET=CHANGE_ME_STAGING_WEBSITE_ADMIN_SECRET
PUBLIC_SITE_LOGO_URL=
PUBLIC_SITE_FAVICON_URL=
PUBLIC_BOOKING_CATALOG_URL=
PUBLIC_SUPABASE_IMG_TRANSFORM=

# --- Upload-Pfade auf dem NAS (müssen als Verzeichnis existieren!) ---------
# Anlegen vor erstem Start:
#   sudo install -d -o 1000 -g 1000 \
#     /volume1/docker/propus-staging/uploads/staging \
#     /volume1/docker/propus-staging/uploads/customer \
#     /volume1/docker/propus-staging/uploads/raw
BOOKING_UPLOAD_REQUIRE_MOUNT=true
BOOKING_UPLOAD_STAGING_HOST_PATH=/volume1/docker/propus-staging/uploads/staging
BOOKING_UPLOAD_CUSTOMER_HOST_PATH=/volume1/docker/propus-staging/uploads/customer
BOOKING_UPLOAD_RAW_HOST_PATH=/volume1/docker/propus-staging/uploads/raw

# --- Nextcloud: im Staging nicht benötigt (leer lassen = Feature aus) ------
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
NEXTCLOUD_CUSTOMER_FOLDER_PATH=

# --- Backup (im Staging normalerweise aus) ---------------------------------
BACKUP_RESTORE_TARGET=/volume1/docker/propus-staging
BACKUP_RETENTION_DAYS=7
BACKUP_INCLUDE_VOLUMES=0
BACKUP_VOLUME_PATHS=/data/state:/app/logs:/upload_staging
BACKUP_NAS_TARGET=
BACKUP_NAS_LOG_PATH=/data/backups/.nas-sync.log
BACKUP_NAS_SCHEDULE=

# --- Laufzeit / Logs (Staging-Defaults) ------------------------------------
TIMEZONE=Europe/Zurich
WORK_START=08:00
WORK_END=18:00
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_REDACT=true
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs/platform.log
LOG_RETENTION_DAYS=7
FRONTEND_LOG_RATE_LIMIT_PER_MIN=120

NEXT_PUBLIC_PICDROP_NOTIFY_EMAIL=staging@example.invalid
