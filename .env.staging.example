# ---------------------------------------------------------------------------
# Propus Platform — LAN-Staging auf UGREEN NAS (192.168.1.5)
#
#   cp .env.staging.example .env.staging && chmod 600 .env.staging
#
# Niemals committen. Optional: .env.staging.secrets für lokale Zusatz-Secrets.
# Keine Prod-Werte aus .env.vps übernehmen (Mail, Payrexx, echte Secrets).
#
# Admin-Login vs. ADMIN_PASS: Siehe docs/STAGING-UGREEN.md →
# „Separates Staging-Admin-Passwort“. Nach DB-Restore aus Prod-VPS-Backup
# gelten die Passwort-Hashes aus dem Dump; ADMIN_PASS überschreibt bestehende
# Konten nicht. Passwort gezielt setzen: scripts/set-core-admin-password.js
# ---------------------------------------------------------------------------

# --- Staging-Metadaten ------------------------------------------------------
STAGING_HOST_IP=192.168.1.5
VPS_COMPOSE_PROJECT=propus-staging

# --- Host-Ports (müssen lokal frei sein) ------------------------------------
# Bind: 0.0.0.0 = LAN; 127.0.0.1 = nur NAS (dann SSH-Tunnel).
STAGING_PLATFORM_BIND=0.0.0.0
STAGING_PLATFORM_PORT=13100
STAGING_WEBSITE_BIND=0.0.0.0
STAGING_WEBSITE_PORT=14343
# Postgres-Host-Port (127.0.0.1 in docker-compose.vps.yml — nur auf dem NAS)
PROPUS_PG_PORT=55435

# --- Interne URLs (Build/SSR, Browser im LAN) --------------------------------
PLATFORM_INTERNAL_URL=http://192.168.1.5:13100

# --- PostgreSQL (eigene Staging-DB) ------------------------------------------
POSTGRES_USER=propus_staging
POSTGRES_PASSWORD=CHANGE_ME_STRONG_STAGING_DB_PASSWORD
POSTGRES_DB=propus_staging

# --- Platform-Ports (Substitution in docker-compose.vps.yml) ----------------
# PLATFORM_PORT / STAGING_PLATFORM_PORT = Host-Port → Container 3001 (Next). NICHT mit Express-PORT verwechseln.
# Express im Container lauscht immer auf 3100 (docker-compose.staging.nas.yml setzt PORT/NEXTJS_PORT fest).
# Kein PORT= oder NEXTJS_PORT= in .env.staging setzen — sonst bricht start.sh.
PLATFORM_PORT=13100
WEBSITE_PORT=14343

# --- Booking / tours sessions ------------------------------------------------
BOOKING_SESSION_SECRET=CHANGE_ME_STRONG_STAGING_BOOKING_SESSION
TOURS_SESSION_SECRET=CHANGE_ME_STRONG_STAGING_TOURS_SESSION
SESSION_COOKIE_DOMAIN=
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=1

# --- Session-Cookies über HTTP im LAN ----------------------------------------
STAGING_SESSION_COOKIE_SECURE=false

# --- Admin (nur Bootstrap, wenn DB noch leer — siehe Kopfkommentar) ----------
ADMIN_USER=janez
ADMIN_PASS=CHANGE_ME_STAGING_ADMIN_PASSWORD
ADMIN_EMAIL=js@propus.ch
ADMIN_NAME=Janez
ADMIN_ROLE=super_admin
ADMIN_SETUP_TOKEN=

# --- Öffentliche URLs (HTTP im LAN) ------------------------------------------
FRONTEND_URL=http://192.168.1.5:13100
ADMIN_PANEL_URL=http://192.168.1.5:13100

# --- Mail (z. B. Mailtrap / Sandbox — niemals Prod-SMTP) ---------------------
MAIL_FROM=
OFFICE_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Microsoft Graph (falls getestet): separate Test-App-Registrierung
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# --- Business integrations (Staging / leer) ----------------------------------
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net
PAYREXX_INSTANCE=
PAYREXX_API_SECRET=
PAYREXX_WEBHOOK_SECRET=

# --- Matterport / Google ------------------------------------------------------
MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=
GOOGLE_PLACES_API_KEY=
GOOGLE_REVIEWS_PLACE_ID=

# --- Propus Website (Astro) ---------------------------------------------------
WEBSITE_SUPABASE_URL=
WEBSITE_SUPABASE_SERVICE_ROLE_KEY=
WEBSITE_ADMIN_USER=admin
WEBSITE_ADMIN_PASSWORD=
WEBSITE_ADMIN_SECRET=
PUBLIC_SITE_LOGO_URL=
PUBLIC_SITE_FAVICON_URL=
PUBLIC_BOOKING_CATALOG_URL=
PUBLIC_SUPABASE_IMG_TRANSFORM=

# --- Upload-Pfade auf dem NAS (Host) -----------------------------------------
BOOKING_UPLOAD_REQUIRE_MOUNT=true
BOOKING_UPLOAD_STAGING_HOST_PATH=/volume1/docker/propus-staging/uploads/staging
BOOKING_UPLOAD_CUSTOMER_HOST_PATH=/volume1/docker/propus-staging/uploads/customer
BOOKING_UPLOAD_RAW_HOST_PATH=/volume1/docker/propus-staging/uploads/raw

# --- Nextcloud: für LAN-Staging leer lassen ----------------------------------
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
NEXTCLOUD_CUSTOMER_FOLDER_PATH=

# --- Backup-Pfade ------------------------------------------------------------
BACKUP_RESTORE_TARGET=/volume1/docker/propus-staging/repo
BACKUP_RETENTION_DAYS=7
BACKUP_INCLUDE_VOLUMES=0
BACKUP_VOLUME_PATHS=/data/state:/app/logs:/upload_staging
BACKUP_NAS_TARGET=
BACKUP_NAS_LOG_PATH=
BACKUP_NAS_SCHEDULE=

# --- Runtime / logging -------------------------------------------------------
TIMEZONE=Europe/Zurich
WORK_START=08:00
WORK_END=18:00
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_REDACT=true
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs/platform.log
LOG_RETENTION_DAYS=14
FRONTEND_LOG_RATE_LIMIT_PER_MIN=120
NEXT_PUBLIC_PICDROP_NOTIFY_EMAIL=
