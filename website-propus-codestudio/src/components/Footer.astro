---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__stack">
      <p class="site-footer__name">Propus GmbH</p>
      <address class="site-footer__address">Untere Roostmatt 8, 6300 Zug, Schweiz</address>

      <div class="site-footer__hours-wrap">
        <p class="site-footer__hours-eyebrow">Öffnungszeiten</p>
        <p class="site-footer__hours" aria-label="Öffnungszeiten Mo–Sa, 08.00 – 17.00 Uhr">
          <span class="site-footer__hours-days">Mo–Sa</span>
          <span class="site-footer__hours-pipe" aria-hidden="true">|</span>
          <span class="site-footer__hours-time">08.00 – 17.00 Uhr</span>
        </p>
      </div>

      <p class="site-footer__contact">
        <a
          class="site-footer__contact-link"
          href="mailto:office@propus.ch"
          aria-label="E-Mail an office@propus.ch"
        >
          <svg
            class="site-footer__contact-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.65"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2.5" y="5" width="19" height="14" rx="2"></rect>
            <path d="M3 7l8.2 5.5a2 2 0 0 0 2.2 0L21 7"></path>
          </svg>
          <span class="site-footer__contact-text">E-Mail</span>
        </a>
        <span class="site-footer__dot" aria-hidden="true">·</span>
        <a
          class="site-footer__contact-link"
          href="tel:+41445896363"
          aria-label="Anrufen: +41 44 589 63 63"
        >
          <svg
            class="site-footer__contact-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.65"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <span class="site-footer__contact-text">Telefon</span>
        </a>
      </p>

      <div class="site-footer__social" role="list" aria-label="Social Media">
        <span role="listitem">
          <a
            href="https://www.instagram.com/propus.ch/"
            class="site-footer__icon-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
          >
            <svg
              class="site-footer__social-svg"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.65"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        </span>
        <span role="listitem">
          <a
            href="https://ch.linkedin.com/company/propusgmbh"
            class="site-footer__icon-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg
              class="site-footer__social-svg"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.65"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        </span>
      </div>

      <nav class="site-footer__legal" aria-label="Rechtliche Hinweise">
        <ul class="site-footer__legal-list">
          <li class="site-footer__legal-item">
            <a href="/impressum">Impressum</a>
          </li>
          <li class="site-footer__legal-sep" role="presentation" aria-hidden="true">
            <span class="site-footer__legal-pipe">|</span>
          </li>
          <li class="site-footer__legal-item">
            <a href="/datenschutz">Datenschutz</a>
          </li>
          <li class="site-footer__legal-sep" role="presentation" aria-hidden="true">
            <span class="site-footer__legal-pipe">|</span>
          </li>
          <li class="site-footer__legal-item">
            <a href="https://www.propus.ch/agb/">AGB</a>
          </li>
        </ul>
      </nav>

      <p class="site-footer__copy">
        © {year} Propus GmbH
        <span class="site-footer__copy-sep" aria-hidden="true">|</span>
        <span class="site-footer__credit-note">Designed by Propus Codestudio</span>
      </p>
    </div>
  </div>
</footer>
