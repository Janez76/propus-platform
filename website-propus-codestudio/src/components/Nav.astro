---
const links = [
  { href: "#leistungen", label: "Leistungen" },
  { href: "#referenzen", label: "Referenzen" },
  { href: "#prozess", label: "Prozess" },
  { href: "#preise", label: "Preise" },
  { href: "#faq", label: "FAQ" },
];
---

<header class="site-header" data-scrolled="false">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label="Zur Startseite Propus Codestudio">
      <img
        class="site-header__logo"
        src="/logo-header.png"
        alt="Propus Codestudio"
        width="1836"
        height="240"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <nav class="site-header__nav" id="site-nav" aria-label="Hauptnavigation" data-nav>
      <div class="site-header__nav-sheet">
        <div class="site-header__nav-cluster">
          <ul class="site-header__list">
            {
              links.map((link) => (
                <li>
                  <a href={link.href} class="site-header__link" data-nav-link>
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <a href="#kontakt" class="site-header__cta site-header__cta--drawer" data-nav-link>
            <span>Kontakt</span>
          </a>
        </div>
      </div>
    </nav>

    <div class="site-header__actions">
      <a href="#kontakt" class="site-header__cta site-header__cta--bar">
        <span>Kontakt</span>
        <span class="site-header__cta-arrow" aria-hidden="true">→</span>
      </a>
      <button
        type="button"
        class="site-header__toggle"
        aria-expanded="false"
        aria-controls="site-nav"
        data-nav-toggle
        aria-label="Menü"
      >
        <span class="visually-hidden">Menü</span>
        <span class="site-header__burger" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div class="site-header__rule" aria-hidden="true"></div>
</header>

<div aria-hidden="true" class="site-header__spacer"></div>

<style>
  .site-header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg), transparent 14%);
    backdrop-filter: saturate(1.15) blur(18px);
    -webkit-backdrop-filter: saturate(1.15) blur(18px);
    transition:
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  .site-header[data-scrolled="true"] {
    background: color-mix(in oklab, var(--color-bg), transparent 4%);
    box-shadow: 0 1px 0 color-mix(in oklab, var(--color-text), transparent 92%);
  }

  .site-header__rule {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in oklab, var(--color-text), transparent 92%) 20%,
      color-mix(in oklab, var(--color-text), transparent 88%) 50%,
      color-mix(in oklab, var(--color-text), transparent 92%) 80%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .site-header[data-scrolled="true"] .site-header__rule {
    opacity: 1;
  }

  .site-header__inner {
    --rail-max: var(--content-max);
    --rail-gutter: clamp(1.25rem, 4vw, 2rem);
    width: min(100% - 2 * var(--rail-gutter), var(--rail-max));
    max-width: var(--rail-max);
    margin-inline: auto;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  /* ---------- Brand ---------- */
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-text);
    text-decoration: none;
    flex-shrink: 0;
    line-height: 0;
    transition: opacity var(--transition-fast);
  }

  .site-header__brand:hover {
    opacity: 0.85;
  }

  .site-header__logo {
    display: block;
    height: clamp(1.875rem, 4.5vw, 2.75rem);
    width: auto;
    max-width: min(100%, 14rem);
    object-fit: contain;
  }

  /* ---------- Nav (Desktop baseline) ---------- */
  .site-header__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 2vw, 2.25rem);
    margin: 0;
    padding: 0;
  }

  .site-header__link {
    position: relative;
    display: inline-block;
    padding: 0.35rem 0;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color var(--transition-fast);
  }

  .site-header__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -2px;
    height: 1px;
    background: var(--color-gold);
    transition: right 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-header__link:hover {
    color: var(--color-text);
  }

  .site-header__link:hover::after {
    right: 0;
  }

  /* ---------- Actions ---------- */
  .site-header__actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.15rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border: 0;
    background: transparent;
    transition: color var(--transition-fast);
  }

  .site-header__cta--bar {
    display: none;
  }

  .site-header__cta--drawer {
    display: none;
  }

  .site-header__cta-arrow {
    display: inline-block;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    color: var(--color-gold);
  }

  .site-header__cta:hover {
    color: var(--color-gold);
  }

  .site-header__cta:hover .site-header__cta-arrow {
    transform: translateX(3px);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- Mobile toggle ---------- */
  .site-header__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .site-header__toggle:hover {
    border-color: color-mix(in oklab, var(--color-text), transparent 82%);
  }

  .site-header__toggle:active {
    opacity: 0.88;
  }

  .site-header__burger {
    position: relative;
    display: block;
    width: 1.25rem;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: background 0.2s ease;
  }

  .site-header__burger::before,
  .site-header__burger::after {
    content: "";
    position: absolute;
    left: 0;
    display: block;
    width: 100%;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition:
      top 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-header__burger::before {
    top: -6px;
  }

  .site-header__burger::after {
    top: 6px;
  }

  /* Burger → X (1:1 wie propus.ch – rotation in place) */
  .site-header__toggle[aria-expanded="true"] .site-header__burger {
    background: transparent;
  }

  .site-header__toggle[aria-expanded="true"] .site-header__burger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .site-header__toggle[aria-expanded="true"] .site-header__burger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  .site-header__spacer {
    height: var(--header-h);
  }

  /* ---------- Mobile drawer (propus.ch-Stil) ---------- */
  @media (max-width: 899px) {
    .site-header__nav {
      --drawer-ease: cubic-bezier(0.22, 1, 0.36, 1);
      --drawer-dur: 0.38s;
      position: fixed;
      inset: 0;
      z-index: 45;
      background: var(--color-bg);
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
      transition:
        opacity var(--drawer-dur) var(--drawer-ease),
        visibility 0s linear var(--drawer-dur);
      display: flex;
      flex-direction: column;
    }

    .site-header__nav.is-open {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
      transition:
        opacity var(--drawer-dur) var(--drawer-ease),
        visibility 0s linear 0s;
    }

    .site-header__brand,
    .site-header__actions {
      position: relative;
      z-index: 70;
    }

    .site-header[data-nav-open="true"] {
      background: var(--color-bg);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .site-header__nav-sheet {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 100dvh;
      padding-inline: clamp(1.25rem, 5vw, 2rem);
      padding-top: calc(var(--header-h) + env(safe-area-inset-top, 0px) + 1rem);
      padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom, 0px));
      overflow-x: hidden;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .site-header__nav-cluster {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1 1 auto;
      width: 100%;
      max-width: 22rem;
      margin-inline: auto;
      text-align: center;
      transform: translateY(0.85rem);
      opacity: 0;
      transition:
        opacity var(--drawer-dur) var(--drawer-ease),
        transform var(--drawer-dur) var(--drawer-ease);
    }

    .site-header__nav.is-open .site-header__nav-cluster {
      transform: translateY(-3vh);
      opacity: 1;
    }

    .site-header__nav .site-header__list {
      flex-direction: column;
      align-items: center;
      flex-wrap: nowrap;
      gap: clamp(1.35rem, 4.5vw, 2.35rem);
      width: 100%;
    }

    .site-header__nav .site-header__link {
      display: inline-block;
      padding: 0.65rem 0.5rem;
      min-height: 2.75rem;
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-text);
      line-height: 1.35;
      border-bottom: 1px solid transparent;
      -webkit-tap-highlight-color: transparent;
      transition:
        color var(--transition-fast),
        border-color var(--transition-fast),
        opacity var(--transition-fast);
    }

    .site-header__nav .site-header__link::after {
      display: none;
    }

    .site-header__nav .site-header__link:hover,
    .site-header__nav .site-header__link:focus-visible {
      color: var(--color-text);
      border-bottom-color: var(--color-text);
    }

    .site-header__nav .site-header__link:active {
      opacity: 0.55;
    }

    .site-header__cta--drawer {
      display: inline-flex;
      margin-top: clamp(2rem, 7vw, 3.25rem);
      flex-shrink: 0;
      width: 100%;
      max-width: 17.5rem;
      justify-content: center;
      padding: 0.95rem 1.5rem;
      border-radius: var(--radius-btn);
      background: var(--color-text);
      color: var(--color-bg);
      font-size: 0.8125rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-decoration: none;
      transition:
        background 0.2s ease,
        opacity 0.2s ease;
    }

    .site-header__cta--drawer:hover {
      background: #1f1f1f;
      color: var(--color-bg);
    }

    .site-header__cta--drawer:hover .site-header__cta-arrow {
      color: var(--color-gold);
    }

    @media (prefers-reduced-motion: reduce) {
      .site-header__nav {
        --drawer-dur: 1ms;
      }
      .site-header__nav-cluster,
      .site-header__nav.is-open .site-header__nav-cluster {
        transform: none;
      }
    }
  }

  @media (min-width: 900px) {
    .site-header__inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      align-items: center;
      column-gap: clamp(1.5rem, 4vw, 3rem);
    }

    .site-header__brand {
      grid-column: 1;
      justify-self: start;
    }

    .site-header__nav {
      grid-column: 2;
      justify-self: center;
    }

    .site-header__actions {
      grid-column: 3;
      justify-self: end;
      margin-left: 0;
    }

    .site-header__nav-sheet,
    .site-header__nav-cluster {
      display: contents;
    }

    .site-header__cta--bar {
      display: inline-flex;
    }

    .site-header__toggle {
      display: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const header = document.querySelector(".site-header");
    const toggle = document.querySelector("[data-nav-toggle]");
    const nav = document.querySelector("[data-nav]");

    const onScroll = () => {
      if (!header) return;
      header.dataset.scrolled = window.scrollY > 8 ? "true" : "false";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    if (!toggle || !nav) return;

    const setOpen = (open) => {
      toggle.setAttribute("aria-expanded", String(open));
      nav.classList.toggle("is-open", open);
      document.body.classList.toggle("is-locked", open);
      if (header) header.dataset.navOpen = open ? "true" : "false";
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!expanded);
    });

    nav.querySelectorAll("[data-nav-link]").forEach((el) => {
      el.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        toggle.focus();
      }
    });

    const mq = window.matchMedia("(min-width: 900px)");
    const syncOnBreak = () => {
      if (mq.matches && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
      }
    };
    mq.addEventListener("change", syncOnBreak);
  })();
</script>
