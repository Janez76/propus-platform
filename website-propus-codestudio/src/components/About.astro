---
import { X } from "@lucide/astro";
import { media } from "../data/media";
---

<section id="ueber-uns" class="u-section about">
  <div class="u-container about__grid">

    <div class="about__text u-animate" style="--delay: 0ms">
      <p class="u-eyebrow">Über uns</p>
      <h2 class="about__title">Webentwicklung aus <em>einer Hand</em>.</h2>
      <div class="divider-gold" aria-hidden="true"></div>

      <p class="about__lead">
        <strong>Propus Codestudio</strong> ist die Software‑Sparte der Propus GmbH. Wir begleiten
        KMU und Organisationen – von klassischen Websites bis zu internen Werkzeugen, die echten
        Alltag vereinfachen.
      </p>

      <blockquote class="about__quote">
        <span class="about__quote-mark" aria-hidden="true">&ldquo;</span>
        Klarer Scope, saubere Architektur, Partnerschaft auf Augenhöhe. Weniger Show – mehr Substanz.
      </blockquote>

      <p class="about__sign">— Ivan, Lead Developer</p>
    </div>

    <aside class="about__aside u-animate" style="--delay: 120ms">
      <article class="profile">
        <div class="profile__media">
          <img
            src={media.about}
            alt="Ivan Mijajlovic – Lead Developer, Propus Codestudio"
            width={1199}
            height={1312}
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="profile__body">
          <h3 class="profile__name">Ivan Mijajlovic</h3>
          <p class="profile__role">
            <span>Lead Developer</span>
          </p>
        </div>
      </article>

      <button
        type="button"
        class="profile__toggle"
        aria-haspopup="dialog"
        aria-controls="about-bio-modal"
        data-profile-open
      >
        <span>Mehr über mich</span>
        <span class="profile__toggle-arrow" aria-hidden="true">→</span>
      </button>
    </aside>
  </div>
</section>

<div
  class="bio-modal"
  id="about-bio-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="about-bio-title"
  aria-hidden="true"
  hidden
  data-profile-modal
>
  <div class="bio-modal__backdrop" data-profile-close></div>

  <div class="bio-modal__dialog" role="document">
    <button
      type="button"
      class="bio-modal__close"
      aria-label="Schließen"
      data-profile-close
    >
      <X size={18} stroke-width={1.8} />
    </button>

    <div class="bio-modal__content">
      <p class="bio-modal__eyebrow">Propus Codestudio</p>
      <h3 class="bio-modal__title" id="about-bio-title">Ivan Mijajlovic</h3>
      <p class="bio-modal__role">Lead Developer</p>
      <div class="bio-modal__divider" aria-hidden="true"></div>

      <div class="bio-modal__text">
        <p>
          Ich bin Ivan – Entwickler mit einem Faible für Produkte, die im Alltag einfach funktionieren.
          Websites, Landingpages und interne Tools – mein Anspruch ist dieselbe Sorgfalt, die auch offline
          zum Propus-Namen gehört.
        </p>
        <p>
          Lieber weniger, dafür richtig: klarer Scope, ehrliche Kommunikation, saubere Umsetzung. Ich arbeite
          nahe am Team, erkläre technische Entscheidungen verständlich und baue Lösungen, die auch nach dem
          Launch wartbar bleiben.
        </p>
        <p>
          Was mich antreibt, ist der Moment, in dem ein Projekt live geht und im Tagesgeschäft einfach
          funktioniert – ohne Umwege, ohne Reibung, ohne technische Überraschungen.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  const openers = document.querySelectorAll<HTMLButtonElement>("[data-profile-open]");
  const modal = document.querySelector<HTMLElement>("[data-profile-modal]");

  if (modal && openers.length > 0) {
    const closers = modal.querySelectorAll<HTMLElement>("[data-profile-close]");
    let lastFocus: HTMLElement | null = null;

    const focusables = () =>
      Array.from(
        modal.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute("hidden"));

    const open = (trigger: HTMLElement) => {
      lastFocus = trigger;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("is-locked");

      requestAnimationFrame(() => {
        modal.classList.add("is-open");
        const [first] = focusables();
        first?.focus();
      });
    };

    const close = () => {
      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("is-locked");
      const finish = () => {
        modal.hidden = true;
        lastFocus?.focus();
      };
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) {
        finish();
      } else {
        window.setTimeout(finish, 220);
      }
    };

    openers.forEach((btn) => {
      btn.addEventListener("click", () => open(btn));
    });

    closers.forEach((el) => {
      el.addEventListener("click", close);
    });

    document.addEventListener("keydown", (e) => {
      if (modal.hidden) return;
      if (e.key === "Escape") {
        e.preventDefault();
        close();
      }
      if (e.key === "Tab") {
        const items = focusables();
        if (items.length === 0) return;
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>

<style>
  .about {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .about__grid {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }

  @media (min-width: 980px) {
    .about__grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .about__text {
    display: flex;
    flex-direction: column;
    gap: clamp(1.15rem, 2.5vw, 1.5rem);
    max-width: 34rem;
  }

  .about__title {
    font-size: clamp(1.75rem, 2.5vw + 1rem, 3rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .about__lead {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.7;
  }

  .about__quote {
    position: relative;
    margin: 0.25rem 0;
    padding: 0 0 0 1.25rem;
    border-left: 2px solid var(--color-gold);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text);
    font-style: italic;
    letter-spacing: -0.005em;
  }

  .about__quote-mark {
    display: none;
  }

  .about__sign {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .about__aside {
    position: relative;
    width: 100%;
    max-width: 24rem;
    justify-self: center;
  }

  @media (min-width: 980px) {
    .about__aside {
      justify-self: end;
    }
  }

  .profile {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(15, 15, 15, 0.04),
      0 30px 60px -28px rgba(15, 15, 15, 0.18);
  }

  .profile__media {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-muted);
  }

  .profile__media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center top;
  }

  .profile__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .profile__name {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .profile__role {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-gold);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .profile__toggle {
    margin: 1.1rem 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 0;
    padding: 0;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--color-text);
    cursor: pointer;
    width: fit-content;
    transition: color var(--transition-fast);
  }

  .profile__toggle:hover {
    color: var(--color-gold);
  }

  .profile__toggle:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .profile__toggle-arrow {
    display: inline-block;
    color: var(--color-gold);
    transition: transform var(--transition-fast);
  }

  .profile__toggle:hover .profile__toggle-arrow {
    transform: translateX(3px);
  }

  /* Bio modal */
  .bio-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(0.75rem, 3vw, 2.5rem);
  }

  .bio-modal[hidden] {
    display: none;
  }

  .bio-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 15, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .bio-modal.is-open .bio-modal__backdrop {
    opacity: 1;
  }

  .bio-modal__dialog {
    position: relative;
    display: flex;
    flex-direction: column;
    width: min(640px, 100%);
    max-height: calc(100dvh - 2rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(15, 15, 15, 0.06),
      0 50px 100px -30px rgba(15, 15, 15, 0.45);
    transform: translateY(12px) scale(0.98);
    opacity: 0;
    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.22s ease;
  }

  .bio-modal.is-open .bio-modal__dialog {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .bio-modal__close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 2;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
    cursor: pointer;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .bio-modal__close:hover {
    color: var(--color-gold);
    border-color: var(--color-gold-line);
  }

  .bio-modal__close:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .bio-modal__content {
    padding: clamp(1.75rem, 3vw, 2.5rem);
    padding-right: clamp(3rem, 4vw, 4rem);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .bio-modal__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .bio-modal__title {
    margin: 0.1rem 0 0;
    font-size: clamp(1.5rem, 1.4vw + 1rem, 1.875rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .bio-modal__role {
    margin: 0.2rem 0 0;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .bio-modal__divider {
    margin: 1.1rem 0 0.75rem;
    width: 3.25rem;
    height: 0;
    border-top: 1px solid var(--color-gold-line);
  }

  .bio-modal__text {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .bio-modal__text p {
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .profile__toggle-arrow,
    .bio-modal__backdrop,
    .bio-modal__dialog {
      transition: none;
    }
    .bio-modal__dialog {
      transform: none;
    }
  }
</style>
