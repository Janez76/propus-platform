---
import { ArrowRight } from "@lucide/astro";

const projectTypes = [
  { value: "landingpage", label: "Landingpage" },
  { value: "website", label: "Website" },
  { value: "tool", label: "Tool / Backpanel" },
  { value: "custom", label: "Custom Software" },
  { value: "other", label: "Etwas anderes" },
];

const budgets = [
  { value: "lt-2k", label: "Unter CHF 2'000" },
  { value: "2-5k", label: "CHF 2'000 – 5'000" },
  { value: "5-10k", label: "CHF 5'000 – 10'000" },
  { value: "10-25k", label: "CHF 10'000 – 25'000" },
  { value: "gt-25k", label: "Über CHF 25'000" },
  { value: "unsure", label: "Noch unklar" },
];
---

<section id="kontakt" class="u-section contact">
  <div class="u-container contact__grid">
    <!-- Left: Intro -->
    <aside class="contact__intro u-animate" style="--delay: 0ms">
      <p class="u-eyebrow">Kontakt</p>
      <h2 class="contact__title">Projekt <em>besprechen</em>.</h2>
      <div class="divider-gold" aria-hidden="true"></div>
      <p class="contact__lead">
        Schreiben Sie uns kurz zum Vorhaben – wir melden uns werktags innert 24 Stunden mit einer
        ehrlichen Einschätzung, nicht mit Verkaufsdruck.
      </p>

      <dl class="contact__meta">
        <div>
          <dt>Antwort</dt>
          <dd>Werktags &lt; 24 h</dd>
        </div>
        <div>
          <dt>Erstgespräch</dt>
          <dd>30 Minuten · gratis</dd>
        </div>
      </dl>
    </aside>

    <!-- Right: flat form -->
    <form id="contact-form" class="contact__form u-animate" style="--delay: 100ms" novalidate>
      <div class="contact__fields">
        <div class="contact__field">
          <label for="c-name">Name</label>
          <input id="c-name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="contact__field">
          <label for="c-email">E‑Mail</label>
          <input id="c-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="contact__field contact__field--full">
          <label for="c-company">Firma <span class="contact__opt">optional</span></label>
          <input id="c-company" name="company" type="text" autocomplete="organization" />
        </div>

        <!-- Projekttyp -->
        <div class="contact__field contact__field--combobox">
          <label id="c-type-label" for="c-type-button">Projekttyp</label>
          <div class="combobox" data-combobox>
            <input type="hidden" name="project-type" value="" data-combobox-input />
            <button
              type="button"
              id="c-type-button"
              class="combobox__button"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-labelledby="c-type-label c-type-button"
              data-combobox-button
            >
              <span class="combobox__value" data-combobox-value>Bitte wählen</span>
              <span class="combobox__chev" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 7.5l5 5 5-5" />
                </svg>
              </span>
            </button>
            <ul
              class="combobox__list"
              role="listbox"
              aria-labelledby="c-type-label"
              tabindex="-1"
              data-combobox-list
            >
              {
                projectTypes.map((opt, i) => (
                  <li
                    class="combobox__option"
                    role="option"
                    aria-selected="false"
                    data-value={opt.value}
                    data-index={i}
                    tabindex="-1"
                  >
                    <span class="combobox__option-text">{opt.label}</span>
                    <span class="combobox__option-check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 10.5L8 14.5L16 6.5" />
                      </svg>
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Budget -->
        <div class="contact__field contact__field--combobox">
          <label id="c-budget-label" for="c-budget-button">Budget</label>
          <div class="combobox" data-combobox>
            <input type="hidden" name="budget" value="" data-combobox-input />
            <button
              type="button"
              id="c-budget-button"
              class="combobox__button"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-labelledby="c-budget-label c-budget-button"
              data-combobox-button
            >
              <span class="combobox__value" data-combobox-value>Bitte wählen</span>
              <span class="combobox__chev" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 7.5l5 5 5-5" />
                </svg>
              </span>
            </button>
            <ul
              class="combobox__list"
              role="listbox"
              aria-labelledby="c-budget-label"
              tabindex="-1"
              data-combobox-list
            >
              {
                budgets.map((opt, i) => (
                  <li
                    class="combobox__option"
                    role="option"
                    aria-selected="false"
                    data-value={opt.value}
                    data-index={i}
                    tabindex="-1"
                  >
                    <span class="combobox__option-text">{opt.label}</span>
                    <span class="combobox__option-check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 10.5L8 14.5L16 6.5" />
                      </svg>
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="contact__field contact__field--full">
          <label for="c-message">Nachricht</label>
          <textarea
            id="c-message"
            name="message"
            rows="4"
            required
            placeholder="Kurz zur Idee, zum Zeitrahmen und Budget …"></textarea>
        </div>
      </div>

      <div class="contact__submit">
        <p class="contact__consent">
          Mit Absenden akzeptieren Sie die
          <a href="/datenschutz">Datenschutzerklärung</a>.
        </p>
        <button type="submit" class="btn btn--primary btn--xl">
          Anfrage senden
          <ArrowRight size={16} />
        </button>
      </div>
    </form>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById("contact-form");
    if (form) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        alert(
          "Das Formular ist noch nicht aktiv.\nBitte senden Sie Ihre Anfrage an hallo@propus.ch – danke!"
        );
      });
    }

    const combos = document.querySelectorAll("[data-combobox]");
    let openCombo = null;

    const closeAll = () => {
      combos.forEach((c) => close(c));
    };

    const close = (combo) => {
      combo.classList.remove("is-open");
      const btn = combo.querySelector("[data-combobox-button]");
      if (btn) btn.setAttribute("aria-expanded", "false");
      if (openCombo === combo) openCombo = null;
    };

    const open = (combo) => {
      if (openCombo && openCombo !== combo) close(openCombo);
      combo.classList.add("is-open");
      const btn = combo.querySelector("[data-combobox-button]");
      if (btn) btn.setAttribute("aria-expanded", "true");
      openCombo = combo;

      const list = combo.querySelector("[data-combobox-list]");
      const selected = list.querySelector('[aria-selected="true"]');
      const first = selected || list.querySelector(".combobox__option");
      if (first) {
        setActive(list, first);
      }
    };

    const setActive = (list, option) => {
      list.querySelectorAll(".combobox__option").forEach((o) => o.classList.remove("is-active"));
      if (option) {
        option.classList.add("is-active");
        option.scrollIntoView({ block: "nearest" });
      }
    };

    const selectOption = (combo, option) => {
      const input = combo.querySelector("[data-combobox-input]");
      const valueEl = combo.querySelector("[data-combobox-value]");
      if (!input || !valueEl || !option) return;
      input.value = option.dataset.value || "";
      valueEl.textContent = option.querySelector(".combobox__option-text").textContent;
      combo.classList.add("has-value");
      combo.querySelectorAll(".combobox__option").forEach((o) => o.setAttribute("aria-selected", "false"));
      option.setAttribute("aria-selected", "true");
      close(combo);
      const btn = combo.querySelector("[data-combobox-button]");
      if (btn) btn.focus();
    };

    combos.forEach((combo) => {
      const btn = combo.querySelector("[data-combobox-button]");
      const list = combo.querySelector("[data-combobox-list]");
      const options = Array.from(combo.querySelectorAll(".combobox__option"));

      btn.addEventListener("click", (e) => {
        e.preventDefault();
        if (combo.classList.contains("is-open")) close(combo);
        else open(combo);
      });

      btn.addEventListener("keydown", (e) => {
        if (["ArrowDown", "ArrowUp", "Enter", " "].includes(e.key)) {
          e.preventDefault();
          open(combo);
        }
      });

      options.forEach((opt) => {
        opt.addEventListener("mouseenter", () => setActive(list, opt));
        opt.addEventListener("click", (e) => {
          e.preventDefault();
          selectOption(combo, opt);
        });
      });

      list.addEventListener("keydown", (e) => {
        const active = list.querySelector(".combobox__option.is-active");
        const idx = active ? options.indexOf(active) : -1;
        if (e.key === "ArrowDown") {
          e.preventDefault();
          setActive(list, options[Math.min(options.length - 1, idx + 1)]);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          setActive(list, options[Math.max(0, idx - 1)]);
        } else if (e.key === "Home") {
          e.preventDefault();
          setActive(list, options[0]);
        } else if (e.key === "End") {
          e.preventDefault();
          setActive(list, options[options.length - 1]);
        } else if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          if (active) selectOption(combo, active);
        } else if (e.key === "Escape" || e.key === "Tab") {
          close(combo);
          if (e.key === "Escape") btn.focus();
        }
      });

      // Make list focusable to catch keys once opened
      combo.addEventListener("transitionend", () => {
        if (combo.classList.contains("is-open")) list.focus();
      });
      combo.addEventListener("focusout", (e) => {
        if (!combo.contains(e.relatedTarget)) close(combo);
      });
    });

    document.addEventListener("click", (e) => {
      if (!openCombo) return;
      if (!openCombo.contains(e.target)) close(openCombo);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && openCombo) {
        const btn = openCombo.querySelector("[data-combobox-button]");
        close(openCombo);
        if (btn) btn.focus();
      }
    });
  })();
</script>

<style>
  .contact {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .contact__grid {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: start;
  }

  @media (min-width: 960px) {
    .contact__grid {
      grid-template-columns: 0.85fr 1.15fr;
      gap: clamp(3.5rem, 7vw, 6rem);
    }
  }

  /* ---------- Left (intro) ---------- */
  .contact__intro {
    max-width: 28rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: calc(var(--header-h) + 1.5rem);
  }

  @media (max-width: 959px) {
    .contact__intro {
      position: static;
    }
  }

  .contact__title {
    font-size: clamp(1.875rem, 2.5vw + 1rem, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--color-text);
  }

  .contact__lead {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .contact__meta {
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact__meta > div {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .contact__meta > div:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 520px) {
    .contact__meta > div {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding-block: 0.85rem;
    }
  }

  .contact__meta dt {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .contact__meta dd {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  /* ---------- Flat Form ---------- */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2.25rem);
    background: transparent;
    border: 0;
    border-radius: 0;
    padding: 0;
    box-shadow: none;
  }

  .contact__fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 720px) {
    .contact__fields {
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(1.5rem, 3vw, 2.5rem);
    }
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
    padding-block: 1rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .contact__field--full {
    grid-column: 1 / -1;
  }

  .contact__field label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    transition: color var(--transition-fast);
  }

  .contact__opt {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text-muted), transparent 20%);
  }

  .contact__field input,
  .contact__field textarea {
    width: 100%;
    padding: 0.25rem 0 0.15rem;
    background: transparent;
    color: var(--color-text);
    border: 0;
    border-radius: 0;
    font: inherit;
    font-size: 1.0625rem;
    line-height: 1.5;
    letter-spacing: -0.005em;
    transition: color var(--transition-fast);
  }

  .contact__field input::placeholder,
  .contact__field textarea::placeholder {
    color: color-mix(in oklab, var(--color-text-muted), transparent 35%);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    outline: none;
  }

  /* subtle underline highlight on focus — flat, not boxed */
  .contact__field::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -1px;
    height: 1px;
    background: var(--color-gold);
    transition: right 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .contact__field:focus-within::after,
  .contact__field--combobox:has(.combobox.is-open)::after {
    right: 0;
  }

  .contact__field:focus-within label,
  .contact__field--combobox:has(.combobox.is-open) label {
    color: var(--color-text);
  }

  .contact__field textarea {
    resize: none;
    min-height: 6rem;
  }

  /* ---------- Custom Combobox (Select) ---------- */
  .combobox {
    position: relative;
  }

  .combobox__button {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.25rem 0 0.15rem;
    background: transparent;
    border: 0;
    border-radius: 0;
    color: var(--color-text);
    font: inherit;
    font-size: 1.0625rem;
    line-height: 1.5;
    letter-spacing: -0.005em;
    text-align: left;
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .combobox__button:focus {
    outline: none;
  }

  .combobox__value {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: color-mix(in oklab, var(--color-text-muted), transparent 20%);
  }

  .combobox.has-value .combobox__value {
    color: var(--color-text);
  }

  .combobox__chev {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      color var(--transition-fast);
  }

  .combobox.is-open .combobox__chev {
    transform: rotate(180deg);
    color: var(--color-gold);
  }

  .combobox__list {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    z-index: 20;
    margin: 0;
    padding: 0.35rem;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 18px 48px -18px rgba(0, 0, 0, 0.25);
    max-height: 16rem;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition:
      opacity 0.18s ease,
      transform 0.18s cubic-bezier(0.22, 1, 0.36, 1);
    outline: none;
  }

  .combobox.is-open .combobox__list {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Scrollbar styling */
  .combobox__list::-webkit-scrollbar {
    width: 8px;
  }
  .combobox__list::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 4px;
  }
  .combobox__list::-webkit-scrollbar-thumb:hover {
    background: color-mix(in oklab, var(--color-text-muted), transparent 50%);
  }

  .combobox__option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.65rem 0.85rem;
    border-radius: calc(var(--radius-md) - 4px);
    color: var(--color-text);
    font-size: 0.9375rem;
    line-height: 1.4;
    cursor: pointer;
    user-select: none;
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
    outline: none;
  }

  .combobox__option-text {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .combobox__option-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .combobox__option[aria-selected="true"] .combobox__option-check {
    opacity: 1;
    transform: scale(1);
  }

  .combobox__option.is-active,
  .combobox__option:hover {
    background: color-mix(in oklab, var(--color-gold), transparent 92%);
  }

  .combobox__option[aria-selected="true"] {
    color: var(--color-text);
    background: color-mix(in oklab, var(--color-gold), transparent 88%);
  }

  @media (prefers-reduced-motion: reduce) {
    .combobox__chev,
    .combobox__list,
    .combobox__option-check {
      transition: none;
    }
  }

  /* Submit row */
  .contact__submit {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1.25rem;
    padding-top: 0.25rem;
  }

  .contact__submit > .btn {
    flex-shrink: 0;
  }

  @media (max-width: 719px) {
    .contact__submit {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      padding-top: 0.5rem;
    }
    .contact__submit > .btn {
      width: 100%;
      justify-content: center;
    }
    .contact__consent {
      order: 2;
      text-align: center;
      max-width: none;
    }
  }

  .contact__consent {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    max-width: 24rem;
  }

  .contact__consent a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .contact__consent a:hover {
    text-decoration: underline;
  }
</style>
