---
import { Check, ArrowRight } from "@lucide/astro";

interface Tier {
  name: string;
  price: string;
  tagline: string;
  features: string[];
  ctaLabel: string;
}

const tiers: Tier[] = [
  {
    name: "Landingpage",
    price: "ab CHF 500",
    tagline: "Kampagnen, Launches, Fokus.",
    features: [
      "1 Seite, klar konvertierend",
      "Schnell & mobil-first",
      "SEO-Grundlagen & Social Preview",
      "Formular-Anbindung",
      "Go-live innert ca. 2 Wochen",
    ],
    ctaLabel: "Anfragen",
  },
  {
    name: "Website",
    price: "ab CHF 2'500",
    tagline: "Ihr Auftritt, strukturiert.",
    features: [
      "5–8 Seiten, CMS optional",
      "Design auf Ihre Marke",
      "Technisches SEO",
      "Analytics-Setup",
      "30 Tage Post-Launch-Support",
    ],
    ctaLabel: "Anfragen",
  },
  {
    name: "Custom Tool",
    price: "ab CHF 3'000",
    tagline: "Portale, Logik, Automation.",
    features: [
      "Scope nach Ihrem Prozess",
      "Rollen & Berechtigungen",
      "APIs & Webhooks",
      "Dokumentation für Ihr Team",
      "SLA optional",
    ],
    ctaLabel: "Anfragen",
  },
];
---

<section id="preise" class="u-section pricing">
  <div class="u-container">
    <div class="section-heading section-heading--center u-animate" style="--delay: 0ms">
      <p class="u-eyebrow">Preise</p>
      <h2>Pakete mit klarem <em>Umfang</em></h2>
      <div class="divider-gold" aria-hidden="true"></div>
      <p class="section-heading__sub">
        Drei Formate, drei Preisrahmen. Die bindende Offerte kommt nach dem Briefing – schriftlich und ohne Kleingedrucktes.
      </p>
    </div>

    <div class="pricing__grid u-animate" style="--delay: 120ms">
      {
        tiers.map((tier, i) => (
          <article class="pricing__card" style={`--card-delay: ${i * 60}ms`}>
            <header class="pricing__head">
              <h3 class="pricing__name">{tier.name}</h3>
              <p class="pricing__tagline">{tier.tagline}</p>
            </header>
            <p class="pricing__price">{tier.price}</p>
            <ul class="pricing__features">
              {tier.features.map((feature) => (
                <li>
                  <Check size={17} class="pricing__check" />
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            <a href="#kontakt" class="btn btn--primary pricing__cta">
              {tier.ctaLabel}
              <ArrowRight size={16} />
            </a>
          </article>
        ))
      }
    </div>

    <p class="pricing__note">Alle Preise exkl. MwSt.</p>
  </div>
</section>

<style>
  .pricing {
    background: var(--color-bg-muted);
    border-top: 1px solid var(--color-border);
  }

  .pricing__grid {
    margin-top: clamp(2rem, 5vw, 3rem);
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .pricing__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }

  .pricing__card {
    display: flex;
    flex-direction: column;
    padding: clamp(1.4rem, 3vw, 2.25rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    transition:
      border-color var(--transition-med),
      box-shadow var(--transition-med),
      transform var(--transition-med);
  }

  .pricing__card:hover {
    border-color: var(--color-gold-line);
    box-shadow: var(--shadow-hover);
    transform: translateY(-3px);
  }

  .pricing__head {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .pricing__name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .pricing__tagline {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .pricing__price {
    margin-top: 1.25rem;
    padding-block: clamp(1rem, 2.5vw, 1.25rem);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    font-size: clamp(1.5rem, 2vw + 1rem, 2.25rem);
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: -0.02em;
  }

  .pricing__features {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex: 1;
  }

  .pricing__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .pricing__check {
    color: var(--color-gold);
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .pricing__cta {
    margin-top: 2rem;
    width: 100%;
  }

  .pricing__note {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
