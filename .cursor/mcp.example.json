{
  "mcpServers": {
    "exa": {
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,deep_researcher_start,deep_researcher_check"
    },
    "higgsfield": {
      "url": "https://mcp.higgsfield.ai/mcp"
    },
    "publer": {
      "command": "npx",
      "args": ["-y", "publer-mcp-server"],
      "env": {
        "PUBLER_API_KEY": "${PUBLER_API_KEY}",
        "PUBLER_WORKSPACE_ID": "${PUBLER_WORKSPACE_ID}"
      }
    }
  }
}
