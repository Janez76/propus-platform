<div class="tm-theme-toggle-wrap">
  <button type="button" id="tmThemeToggle" class="tm-theme-toggle" aria-label="Darstellung">
    <i class="fa-solid fa-desktop" id="tmThemeIcon" aria-hidden="true"></i>
    <span id="tmThemeLabel">System</span>
  </button>
</div>
<script>
(function () {
  var STORAGE_KEY = "admin_theme_v1";
  var mql = window.matchMedia("(prefers-color-scheme: dark)");
  var mediaListener = null;

  function getStored() {
    try {
      var t = localStorage.getItem(STORAGE_KEY);
      if (t === "light" || t === "dark" || t === "system") return t;
    } catch (e) {}
    return "system";
  }

  function resolved(theme) {
    if (theme === "system") return mql.matches ? "dark" : "light";
    return theme;
  }

  function applyResolved(resolvedTheme) {
    var html = document.documentElement;
    var dark = resolvedTheme === "dark";
    html.classList.toggle("dark", dark);
    html.style.colorScheme = dark ? "dark" : "light";
  }

  function persist(theme) {
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch (e) {}
  }

  function bindMedia(theme) {
    if (mediaListener) {
      mql.removeEventListener("change", mediaListener);
      mediaListener = null;
    }
    if (theme !== "system") return;
    mediaListener = function () {
      if (getStored() !== "system") return;
      applyResolved(resolved("system"));
      updateToggleUI();
    };
    mql.addEventListener("change", mediaListener);
  }

  function updateToggleUI() {
    var theme = getStored();
    var btn = document.getElementById("tmThemeToggle");
    var icon = document.getElementById("tmThemeIcon");
    var label = document.getElementById("tmThemeLabel");
    if (!btn || !icon || !label) return;
    var iconClass =
      theme === "dark"
        ? "fa-moon"
        : theme === "light"
          ? "fa-sun"
          : "fa-desktop";
    icon.className = "fa-solid " + iconClass;
    label.textContent =
      theme === "dark" ? "Dunkel" : theme === "light" ? "Hell" : "System";
    var title = "Darstellung: " + label.textContent;
    btn.title = title;
    btn.setAttribute("aria-label", title);
  }

  function cycle() {
    var t = getStored();
    var next = t === "system" ? "light" : t === "light" ? "dark" : "system";
    persist(next);
    applyResolved(resolved(next));
    bindMedia(next);
    updateToggleUI();
  }

  function init() {
    var t = getStored();
    applyResolved(resolved(t));
    bindMedia(t);
    var btn = document.getElementById("tmThemeToggle");
    if (btn && !btn.__propusTmThemeBound) {
      btn.__propusTmThemeBound = true;
      btn.addEventListener("click", cycle);
    }
    updateToggleUI();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
