<% const _pv = typeof variant === 'string' ? variant : 'portal'; %>
<div id="profileEditBackdrop" class="profile-edit-backdrop" hidden aria-hidden="true"></div>
<div id="profileEditDialog" class="profile-edit-dialog" role="dialog" aria-modal="true" aria-labelledby="profileEditTitle" hidden>
  <div class="profile-edit-panel">
    <div class="profile-edit-head">
      <div class="profile-edit-head-text">
        <h2 id="profileEditTitle">Profil bearbeiten</h2>
        <p class="profile-edit-sub">Kontodaten &amp; Erscheinungsbild</p>
      </div>
      <button type="button" class="profile-edit-close" id="profileEditClose" aria-label="Schließen">
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
    </div>

    <div class="profile-edit-body">
      <form id="profileEditForm" class="profile-edit-form">
        <div class="profile-edit-section">
          <div class="profile-edit-section-title">
            <i class="fa-regular fa-user" aria-hidden="true"></i>
            <span>Persönliche Angaben</span>
          </div>
          <label class="profile-edit-label" for="profileDisplayName">Anzeigename</label>
          <input type="text" id="profileDisplayName" name="displayName" class="profile-edit-input" autocomplete="name" maxlength="120" placeholder="Vor- und Nachname">

          <% if (_pv === 'portal') { %>
          <div class="profile-edit-subblock profile-edit-subblock--tight">
            <p class="profile-edit-subhead">Passwort ändern</p>
            <p class="profile-edit-hint profile-edit-hint--tight">Ihr Login wird jetzt intern im Kundenportal verwaltet.</p>
            <label class="profile-edit-label" for="profilePwCurrent">Aktuelles Passwort</label>
            <input type="password" id="profilePwCurrent" class="profile-edit-input" autocomplete="current-password">
            <label class="profile-edit-label" for="profilePwNew">Neues Passwort</label>
            <input type="password" id="profilePwNew" class="profile-edit-input" autocomplete="new-password" minlength="8">
            <label class="profile-edit-label" for="profilePwNew2">Neues Passwort wiederholen</label>
            <input type="password" id="profilePwNew2" class="profile-edit-input" autocomplete="new-password" minlength="8">
            <button type="button" class="profile-edit-btn profile-edit-btn--secondary" id="profilePasswordSave">
              Passwort speichern
            </button>
          </div>
          <% } else { %>
          <div id="adminPasswordBlock" class="profile-edit-subblock profile-edit-subblock--tight" hidden>
            <p class="profile-edit-subhead">Passwort ändern</p>
            <label class="profile-edit-label" for="profilePwCurrent">Aktuelles Passwort</label>
            <input type="password" id="profilePwCurrent" class="profile-edit-input" autocomplete="current-password">
            <label class="profile-edit-label" for="profilePwNew">Neues Passwort</label>
            <input type="password" id="profilePwNew" class="profile-edit-input" autocomplete="new-password" minlength="8">
            <label class="profile-edit-label" for="profilePwNew2">Neues Passwort wiederholen</label>
            <input type="password" id="profilePwNew2" class="profile-edit-input" autocomplete="new-password" minlength="8">
            <button type="button" class="profile-edit-btn profile-edit-btn--secondary" id="profilePasswordSave">
              Passwort speichern
            </button>
          </div>
          <% } %>
        </div>

        <div class="profile-edit-section">
          <div class="profile-edit-section-title">
            <i class="fa-solid fa-key" aria-hidden="true"></i>
            <span>Anmeldung &amp; Sicherheit</span>
          </div>

          <label class="profile-edit-label" for="profileEmailDisplay">E-Mail-Adresse (Login)</label>
          <input type="text" id="profileEmailDisplay" class="profile-edit-input profile-edit-input--readonly" readonly tabindex="-1" autocomplete="username">

          <% if (_pv === 'portal') { %>
          <p class="profile-edit-hint">Nur Anzeige. Die Login-E-Mail ist mit Ihren Touren bzw. Team-Zugriffen verknüpft.</p>
          <% } else { %>
          <p id="adminAuthIntro" class="profile-edit-hint">Änderungen an der E-Mail gelten für Ihre Admin-Anmeldung.</p>

          <div id="adminEnvHint" class="profile-edit-banner profile-edit-banner--info" hidden>
            <strong>Nur .env-Zugang:</strong> E-Mail und Passwort für dieses Konto sind in der Server-Konfiguration hinterlegt, nicht in der Datenbank. Bitte dort anpassen oder einen Einladungs-Link nutzen.
          </div>

          <div id="adminEmailBlock" class="profile-edit-subblock" hidden>
            <p class="profile-edit-subhead">E-Mail-Adresse ändern</p>
            <label class="profile-edit-label" for="profileNewEmail">Neue E-Mail-Adresse</label>
            <input type="email" id="profileNewEmail" class="profile-edit-input" autocomplete="off" maxlength="200">
            <label class="profile-edit-label" for="profileEmailPw">Aktuelles Passwort zur Bestätigung</label>
            <input type="password" id="profileEmailPw" class="profile-edit-input" autocomplete="current-password">
            <button type="button" class="profile-edit-btn profile-edit-btn--secondary" id="profileEmailSave">
              E-Mail speichern
            </button>
          </div>
          <% } %>
        </div>

        <div class="profile-edit-section">
          <div class="profile-edit-section-title">
            <i class="fa-regular fa-image" aria-hidden="true"></i>
            <span>Profilfoto</span>
          </div>
          <label class="profile-edit-upload" for="profilePhotoFile">
            <span class="profile-edit-upload-inner">
              <i class="fa-solid fa-cloud-arrow-up" aria-hidden="true"></i>
              <span class="profile-edit-upload-text"><strong>Datei wählen</strong> oder hier ablegen</span>
              <span class="profile-edit-upload-meta">JPG, PNG, GIF, WebP · max. 512&nbsp;KB</span>
            </span>
            <input type="file" id="profilePhotoFile" name="photo" accept="image/jpeg,image/png,image/gif,image/webp" class="profile-edit-file-native">
          </label>
          <p id="profilePhotoFileName" class="profile-edit-file-name" hidden></p>

          <label class="profile-edit-check">
            <input type="checkbox" id="profileRemovePhoto" name="removePhoto" value="1">
            <span>Profilfoto entfernen</span>
          </label>
        </div>

        <p id="profileEditError" class="profile-edit-error" hidden></p>
        <p id="profileEditOk" class="profile-edit-ok" hidden></p>

        <div class="profile-edit-actions">
          <button type="button" class="profile-edit-btn profile-edit-btn--ghost" id="profileEditCancel">Abbrechen</button>
          <button type="submit" class="profile-edit-btn profile-edit-btn--primary" id="profileEditSave">
            <i class="fa-solid fa-check" aria-hidden="true"></i> Profil speichern
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
(function () {
  var variant = <%- JSON.stringify(_pv) %>;
  var base = variant === 'admin' ? '/admin' : '/portal';
  var openBtn = document.getElementById('sidebarProfileOpen');
  var dialog = document.getElementById('profileEditDialog');
  var backdrop = document.getElementById('profileEditBackdrop');
  var closeBtn = document.getElementById('profileEditClose');
  var cancelBtn = document.getElementById('profileEditCancel');
  var form = document.getElementById('profileEditForm');
  var errEl = document.getElementById('profileEditError');
  var okEl = document.getElementById('profileEditOk');
  var fileNameEl = document.getElementById('profilePhotoFileName');
  if (!openBtn || !dialog || !form) return;

  function showErr(msg) {
    if (!errEl) return;
    errEl.textContent = msg || '';
    errEl.hidden = !msg;
    if (okEl) okEl.hidden = true;
  }
  function showOk(msg) {
    if (!okEl) return;
    okEl.textContent = msg || 'Gespeichert.';
    okEl.hidden = false;
    if (errEl) errEl.hidden = true;
  }

  function applyAuthUi(data) {
    if (variant === 'portal') {
      return;
    }
    var envHint = document.getElementById('adminEnvHint');
    var emailBlock = document.getElementById('adminEmailBlock');
    var pwBlock = document.getElementById('adminPasswordBlock');
    var intro = document.getElementById('adminAuthIntro');
    if (envHint) envHint.hidden = true;
    if (emailBlock) emailBlock.hidden = true;
    if (pwBlock) pwBlock.hidden = true;
    if (!data.isDatabaseUser && data.isEnvCredentials && envHint) {
      envHint.hidden = false;
      if (intro) intro.hidden = true;
      return;
    }
    if (intro) intro.hidden = false;
    if (emailBlock) emailBlock.hidden = !data.canChangeEmail;
    if (pwBlock) pwBlock.hidden = !data.canChangePassword;
  }

  function scrollbarWidth() {
    return Math.max(0, window.innerWidth - document.documentElement.clientWidth);
  }
  function lockBodyScroll() {
    var w = scrollbarWidth();
    if (w > 0) document.body.style.paddingRight = w + 'px';
    document.body.classList.add('profile-edit-open');
  }
  function unlockBodyScroll() {
    document.body.style.paddingRight = '';
    document.body.classList.remove('profile-edit-open');
  }

  function openModal() {
    showErr('');
    if (okEl) okEl.hidden = true;
    dialog.hidden = false;
    backdrop.hidden = false;
    lockBodyScroll();
    fetch(base + '/profile/me', { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) throw new Error(data.error || 'Laden fehlgeschlagen');
        applyAuthUi(data);
        var em = document.getElementById('profileEmailDisplay');
        if (em) em.value = data.email || '';
        var dn = document.getElementById('profileDisplayName');
        if (dn) dn.value = data.displayName || '';
        var ne = document.getElementById('profileNewEmail');
        if (ne) ne.value = '';
        var epw = document.getElementById('profileEmailPw');
        if (epw) epw.value = '';
        ['profilePwCurrent', 'profilePwNew', 'profilePwNew2'].forEach(function (id) {
          var el = document.getElementById(id);
          if (el) el.value = '';
        });
        var rm = document.getElementById('profileRemovePhoto');
        if (rm) rm.checked = false;
        var f = document.getElementById('profilePhotoFile');
        if (f) f.value = '';
        if (fileNameEl) { fileNameEl.textContent = ''; fileNameEl.hidden = true; }
      })
      .catch(function (e) { showErr(e.message || 'Profil konnte nicht geladen werden.'); });
    closeBtn && closeBtn.focus();
  }

  function closeModal() {
    dialog.hidden = true;
    backdrop.hidden = true;
    unlockBodyScroll();
    showErr('');
    if (okEl) okEl.hidden = true;
  }

  var fileInput = document.getElementById('profilePhotoFile');
  if (fileInput && fileNameEl) {
    fileInput.addEventListener('change', function () {
      var f = fileInput.files && fileInput.files[0];
      if (f) {
        fileNameEl.textContent = 'Ausgewählt: ' + f.name;
        fileNameEl.hidden = false;
      } else {
        fileNameEl.hidden = true;
      }
    });
  }

  openBtn.addEventListener('click', function (e) { e.preventDefault(); openModal(); });
  closeBtn && closeBtn.addEventListener('click', closeModal);
  cancelBtn && cancelBtn.addEventListener('click', closeModal);
  backdrop && backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !dialog.hidden) closeModal();
  });

  var btnPw = document.getElementById('profilePasswordSave');
  if (variant === 'admin') {
    var btnEmail = document.getElementById('profileEmailSave');
    if (btnEmail) {
      btnEmail.addEventListener('click', function () {
        showErr('');
        var ne = document.getElementById('profileNewEmail');
        var pw = document.getElementById('profileEmailPw');
        btnEmail.disabled = true;
        fetch(base + '/profile/email', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ newEmail: (ne && ne.value) || '', currentPassword: (pw && pw.value) || '' }),
        })
          .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
          .then(function (x) {
            btnEmail.disabled = false;
            if (!x.ok || !x.j.ok) throw new Error((x.j && x.j.error) || 'E-Mail konnte nicht geändert werden');
            showOk('E-Mail gespeichert. Seite wird neu geladen…');
            window.location.reload();
          })
          .catch(function (e) {
            btnEmail.disabled = false;
            showErr(e.message || 'Fehler');
          });
      });
    }
  }
  if (btnPw) {
    btnPw.addEventListener('click', function () {
      showErr('');
      var c = document.getElementById('profilePwCurrent');
      var n1 = document.getElementById('profilePwNew');
      var n2 = document.getElementById('profilePwNew2');
      if (!n1 || !n2 || n1.value !== n2.value) {
        showErr('Die neuen Passwörter stimmen nicht überein.');
        return;
      }
      btnPw.disabled = true;
      fetch(base + '/profile/password', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          currentPassword: (c && c.value) || '',
          newPassword: (n1 && n1.value) || '',
        }),
      })
        .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
        .then(function (x) {
          btnPw.disabled = false;
          if (!x.ok || !x.j.ok) throw new Error((x.j && x.j.error) || 'Passwort konnte nicht geändert werden');
          if (c) c.value = '';
          if (n1) n1.value = '';
          if (n2) n2.value = '';
          showOk('Passwort geändert.');
        })
        .catch(function (e) {
          btnPw.disabled = false;
          showErr(e.message || 'Fehler');
        });
    });
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    showErr('');
    if (okEl) okEl.hidden = true;
    var fd = new FormData();
    var dn = document.getElementById('profileDisplayName');
    if (dn) fd.append('displayName', dn.value || '');
    var rm = document.getElementById('profileRemovePhoto');
    if (rm && rm.checked) fd.append('removePhoto', '1');
    var fin = document.getElementById('profilePhotoFile');
    if (fin && fin.files && fin.files[0]) fd.append('photo', fin.files[0]);
    var saveBtn = document.getElementById('profileEditSave');
    if (saveBtn) { saveBtn.disabled = true; saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i> Speichern…'; }
    fetch(base + '/profile/me', { method: 'POST', body: fd, credentials: 'same-origin' })
      .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
      .then(function (x) {
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerHTML = '<i class="fa-solid fa-check" aria-hidden="true"></i> Profil speichern';
        }
        if (!x.ok || !x.j.ok) throw new Error((x.j && x.j.error) || 'Speichern fehlgeschlagen');
        window.location.reload();
      })
      .catch(function (e) {
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerHTML = '<i class="fa-solid fa-check" aria-hidden="true"></i> Profil speichern';
        }
        showErr(e.message || 'Fehler beim Speichern');
      });
  });
})();
</script>
