<%/* Gleicher Schlüssel + Logik wie platform/frontend/index.html (React Admin) */%>
<script>
(function () {
  try {
    var t = localStorage.getItem("admin_theme_v1") || "system";
    var dark =
      t === "dark" ||
      (t === "system" &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);
    document.documentElement.classList.toggle("dark", dark);
    document.documentElement.style.colorScheme = dark ? "dark" : "light";
  } catch (e) {}
})();
</script>
