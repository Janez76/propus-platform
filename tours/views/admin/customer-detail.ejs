<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (customer.name||'').trim() || (customer.company||'').trim() || customer.email %> – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
  <style>
    .contact-card { display:flex; align-items:center; gap:0.75rem; padding:0.65rem 0.75rem; background:var(--bg); border:1px solid var(--border); border-radius:8px; }
    .contact-avatar { width:36px; height:36px; border-radius:50%; background:rgba(99,102,241,0.2); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:0.85rem; font-weight:700; color:#a5b4fc; }
    .contact-info { flex:1; min-width:0; }
    .contact-name { font-weight:600; font-size:0.88rem; }
    .contact-meta { font-size:0.78rem; color:var(--text-muted); margin-top:1px; }
    .contact-actions { display:flex; align-items:center; gap:0.4rem; flex-shrink:0; }
    .portal-role-wrap { display:flex; align-items:center; gap:0.3rem; }
    .portal-role-select {
      padding:0.28rem 0.5rem; font-size:0.75rem; border-radius:6px;
      border:1px solid var(--border); background:var(--bg); color:var(--text); cursor:pointer;
    }
    .portal-role-badge {
      display:inline-flex; align-items:center; gap:3px;
      padding:2px 7px; border-radius:20px; font-size:0.7rem; font-weight:600;
    }
    .prb-admin      { background:rgba(197,160,89,.12); color:#C5A059; }
    .prb-mitarbeiter{ background:rgba(99,102,241,.12); color:#a5b4fc; }
    .prb-none       { background:rgba(0,0,0,.05); color:var(--text-muted); }
    .portal-role-save { padding:0.28rem 0.6rem; font-size:0.73rem; }
  </style>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">

      <% const bp = typeof basePath === 'string' ? basePath : ''; %>
      <!-- Breadcrumb -->
      <div style="font-size:0.82rem;color:var(--text-muted);margin-bottom:1rem;">
        <a href="<%= bp %>/admin/customers" style="color:var(--link);text-decoration:none;">Kunden</a>
        <span style="margin:0 0.4rem;">›</span>
        <span><%= (customer.name||'').trim() || (customer.company||'').trim() || customer.email %></span>
      </div>

      <% if (flash) { %>
        <div style="background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.3);border-radius:8px;padding:0.65rem 1rem;margin-bottom:1rem;font-size:0.88rem;color:#4ade80;">
          <i class="fa-solid fa-check-circle"></i> <%= flash %>
        </div>
      <% } %>
      <% if (error) { %>
        <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:0.65rem 1rem;margin-bottom:1rem;font-size:0.88rem;color:#f87171;">
          <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
        </div>
      <% } %>

      <div style="display:grid;grid-template-columns:1fr 320px;gap:1.25rem;align-items:start;">

        <!-- Hauptformular -->
        <div>
          <div class="section">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
              <h2 style="margin:0;font-size:1rem;">Kundendaten</h2>
              <% if (customer.exxas_contact_id) { %>
                <span class="badge" style="background:rgba(251,191,36,0.15);color:#fbbf24;font-size:0.78rem;">
                  <i class="fa-solid fa-link"></i> Exxas #<%= customer.exxas_contact_id %>
                </span>
              <% } %>
            </div>

            <form method="POST" action="<%= bp %>/admin/customers/<%= customer.id %>">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.85rem;">

                <div class="form-group">
                  <label class="form-label">Name *</label>
                  <input type="text" name="name" value="<%= customer.name || '' %>"
                    class="form-input" required placeholder="Vor- und Nachname oder Firmenname">
                </div>

                <div class="form-group">
                  <label class="form-label">E-Mail *</label>
                  <input type="email" name="email" value="<%= customer.email %>"
                    class="form-input" required>
                </div>

                <div class="form-group">
                  <label class="form-label">Firma</label>
                  <input type="text" name="company" value="<%= customer.company || '' %>"
                    class="form-input" placeholder="Firmenname">
                </div>

                <div class="form-group">
                  <label class="form-label">Telefon</label>
                  <input type="text" name="phone" value="<%= customer.phone || '' %>"
                    class="form-input" placeholder="+41 44 …">
                </div>

                <div class="form-group">
                  <label class="form-label">Strasse</label>
                  <input type="text" name="street" value="<%= customer.street || '' %>"
                    class="form-input" placeholder="Musterstrasse 1">
                </div>

                <div class="form-group">
                  <label class="form-label">PLZ / Ort</label>
                  <input type="text" name="zipcity" value="<%= customer.zipcity || '' %>"
                    class="form-input" placeholder="8001 Zürich">
                </div>

                <div class="form-group" style="grid-column:1/-1;">
                  <label class="form-label">Notizen (intern)</label>
                  <textarea name="notes" rows="3" class="form-input"
                    placeholder="Interne Notizen zum Kunden…"><%= customer.notes || '' %></textarea>
                </div>

                <div class="form-group">
                  <label class="form-label">Exxas Kontakt-ID</label>
                  <input type="text" name="exxas_contact_id" value="<%= customer.exxas_contact_id || '' %>"
                    class="form-input" placeholder="Exxas ID (optional)">
                </div>

                <div class="form-group" style="display:flex;align-items:center;gap:0.6rem;padding-top:1.5rem;">
                  <input type="checkbox" name="blocked" id="blocked" value="1"
                    <%= customer.blocked ? 'checked' : '' %>
                    style="width:16px;height:16px;accent-color:#ef4444;">
                  <label for="blocked" style="font-size:0.88rem;cursor:pointer;color:var(--text-muted);">
                    Konto gesperrt
                  </label>
                </div>

              </div>

              <div style="display:flex;gap:0.6rem;margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border);">
                <button type="submit" class="btn btn-primary">
                  <i class="fa-solid fa-floppy-disk"></i> Speichern
                </button>
                <a href="<%= bp %>/admin/customers" class="btn btn-ghost">Abbrechen</a>
              </div>
            </form>
          </div>

          <!-- Kontaktpersonen -->
          <div class="section" style="margin-top:1rem;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.85rem;">
              <h2 style="margin:0;font-size:1rem;">
                <i class="fa-solid fa-address-book" style="color:var(--text-muted);margin-right:0.4rem;"></i>
                Kontaktpersonen (<%= contacts.length %>)
              </h2>
              <button type="button" class="btn btn-ghost btn-small" onclick="showAddContact()">
                <i class="fa-solid fa-plus"></i> Hinzufügen
              </button>
            </div>

            <!-- Neuer Kontakt (ausgeblendet) -->
            <div id="addContactForm" style="display:none;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.85rem;margin-bottom:0.85rem;">
              <form method="POST" action="<%= bp %>/admin/customers/<%= customer.id %>/contacts">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                  <div class="form-group">
                    <label class="form-label">Name *</label>
                    <input type="text" name="name" class="form-input" placeholder="Max Muster" required>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Rolle / Position</label>
                    <input type="text" name="role" class="form-input" placeholder="Geschäftsführer, IT, …">
                  </div>
                  <div class="form-group">
                    <label class="form-label">E-Mail</label>
                    <input type="email" name="email" class="form-input">
                  </div>
                  <div class="form-group">
                    <label class="form-label">Telefon</label>
                    <input type="text" name="phone" class="form-input" placeholder="+41 …">
                  </div>
                </div>
                <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
                  <button type="submit" class="btn btn-primary btn-small">Speichern</button>
                  <button type="button" class="btn btn-ghost btn-small" onclick="hideAddContact()">Abbrechen</button>
                </div>
              </form>
            </div>

            <%
            const portalRoles = typeof contactPortalRoles !== 'undefined' ? contactPortalRoles : {};
            function portalRoleBadge(r) {
              if (!r) return '<span class="portal-role-badge prb-none"><i class="fa-solid fa-ban"></i> Kein Zugang</span>';
              if (r.role === 'admin') return '<span class="portal-role-badge prb-admin"><i class="fa-solid fa-user-gear"></i> Kunden-Admin</span>';
              return '<span class="portal-role-badge prb-mitarbeiter"><i class="fa-solid fa-user"></i> Mitarbeiter</span>';
            }
          %>
          <% if (contacts.length === 0) { %>
              <div style="color:var(--text-muted);font-size:0.85rem;padding:0.5rem 0;">
                Noch keine Kontaktpersonen eingetragen.
              </div>
            <% } else { %>
              <div style="display:flex;flex-direction:column;gap:0.5rem;">
                <% contacts.forEach(ct => {
                   const ctEmail = (ct.email || '').trim().toLowerCase();
                   const pr = ctEmail ? portalRoles[ctEmail] : null;
                   const currentRole = pr ? pr.role : '';
                %> 
                  <div class="contact-card">
                    <div class="contact-avatar">
                      <%= (ct.name || '?').charAt(0).toUpperCase() %>
                    </div>
                    <div class="contact-info">
                      <div class="contact-name"><%= ct.name %></div>
                      <div class="contact-meta">
                        <% if (ct.role) { %><span><%= ct.role %></span><% } %>
                        <% if (ct.email) { %><% if (ct.role) { %> · <% } %><a href="mailto:<%= ct.email %>" style="color:var(--link);"><%= ct.email %></a><% } %>
                        <% if (ct.phone) { %> · <%= ct.phone %><% } %>
                      </div>
                      <% if (ctEmail) { %>
                        <div style="margin-top:0.35rem;">
                          <%- portalRoleBadge(pr) %>
                        </div>
                      <% } %>
                    </div>
                    <div class="contact-actions">
                      <% if (ctEmail) { %>
                        <form method="POST" action="<%= bp %>/admin/customers/<%= customer.id %>/contacts/<%= ct.id %>/portal-role"
                              class="portal-role-wrap" title="Portal-Zugang setzen">
                          <select name="portal_role" class="portal-role-select" onchange="this.form.submit()" title="Portal-Rolle">
                            <option value=""              <%= currentRole==='' ? 'selected':'' %>>Kein Zugang</option>
                            <option value="mitarbeiter"   <%= currentRole==='mitarbeiter' ? 'selected':'' %>>Mitarbeiter</option>
                            <option value="admin"         <%= currentRole==='admin' ? 'selected':'' %>>Kunden-Admin</option>
                          </select>
                        </form>
                      <% } else { %>
                        <span style="font-size:0.72rem;color:var(--text-muted);" title="Keine E-Mail – kein Portal-Zugang">
                          <i class="fa-solid fa-envelope-slash"></i>
                        </span>
                      <% } %>
                      <form method="POST" action="<%= bp %>/admin/customers/<%= customer.id %>/contacts/<%= ct.id %>/delete"
                            onsubmit="return confirm('Kontakt wirklich löschen?')">
                        <button type="submit" class="btn btn-ghost btn-small"
                          style="color:var(--text-muted);" title="Löschen">
                          <i class="fa-solid fa-trash-can"></i>
                        </button>
                      </form>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Sidebar: Touren & Info -->
        <div>
          <!-- Zugehörige Touren -->
          <div class="section">
            <h2 style="margin:0 0 0.75rem 0;font-size:0.95rem;">
              <i class="fa-solid fa-house" style="color:var(--text-muted);margin-right:0.4rem;"></i>
              Touren (<%= tours.length %>)
            </h2>
            <% if (tours.length === 0) { %>
              <div style="color:var(--text-muted);font-size:0.84rem;">Keine Touren verknüpft.</div>
            <% } else { %>
              <div style="display:flex;flex-direction:column;gap:0.4rem;">
                <% tours.forEach(t => { %>
                  <a href="<%= bp %>/admin/tours/<%= t.id %>"
                     style="display:block;padding:0.5rem 0.65rem;background:var(--bg);border:1px solid var(--border);border-radius:8px;text-decoration:none;color:var(--text);font-size:0.83rem;">
                    <div style="font-weight:600;margin-bottom:0.15rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                      <%= t.bezeichnung || t.object_label || 'Tour #'+t.id %>
                    </div>
                    <div style="color:var(--text-muted);font-size:0.76rem;">
                      <span class="badge badge-<%= t.status %>" style="font-size:0.7rem;">
                        <%= {ACTIVE:'Aktiv',ARCHIVED:'Archiviert',EXPIRING_SOON:'Bald ab',EXPIRED_PENDING_ARCHIVE:'Abgelaufen'}[t.status] || t.status %>
                      </span>
                      <% if (t.term_end_date) { %>
                        · bis <%= new Date(t.term_end_date).toLocaleDateString('de-CH',{day:'2-digit',month:'2-digit',year:'numeric'}) %>
                      <% } %>
                    </div>
                  </a>
                <% }) %>
              </div>
              <% if (tours.length >= 10) { %>
                <a href="<%= bp %>/admin/tours?customer_email=<%= encodeURIComponent(customer.email) %>"
                   class="btn btn-ghost btn-small" style="width:100%;margin-top:0.5rem;text-align:center;">
                  Alle Touren anzeigen →
                </a>
              <% } %>
            <% } %>
          </div>

          <!-- Kunden-Info -->
          <div class="section" style="margin-top:0.75rem;">
            <h2 style="margin:0 0 0.75rem 0;font-size:0.95rem;">Info</h2>
            <div style="font-size:0.82rem;display:flex;flex-direction:column;gap:0.4rem;">
              <div style="display:flex;justify-content:space-between;">
                <span style="color:var(--text-muted);">Kunden-ID</span>
                <span style="font-family:monospace;">#<%= customer.id %></span>
              </div>
              <div style="display:flex;justify-content:space-between;">
                <span style="color:var(--text-muted);">Erstellt</span>
                <span><%= customer.created_at ? new Date(customer.created_at).toLocaleDateString('de-CH') : '–' %></span>
              </div>
              <div style="display:flex;justify-content:space-between;">
                <span style="color:var(--text-muted);">E-Mail verifiziert</span>
                <span><%= customer.email_verified ? '✓ Ja' : '– Nein' %></span>
              </div>
              <div style="display:flex;justify-content:space-between;">
                <span style="color:var(--text-muted);">Status</span>
                <span style="<%= customer.blocked ? 'color:#f87171;' : 'color:#4ade80;' %>">
                  <%= customer.blocked ? '⛔ Gesperrt' : '✓ Aktiv' %>
                </span>
              </div>
              <% if (customer.exxas_contact_id) { %>
                <div style="display:flex;justify-content:space-between;">
                  <span style="color:var(--text-muted);">Exxas ID</span>
                  <span style="font-family:monospace;font-size:0.78rem;"><%= customer.exxas_contact_id %></span>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Gefahrenzone -->
          <div class="section" style="margin-top:0.75rem;border-color:rgba(239,68,68,0.25);">
            <h2 style="margin:0 0 0.75rem 0;font-size:0.95rem;color:#f87171;">Gefahrenzone</h2>
            <form method="POST" action="<%= bp %>/admin/customers/<%= customer.id %>/delete"
                  onsubmit="return confirm('Kunde wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden!')">
              <button type="submit" class="btn btn-small"
                style="background:rgba(239,68,68,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.3);width:100%;">
                <i class="fa-solid fa-trash-can"></i> Kunde löschen
              </button>
            </form>
          </div>
        </div>
      </div>

    </main>
  </div>

  <script>
    function showAddContact() {
      document.getElementById('addContactForm').style.display = 'block';
      document.getElementById('addContactForm').querySelector('input[name="name"]').focus();
    }
    function hideAddContact() {
      document.getElementById('addContactForm').style.display = 'none';
    }
  </script>
</body>
</html>
