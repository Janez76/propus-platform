<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
  <style>
    .team-intro { color: var(--text-muted); margin: 0 0 1rem 0; max-width: 860px; }
    .team-layout { display: grid; grid-template-columns: 1.25fr 0.75fr; gap: 1rem; }
    .team-list { border: 1px solid var(--border); border-radius: 12px; background: var(--surface); overflow: hidden; }
    .team-row { display: grid; grid-template-columns: auto 1fr auto; gap: 0.85rem; align-items: center; padding: 0.85rem 1rem; border-top: 1px solid var(--border); }
    .team-row:first-child { border-top: none; }
    .admin-team-avatar {
      width: 44px; height: 44px; border-radius: 50%; overflow: hidden; flex-shrink: 0;
      background: linear-gradient(145deg, var(--surface-raised), var(--surface)); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center; position: relative;
    }
    .admin-team-avatar-img {
      position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
      border-radius: 50%; display: block; z-index: 1;
    }
    .admin-team-avatar-fallback {
      position: relative; z-index: 0;
      font-size: 0.82rem; font-weight: 700; color: var(--gray-700); letter-spacing: 0.03em; line-height: 1;
      display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;
    }
    .admin-team-avatar.has-photo .admin-team-avatar-fallback { opacity: 0; }
    .team-title { margin: 0 0 0.1rem 0; font-size: 0.93rem; font-weight: 700; color: var(--gray-900); }
    .team-sub { margin: 0; color: var(--text-muted); font-size: 0.8rem; }
    .team-meta { margin-top: 0.35rem; display: flex; gap: 0.35rem; flex-wrap: wrap; }
    .team-tag { display: inline-flex; align-items: center; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-raised); color: var(--text-muted); padding: 0.08rem 0.36rem; font-size: 0.66rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
    .team-tag.active { color: #137347; border-color: rgba(22,179,100,0.28); background: rgba(22,179,100,0.08); }
    .team-tag.inactive { color: #9f5b00; border-color: rgba(245,158,11,0.35); background: rgba(245,158,11,0.12); }
    .team-tag.pending { color: #1e56ca; border-color: rgba(59,130,246,0.32); background: rgba(59,130,246,0.1); }
    .team-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; justify-content: flex-end; }
    .form-grid { display: grid; gap: 0.6rem; }
    .form-grid label { display: grid; gap: 0.3rem; color: var(--text-muted); font-size: 0.82rem; }
    .days-input-wrap {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 42px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      padding: 0.15rem 0.2rem 0.15rem 0.55rem;
    }
    .days-input-wrap input[type="number"] {
      border: none !important;
      box-shadow: none !important;
      background: transparent !important;
      min-height: 34px;
      width: 92px;
      font-weight: 700;
      color: var(--gray-900);
      padding: 0.15rem 0.2rem;
    }
    .days-input-wrap input[type="number"]:focus { outline: none; box-shadow: none; }
    .days-input-suffix {
      margin-left: auto;
      border-left: 1px solid var(--border);
      padding: 0 0.6rem 0 0.55rem;
      color: var(--text-muted);
      font-size: 0.76rem;
      white-space: nowrap;
    }
    .pending-list { display: grid; gap: 0.55rem; }
    .pending-item { border: 1px solid var(--border); border-radius: 10px; padding: 0.6rem 0.7rem; background: var(--surface); display: grid; grid-template-columns: 1fr auto; gap: 0.55rem; align-items: center; }
    .pending-email { font-weight: 700; font-size: 0.86rem; color: var(--gray-900); }
    .pending-meta { color: var(--text-muted); font-size: 0.76rem; margin-top: 0.15rem; }
    .btn-soft-success { background: rgba(22,179,100,0.12); border: 1px solid rgba(22,179,100,0.35); color: #137347; }
    .btn-soft-danger { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.35); color: #c13737; }
    .tm-modal-backdrop { position: fixed; inset: 0; background: rgba(15,15,18,0.5); z-index: 2100; display: none; align-items: center; justify-content: center; padding: 1rem; }
    .tm-modal-backdrop.open { display: flex; }
    .tm-modal { width: min(560px, 100%); background: var(--surface); border: 1px solid var(--border); border-radius: 14px; box-shadow: 0 24px 48px rgba(20,19,17,0.2); overflow: hidden; }
    .tm-modal-head { padding: 0.9rem 1rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; background: var(--gray-50); }
    .tm-modal-title { margin: 0; font-size: 0.95rem; font-weight: 700; }
    .tm-modal-close { border: 1px solid var(--border); background: var(--surface-raised); color: var(--text-muted); width: 30px; height: 30px; border-radius: 8px; cursor: pointer; font-size: 1rem; }
    .tm-modal-body { padding: 1rem; }
    .tm-modal-foot { padding: 0.85rem 1rem 0.95rem; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 0.55rem; background: var(--surface); }
    .tm-form-row { display: grid; gap: 0.35rem; margin-bottom: 0.72rem; font-size: 0.82rem; color: var(--text-muted); }
    .tm-help { margin: 0; color: var(--text-muted); font-size: 0.8rem; }
    .password-row { display: flex; gap: 0.45rem; align-items: center; }
    .password-row input { flex: 1; }
    .password-toggle { border: 1px solid var(--border); background: var(--surface-raised); border-radius: 8px; height: 36px; min-width: 38px; cursor: pointer; color: var(--text-muted); }
    @media (max-width: 980px) { .team-layout { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">
      <h1>Team</h1>
      <p class="team-intro">Admins, Einladungen und Zugriffe zentral verwalten – klar, schnell und ohne unnötigen Ballast.</p>

      <% if (invited) { %><div class="alert alert-success">Einladung wurde versendet.</div><% } %>
      <% if (accepted) { %><div class="alert alert-success">Einladung angenommen. Zugang ist aktiv.</div><% } %>
      <% if (updated) { %><div class="alert alert-success">Zugriff wurde aktualisiert.</div><% } %>
      <% if (edited) { %><div class="alert alert-success">Team-Mitglied wurde aktualisiert.</div><% } %>
      <% if (deleted) { %><div class="alert alert-success">Team-Mitglied wurde entfernt.</div><% } %>
      <% if (revoked) { %><div class="alert alert-success">Einladung wurde widerrufen.</div><% } %>
      <% if (inviteError) { %><div class="alert alert-error">
        <% const map = { invalid_email:'Ungültige E-Mail-Adresse.', invite_failed:'Einladung konnte nicht erstellt werden.', invite_mail_failed:'Einladung gespeichert, aber E-Mail konnte nicht gesendet werden.', user_not_found:'Benutzer nicht gefunden.', invalid_action:'Ungültige Aktion.', invite_not_found:'Einladung nicht gefunden.', invalid_user:'Ungültiger Benutzer.', invalid_password:'Passwort muss mindestens 8 Zeichen haben.', system_managed_user:'System-Accounts können hier nicht bearbeitet oder entfernt werden.', system_managed_email:'Diese E-Mail ist als System-Account reserviert.', email_exists:'Diese E-Mail existiert bereits im Team.', update_failed:'Änderung konnte nicht gespeichert werden.', delete_failed:'Benutzer konnte nicht entfernt werden.' }; %>
        <%= map[inviteError] || 'Aktion fehlgeschlagen.' %>
      </div><% } %>

      <div class="team-layout">
        <section class="section">
          <h2>Team-Mitglieder</h2>
          <div class="team-list">
            <% if (pendingInvites && pendingInvites.length > 0) { %>
              <% pendingInvites.forEach((invite) => { %>
                <div class="team-row">
                  <div class="admin-team-avatar" aria-hidden="true">
                    <span class="admin-team-avatar-fallback"><%= getInitials(invite.email) %></span>
                  </div>
                  <div>
                    <p class="team-title"><%= teamInviteListLabel(invite.email) %></p>
                    <p class="team-sub">
                      <% if (invite.invitedBy) { %>Einladung von <%= String(invite.invitedBy).includes('@') ? 'Team' : invite.invitedBy %> · <% } %>
                      Gültig bis <%= invite.expiresAt ? new Date(invite.expiresAt).toLocaleString('de-CH') : '-' %>
                    </p>
                    <div class="team-meta">
                      <span class="team-tag pending">Ausstehend</span>
                      <span class="team-tag">Einladung</span>
                    </div>
                  </div>
                  <div class="team-actions">
                    <form method="post" action="/admin/team/invites/<%= invite.id %>/revoke" style="margin:0;">
                      <button type="submit" class="btn btn-soft-danger">Widerrufen</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } %>
            <% if (!users || users.length === 0) { %>
              <div class="team-row" style="grid-template-columns: 1fr;"><p class="team-sub">Keine Admin-User vorhanden.</p></div>
            <% } else { %>
              <% users.forEach((user) => { %>
                <div class="team-row">
                  <div class="admin-team-avatar" aria-hidden="true">
                    <img
                      class="admin-team-avatar-img"
                      src="/admin/profile/photo/<%= encodeURIComponent(user.email) %>"
                      alt=""
                      loading="lazy"
                      onload="this.parentElement.classList.add('has-photo')"
                      onerror="this.remove();">
                    <span class="admin-team-avatar-fallback"><%= getInitials(user.name || user.email) %></span>
                  </div>
                  <div>
                    <p class="team-title"><%= teamMemberListTitle(user.name) %></p>
                    <p class="team-sub">
                      <% if (user.invitedBy) { %>Eingeladen von <%= String(user.invitedBy).includes('@') ? 'Team' : user.invitedBy %> · <% } %>
                      Letzter Login: <%= user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleString('de-CH') : '-' %>
                    </p>
                    <div class="team-meta">
                      <span class="team-tag <%= user.isActive ? 'active' : 'inactive' %>"><%= user.isActive ? 'Aktiv' : 'Inaktiv' %></span>
                      <span class="team-tag"><%= user.source === 'env' ? 'System' : 'Team' %></span>
                    </div>
                  </div>
                  <div class="team-actions">
                    <% if (user.source === 'env') { %>
                      <button type="button" class="btn btn-ghost" disabled title="Dieser Account wird über .env verwaltet">System-Account</button>
                    <% } else { %>
                      <form method="post" action="/admin/team/<%= encodeURIComponent(user.email) %>/toggle" style="margin:0;">
                        <input type="hidden" name="action" value="<%= user.isActive ? 'disable' : 'enable' %>">
                        <button type="submit" class="btn <%= user.isActive ? 'btn-soft-danger' : 'btn-soft-success' %>"><%= user.isActive ? 'Sperren' : 'Aktivieren' %></button>
                      </form>
                      <button type="button" class="btn btn-ghost" data-user-id="<%= user.id %>" data-user-email="<%= user.email %>" data-user-name="<%= user.name || '' %>" onclick="openEditMemberModal(this)">Bearbeiten</button>
                      <button type="button" class="btn btn-soft-danger" data-user-id="<%= user.id %>" data-user-email="<%= user.email %>" onclick="openDeleteMemberModal(this)">Entfernen</button>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </section>

        <section class="section">
          <h2>Einladen</h2>
          <form method="post" action="/admin/team/invite" class="form-grid">
            <label>
              E-Mail
              <input type="email" name="email" required placeholder="name@firma.ch">
            </label>
            <label>
              Gültig für (Tage)
              <div class="days-input-wrap">
                <input type="number" name="expiresDays" min="1" max="30" step="1" value="7">
                <span class="days-input-suffix">Tage</span>
              </div>
            </label>
            <div style="display:flex;gap:0.55rem;flex-wrap:wrap;">
              <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Einladung senden</button>
            </div>
          </form>

          <h2 style="margin-top:1.1rem;">Offene Einladungen</h2>
          <% if (!pendingInvites || pendingInvites.length === 0) { %>
            <p class="team-sub">Keine offenen Einladungen.</p>
          <% } else { %>
            <div class="pending-list">
              <% pendingInvites.forEach((invite) => { %>
                <div class="pending-item">
                  <div>
                    <div class="pending-email"><%= teamInviteListLabel(invite.email) %></div>
                    <div class="pending-meta">
                      <% if (invite.invitedBy) { %>Von <%= String(invite.invitedBy).includes('@') ? 'Team' : invite.invitedBy %> · <% } %>
                      Ablauf: <%= invite.expiresAt ? new Date(invite.expiresAt).toLocaleString('de-CH') : '-' %>
                    </div>
                  </div>
                  <form method="post" action="/admin/team/invites/<%= invite.id %>/revoke" style="margin:0;">
                    <button type="submit" class="btn btn-soft-danger">Widerrufen</button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>
      </div>
    </main>
  </div>

  <div class="tm-modal-backdrop" id="editMemberBackdrop" onclick="closeEditMemberModal(event)">
    <div class="tm-modal" onclick="event.stopPropagation()">
      <div class="tm-modal-head">
        <h3 class="tm-modal-title">Team-Mitglied bearbeiten</h3>
        <button class="tm-modal-close" type="button" onclick="closeEditMemberModal()">&times;</button>
      </div>
      <form method="post" id="editMemberForm">
        <div class="tm-modal-body">
          <div class="tm-form-row">
            <label for="editMemberName">Name</label>
            <input type="text" id="editMemberName" name="name" placeholder="Vor- und Nachname">
          </div>
          <div class="tm-form-row">
            <label for="editMemberEmail">E-Mail</label>
            <input type="email" id="editMemberEmail" name="email" required>
          </div>
          <div class="tm-form-row">
            <label for="editMemberPassword">Neues Passwort</label>
            <div class="password-row">
              <input type="password" id="editMemberPassword" name="password" value="********" minlength="8">
              <button type="button" class="password-toggle" onclick="toggleEditPassword(this)">
                <i class="fa-regular fa-eye"></i>
              </button>
            </div>
            <p class="tm-help">Leer bzw. `********` lassen, wenn das Passwort unverändert bleiben soll.</p>
          </div>
        </div>
        <div class="tm-modal-foot">
          <button class="btn btn-ghost" type="button" onclick="closeEditMemberModal()">Abbrechen</button>
          <button class="btn btn-primary" type="submit">Speichern</button>
        </div>
      </form>
    </div>
  </div>

  <div class="tm-modal-backdrop" id="deleteMemberBackdrop" onclick="closeDeleteMemberModal(event)">
    <div class="tm-modal" onclick="event.stopPropagation()">
      <div class="tm-modal-head">
        <h3 class="tm-modal-title">Team-Mitglied entfernen</h3>
        <button class="tm-modal-close" type="button" onclick="closeDeleteMemberModal()">&times;</button>
      </div>
      <form method="post" id="deleteMemberForm">
        <div class="tm-modal-body">
          <p class="tm-help" id="deleteMemberText">Möchtest du dieses Team-Mitglied wirklich entfernen?</p>
        </div>
        <div class="tm-modal-foot">
          <button class="btn btn-ghost" type="button" onclick="closeDeleteMemberModal()">Abbrechen</button>
          <button class="btn btn-soft-danger" type="submit">Ja, entfernen</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (() => {
      const editBackdrop = document.getElementById('editMemberBackdrop');
      const deleteBackdrop = document.getElementById('deleteMemberBackdrop');
      const editForm = document.getElementById('editMemberForm');
      const deleteForm = document.getElementById('deleteMemberForm');
      const editName = document.getElementById('editMemberName');
      const editEmail = document.getElementById('editMemberEmail');
      const editPassword = document.getElementById('editMemberPassword');
      const deleteText = document.getElementById('deleteMemberText');

      window.openEditMemberModal = (btn) => {
        const id = btn?.dataset?.userId || '';
        const email = btn?.dataset?.userEmail || '';
        const name = btn?.dataset?.userName || '';
        if (!id || !email) return;
        editForm.action = `/admin/team/users/${encodeURIComponent(id)}/update`;
        editName.value = name;
        editEmail.value = email;
        editPassword.type = 'password';
        editPassword.value = '********';
        editBackdrop.classList.add('open');
      };

      window.closeEditMemberModal = (event) => {
        if (event && event.target && event.target.id !== 'editMemberBackdrop') return;
        editBackdrop.classList.remove('open');
      };

      window.openDeleteMemberModal = (btn) => {
        const id = btn?.dataset?.userId || '';
        const email = btn?.dataset?.userEmail || '';
        if (!id || !email) return;
        deleteForm.action = `/admin/team/users/${encodeURIComponent(id)}/delete`;
        deleteText.textContent = `Möchtest du ${email} wirklich entfernen?`;
        deleteBackdrop.classList.add('open');
      };

      window.closeDeleteMemberModal = (event) => {
        if (event && event.target && event.target.id !== 'deleteMemberBackdrop') return;
        deleteBackdrop.classList.remove('open');
      };

      window.toggleEditPassword = (btn) => {
        const icon = btn?.querySelector('i');
        const show = editPassword.type === 'password';
        editPassword.type = show ? 'text' : 'password';
        if (icon) icon.className = show ? 'fa-regular fa-eye-slash' : 'fa-regular fa-eye';
      };
    })();
  </script>
</body>
</html>
