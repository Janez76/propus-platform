<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Neuer Kunde – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">

      <div style="font-size:0.82rem;color:var(--text-muted);margin-bottom:1rem;">
        <a href="/admin/customers" style="color:var(--link);text-decoration:none;">Kunden</a>
        <span style="margin:0 0.4rem;">›</span>
        <span>Neuer Kunde</span>
      </div>

      <div style="max-width:660px;">
        <h1 style="margin:0 0 0.25rem 0;">Neuer Kunde</h1>
        <p style="color:var(--text-muted);font-size:0.88rem;margin:0 0 1.25rem 0;">
          Wird in der zentralen Kundendatenbank (core.customers) gespeichert und steht sofort in beiden Modulen zur Verfügung.
        </p>

        <% if (error) { %>
          <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:0.65rem 1rem;margin-bottom:1rem;font-size:0.88rem;color:#f87171;">
            <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
          </div>
        <% } %>

        <!-- Exxas-Suche -->
        <div class="section" style="margin-bottom:1rem;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.6rem;">
            <h2 style="margin:0;font-size:0.95rem;">Aus Exxas importieren</h2>
            <span style="font-size:0.76rem;color:var(--text-muted);">(optional)</span>
          </div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin:0 0 0.6rem 0;">
            Suche zuerst in Exxas – falls der Kunde dort existiert, werden die Daten automatisch übernommen.
          </p>
          <div style="display:flex;gap:0.5rem;">
            <input type="text" id="exxasSearch" placeholder="Name oder E-Mail in Exxas suchen…"
              style="flex:1;padding:0.5rem 0.75rem;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:0.88rem;">
            <button type="button" class="btn btn-ghost" onclick="searchExxas()" id="exxasSearchBtn">
              <i class="fa-solid fa-magnifying-glass"></i> Suchen
            </button>
          </div>
          <div id="exxasResults" style="margin-top:0.5rem;display:none;"></div>
        </div>

        <!-- Manuelles Formular -->
        <div class="section">
          <h2 style="margin:0 0 1rem 0;font-size:0.95rem;">Manuell erfassen</h2>
          <form method="POST" action="/admin/customers/new" id="customerForm">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.85rem;">

              <div class="form-group">
                <label class="form-label">Name *</label>
                <input type="text" name="name" id="f_name" value="<%= prefill?.name || '' %>"
                  class="form-input" required placeholder="Vor- und Nachname">
              </div>

              <div class="form-group">
                <label class="form-label">E-Mail *</label>
                <input type="email" name="email" id="f_email" value="<%= prefill?.email || '' %>"
                  class="form-input" required>
              </div>

              <div class="form-group">
                <label class="form-label">Firma</label>
                <input type="text" name="company" id="f_company" value="<%= prefill?.company || '' %>"
                  class="form-input" placeholder="Firmenname (optional)">
              </div>

              <div class="form-group">
                <label class="form-label">Telefon</label>
                <input type="text" name="phone" id="f_phone" value="<%= prefill?.phone || '' %>"
                  class="form-input" placeholder="+41 44 …">
              </div>

              <div class="form-group">
                <label class="form-label">Strasse</label>
                <input type="text" name="street" id="f_street" value="<%= prefill?.street || '' %>"
                  class="form-input" placeholder="Musterstrasse 1">
              </div>

              <div class="form-group">
                <label class="form-label">PLZ / Ort</label>
                <input type="text" name="zipcity" id="f_zipcity" value="<%= prefill?.zipcity || '' %>"
                  class="form-input" placeholder="8001 Zürich">
              </div>

              <div class="form-group" style="grid-column:1/-1;">
                <label class="form-label">Notizen</label>
                <textarea name="notes" rows="2" class="form-input"
                  placeholder="Interne Notizen (optional)"></textarea>
              </div>

              <input type="hidden" name="exxas_contact_id" id="f_exxas_id" value="<%= prefill?.exxas_contact_id || '' %>">
            </div>

            <div style="display:flex;gap:0.6rem;margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border);">
              <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-user-plus"></i> Kunden anlegen
              </button>
              <a href="/admin/customers" class="btn btn-ghost">Abbrechen</a>
            </div>
          </form>
        </div>
      </div>

    </main>
  </div>

  <script>
    async function searchExxas() {
      const q = document.getElementById('exxasSearch').value.trim();
      const resultsDiv = document.getElementById('exxasResults');
      const btn = document.getElementById('exxasSearchBtn');
      if (q.length < 2) return;

      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      resultsDiv.style.display = 'none';

      try {
        const resp = await fetch('/admin/customers/exxas-search?q=' + encodeURIComponent(q));
        const data = await resp.json();

        if (!data.results || data.results.length === 0) {
          resultsDiv.innerHTML = '<div style="font-size:0.84rem;color:var(--text-muted);padding:0.4rem 0;">Keine Treffer in Exxas.</div>';
        } else {
          resultsDiv.innerHTML = data.results.map(r => `
            <div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.75rem;
                        background:var(--bg);border:1px solid var(--border);border-radius:8px;margin-bottom:0.4rem;">
              <div>
                <div style="font-weight:600;font-size:0.88rem;">${esc(r.name || '')}</div>
                <div style="font-size:0.78rem;color:var(--text-muted);">
                  ${r.email ? esc(r.email) : ''}
                  ${r.company ? ' · ' + esc(r.company) : ''}
                  ${r.phone ? ' · ' + esc(r.phone) : ''}
                </div>
              </div>
              <button type="button" class="btn btn-primary btn-small"
                onclick="fillFromExxas(${JSON.stringify(r).replace(/"/g,'&quot;')})">
                Übernehmen
              </button>
            </div>`).join('');
        }
        resultsDiv.style.display = 'block';
      } catch (e) {
        resultsDiv.innerHTML = '<div style="font-size:0.84rem;color:#f87171;">Fehler bei Exxas-Suche: ' + e.message + '</div>';
        resultsDiv.style.display = 'block';
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i> Suchen';
    }

    function fillFromExxas(r) {
      if (r.name) document.getElementById('f_name').value = r.name;
      if (r.email) document.getElementById('f_email').value = r.email;
      if (r.company) document.getElementById('f_company').value = r.company;
      if (r.phone) document.getElementById('f_phone').value = r.phone;
      if (r.street) document.getElementById('f_street').value = r.street;
      if (r.zipcity) document.getElementById('f_zipcity').value = r.zipcity;
      if (r.exxas_contact_id || r.id) document.getElementById('f_exxas_id').value = r.exxas_contact_id || r.id;
      document.getElementById('exxasResults').style.display = 'none';
      document.getElementById('f_name').scrollIntoView({ behavior: 'smooth' });
    }

    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    document.getElementById('exxasSearch').addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); searchExxas(); }
    });
  </script>
</body>
</html>
