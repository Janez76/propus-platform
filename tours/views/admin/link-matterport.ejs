<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matterport verknüpfen – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
  <style>
    .page-intro { margin-bottom: 0.85rem; color: var(--text-muted); }
    .count-pill { display: inline-flex; align-items: center; gap: 0.4rem; border: 1px solid var(--border); border-radius: 8px; padding: 0.35rem 0.7rem; font-size: 0.85rem; background: #fff; }
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 0.95rem;
    }
    .toolbar-right {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      margin-left: auto;
    }
    .tours-search-form {
      position: relative;
      width: min(320px, 100%);
      margin: 0;
    }
    .tours-search-icon {
      position: absolute;
      left: 0.72rem;
      top: 50%;
      transform: translateY(-50%);
      color: #b6b0a6;
      font-size: 0.8rem;
      pointer-events: none;
      z-index: 2;
    }
    .tours-search-form input.tours-search-input {
      width: 100%;
      height: 2rem;
      border-radius: 0.5rem;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--gray-700);
      font-family: inherit;
      font-size: 0.84rem;
      line-height: 1.2;
      padding: 0.36rem 0.75rem 0.36rem 2rem;
    }
    .tours-search-form input.tours-search-input::placeholder { color: #9d9890; }
    .tours-search-form input.tours-search-input:focus {
      outline: none;
      border-color: var(--gold-400);
      box-shadow: 0 0 0 3px rgba(220, 170, 78, 0.16);
    }
    th.sortable a {
      color: inherit;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
    }
    th.sortable.sort-active { color: var(--gray-900); }
    .sort-icon {
      font-size: 0.74rem;
      color: var(--text-muted);
      display: inline-flex;
      justify-content: center;
      align-items: center;
      width: 0.95rem;
      flex: 0 0 0.95rem;
    }
    .table-wrap { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; background: #fff; }
    .table-wrap table { width: 100%; table-layout: fixed; }
    .table-wrap th:nth-child(1),
    .table-wrap td:nth-child(1) { width: 42%; }
    .table-wrap th:nth-child(2),
    .table-wrap td:nth-child(2) { width: 18%; }
    .table-wrap th:nth-child(3),
    .table-wrap td:nth-child(3) { width: 20%; }
    .table-wrap th:nth-child(4),
    .table-wrap td:nth-child(4) { width: 20%; }
    .space-name { font-weight: 600; color: var(--text); }
    .space-meta { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.12rem; }
    .space-link { font-size: 0.82rem; }
    .space-link code { font-size: 0.8rem; }
    .space-created { color: var(--text-muted); font-size: 0.84rem; }
    .space-action { text-align: left; white-space: nowrap; }
    .tours-pagination {
      margin-top: 0.95rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
      padding: 0.7rem 0.15rem 0.2rem;
      border-top: 1px solid var(--border);
    }
    .tours-pagination-info {
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .tours-pagination-links {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      flex-wrap: wrap;
    }
    .tours-page-link {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--gray-700);
      border-radius: 8px;
      padding: 0.22rem 0.58rem;
      font-size: 0.8rem;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
    }
    .tours-page-link:hover { border-color: var(--gold-400); color: var(--gray-900); }
    .tours-page-link.active { background: var(--gold-100); border-color: var(--gold-300); color: var(--gold-800); }
    .tours-page-link.disabled { pointer-events: none; opacity: 0.45; }
    .suggestions { border: 1px solid var(--border); border-radius: 8px; background: var(--bg); max-height: 170px; overflow-y: auto; display: none; }
    .suggestion-btn { width: 100%; text-align: left; border: none; border-bottom: 1px solid var(--border); background: #fff; color: var(--text); padding: 0.55rem 0.65rem; cursor: pointer; font-size: 0.84rem; }
    .suggestion-btn:last-child { border-bottom: none; }
    .suggestion-btn:hover { background: #f9f6ef; }
    .suggestion-section-title {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--text-muted);
      padding: 0.4rem 0.65rem 0.15rem;
      background: var(--bg-hover);
      border-bottom: 1px solid var(--border);
    }
    .suggestion-kind {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.12rem 0.38rem;
      border-radius: 4px;
      margin-right: 0.35rem;
      vertical-align: middle;
    }
    .suggestion-kind.firma { background: rgba(34, 197, 94, 0.2); color: #15803d; }
    .suggestion-kind.kontakt { background: rgba(59, 130, 246, 0.18); color: #1d4ed8; }
    .suggestion-title { font-weight: 600; color: var(--gray-900); line-height: 1.25; display: inline; }
    .suggestion-sub { font-size: 0.77rem; color: var(--text-muted); margin-top: 0.12rem; }
    .selected-customer { color: var(--text-muted); font-size: 0.82rem; margin-top: -0.2rem; }
    .matterport-api-alert .matterport-api-alert-body {
      margin-top: 0.45rem;
      font-size: 0.9rem;
      line-height: 1.45;
      font-weight: 500;
    }
    .empty-state { border: 1px solid var(--gold-300); background: var(--gold-50); border-radius: 12px; padding: 1rem; }
    .customer-row { display: grid; grid-template-columns: 1fr auto; gap: 0.5rem; align-items: end; }
    .customer-search-group { position: relative; }
    .customer-search-group .suggestions {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 0.3rem);
      z-index: 30;
      box-shadow: 0 12px 26px rgba(20, 19, 17, 0.12);
      max-height: 220px;
      background: #fff;
    }
    .contact-suggestions {
      display: none;
      margin-top: 0.25rem;
    }
    .contact-chip {
      width: 100%;
      text-align: left;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--gray-800);
      border-radius: 8px;
      padding: 0.48rem 0.62rem;
      font-size: 0.78rem;
      cursor: pointer;
      line-height: 1.2;
      display: grid;
      gap: 0.14rem;
      margin-bottom: 0.32rem;
    }
    .contact-chip:last-child { margin-bottom: 0; }
    .contact-chip:hover {
      border-color: var(--gold-400);
      background: #f9f6ef;
      transform: translateY(-1px);
    }
    .contact-chip-title {
      font-size: 0.86rem;
      font-weight: 600;
      color: var(--gray-900);
      line-height: 1.2;
    }
    .contact-chip-sub {
      font-size: 0.78rem;
      color: var(--text-muted);
      line-height: 1.2;
    }
    .contact-chip-tag {
      justify-self: start;
      border: 1px solid var(--gold-300);
      border-radius: 8px;
      background: var(--gold-100);
      color: var(--gold-800);
      padding: 0.08rem 0.35rem;
      font-size: 0.66rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .tm-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(15, 15, 18, 0.5);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .tm-modal-backdrop.open { display: flex; }
    .tm-modal {
      width: min(760px, 100%);
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 24px 45px rgba(20, 19, 17, 0.2);
      overflow: hidden;
    }
    .tm-modal-head {
      padding: 0.9rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.6rem;
      background: var(--gray-50);
    }
    .tm-modal-title { font-size: 0.95rem; font-weight: 700; margin: 0; color: var(--gray-900); }
    .tm-modal-close {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text-muted);
      border-radius: 8px;
      width: 30px;
      height: 30px;
      cursor: pointer;
      line-height: 1;
      font-size: 1rem;
    }
    .tm-modal-body { padding: 1rem 1.05rem; }
    .tm-modal-foot {
      padding: 0.85rem 1rem 0.95rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: 0.45rem;
      background: #fff;
    }
    .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
    .modal-grid .full { grid-column: 1 / -1; }
    .modal-meta {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 0.8rem;
      padding: 0.55rem 0.7rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: #fcfcfb;
      line-height: 1.35;
    }
    .modal-section {
      padding-top: 0.85rem;
      border-top: 1px solid var(--border);
      margin-top: 0.85rem;
    }
    .modal-section:first-of-type {
      padding-top: 0;
      border-top: none;
      margin-top: 0;
    }
    .modal-section-title {
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
      font-weight: 700;
      margin: 0 0 0.55rem;
    }
    #linkModalForm label {
      font-size: 0.82rem;
      color: var(--gray-700);
      display: flex;
      flex-direction: column;
      gap: 0.28rem;
    }
    #linkModalForm input[type="text"],
    #linkModalForm input[type="email"],
    #linkModalForm input[type="url"],
    #linkModalForm select {
      width: 100%;
      min-height: 2.15rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--gray-800);
      font: inherit;
      padding: 0.38rem 0.62rem;
    }
    #linkModalForm input:focus,
    #linkModalForm select:focus {
      outline: none;
      border-color: var(--gold-400);
      box-shadow: 0 0 0 3px rgba(220, 170, 78, 0.16);
    }
    .selected-customer {
      color: var(--text-muted);
      font-size: 0.82rem;
      margin-top: 0;
      border: 1px dashed var(--border);
      border-radius: 8px;
      padding: 0.5rem 0.62rem;
      background: #fcfcfb;
    }
    .suggestions { margin-top: 0.1rem; }
    .contact-name-wrap {
      position: relative;
    }
    .contact-name-wrap input { padding-right: 2.35rem !important; }
    .contact-picker-toggle {
      position: absolute;
      right: 0.38rem;
      top: 50%;
      transform: translateY(-50%);
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text-muted);
      border-radius: 8px;
      width: 1.7rem;
      height: 1.7rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
    .contact-picker-toggle:hover {
      border-color: var(--gold-400);
      color: var(--gray-900);
      background: #f9f6ef;
    }
    .contact-picker-modal { width: min(560px, 100%); }
    .contact-picker-list {
      border: 1px solid var(--border);
      border-radius: 8px;
      max-height: 260px;
      overflow-y: auto;
      background: #fcfcfb;
      padding: 0.36rem;
    }
    .contact-picker-empty {
      color: var(--text-muted);
      font-size: 0.83rem;
      border: 1px dashed var(--border);
      border-radius: 8px;
      padding: 0.7rem;
      background: #fcfcfb;
    }
    @media (max-width: 820px) {
      .modal-grid { grid-template-columns: 1fr; }
    }
    .modal-cannot-assign {
      padding-top: 0;
      border-top: none;
      margin-top: 0;
      margin-bottom: 0.75rem;
    }
    #linkModalForm .modal-cannot-assign > label,
    #linkModalForm .modal-archive-row label {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
    #linkModalForm .modal-cannot-assign > label {
      font-weight: 600;
    }
    #linkModalForm .modal-archive-row label {
      color: var(--text-muted);
    }
    .modal-archive-row {
      display: none;
      margin-top: 0.45rem;
      padding-left: 1.4rem;
    }
  </style>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">
      <a href="/admin/tours" class="back">← Zurück zu Touren</a>
      <h1>Matterport verknüpfen</h1>
      <p class="page-intro">Hier verknüpfst du aktive Matterport-Spaces manuell mit Tour-Link, Organisation und Kontakt. Bereits verknüpfte Spaces verschwinden automatisch aus dieser Liste.</p>

      <% if (linked) { %><div class="alert alert-success">Tour erfolgreich verknüpft und im Admin-Panel übernommen.</div><% } %>
      <% if (error === 'missing') { %><div class="alert alert-error">Bitte Matterport-Space und Tour-Link ausfüllen.</div><% } %>
      <% if (error === 'duplicate') { %><div class="alert alert-error">Diese Matterport-ID ist bereits verknüpft.<% if (duplicateTourId) { %> <a href="/admin/tours/<%= duplicateTourId %>" style="color:var(--danger);">Tour #<%= duplicateTourId %> öffnen</a><% } %></div><% } %>
      <% if (error === 'insert') { %><div class="alert alert-error">Verknüpfung konnte nicht gespeichert werden.</div><% } %>
      <% if (mpError) { %>
        <div class="alert alert-warning matterport-api-alert">
          <strong>Matterport API</strong>
          <div class="matterport-api-alert-body"><%= mpError %></div>
        </div>
      <% } %>

      <div class="toolbar">
        <div class="count-pill">
          <strong><%= matterportOpenCount %></strong>
          <span>aktive Spaces noch nicht verknüpft</span>
        </div>
        <div class="toolbar-right">
          <form method="get" action="/admin/link-matterport" class="tours-search-form">
            <i class="fa-solid fa-magnifying-glass tours-search-icon"></i>
            <input type="hidden" name="sort" value="<%= sort %>">
            <input type="hidden" name="order" value="<%= order %>">
            <input type="text" class="tours-search-input" name="q" value="<%= (filters && filters.q) || '' %>" placeholder="Suche...">
          </form>
        </div>
      </div>

      <% if (!mpError && openSpaces.length === 0) { %>
        <div class="empty-state">
          <strong>Alles erledigt.</strong>
          <p style="margin:0.4rem 0 0 0;">Alle aktiven Matterport-Spaces sind verknüpft. Du findest sie jetzt auf der Startseite im Admin-Panel.</p>
          <p style="margin:0.7rem 0 0 0;"><a href="/admin/tours" class="btn btn-primary">Zu den Touren</a></p>
        </div>
      <% } %>

      <% if (!mpError && openSpaces.length > 0) { %>
      <% const sortUrl = (field) => {
           const nextOrder = (sort === field && order === 'asc') ? 'desc' : 'asc';
           const params = new URLSearchParams();
           if (filters && filters.q) params.set('q', filters.q);
           params.set('sort', field);
           params.set('order', nextOrder);
           return '/admin/link-matterport?' + params.toString();
         };
         const pageUrl = (targetPage) => {
           const params = new URLSearchParams();
           if (filters && filters.q) params.set('q', filters.q);
           if (sort) params.set('sort', sort);
           if (order) params.set('order', order);
           params.set('page', targetPage);
           return '/admin/link-matterport?' + params.toString();
         };
      %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="sortable <%= sort === 'space' ? 'sort-active' : '' %>"><a href="<%= sortUrl('space') %>">Space <span class="sort-icon"><%= sort === 'space' ? (order === 'desc' ? '▼' : '▲') : '◆' %></span></a></th>
              <th class="sortable <%= sort === 'created' ? 'sort-active' : '' %>"><a href="<%= sortUrl('created') %>">Erstellt <span class="sort-icon"><%= sort === 'created' ? (order === 'desc' ? '▼' : '▲') : '◆' %></span></a></th>
              <th>Link</th>
              <th style="text-align:left;">Aktion</th>
            </tr>
          </thead>
          <tbody>
            <% openSpaces.forEach((space) => {
              const createdLabel = space.created ? new Date(space.created).toLocaleDateString('de-CH', { day: '2-digit', month: 'short', year: 'numeric' }) : '-';
              const defaultUrl = `https://my.matterport.com/show/?m=${space.id}`;
            %>
            <tr class="mp-row">
              <td>
                <div class="space-name"><%= space.name || 'Ohne Namen' %></div>
                <div class="space-meta">ID: <code><%= space.id %></code></div>
              </td>
              <td class="space-created"><%= createdLabel %></td>
              <td class="space-link"><a href="<%= defaultUrl %>" target="_blank" rel="noopener">Space öffnen</a></td>
              <td class="space-action">
                <button
                  type="button"
                  class="btn btn-primary"
                  data-space-id="<%= space.id %>"
                  data-space-name="<%= space.name || '' %>"
                  data-space-created="<%= createdLabel %>"
                  data-space-url="<%= defaultUrl %>"
                  onclick="openLinkModal(this)"
                >Verknüpfen</button>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% if (pagination) { %>
      <%
        const startItem = pagination.totalItems ? ((pagination.page - 1) * pagination.pageSize) + 1 : 0;
        const endItem = Math.min(pagination.page * pagination.pageSize, pagination.totalItems);
        const maxVisiblePages = 5;
        const startPage = Math.max(1, pagination.page - Math.floor(maxVisiblePages / 2));
        const endPage = Math.min(pagination.totalPages, startPage + maxVisiblePages - 1);
      %>
      <div class="tours-pagination">
        <div class="tours-pagination-info">
          Seite <strong><%= pagination.page %></strong> von <strong><%= pagination.totalPages %></strong> · Zeige <strong><%= startItem %>–<%= endItem %></strong> von <strong><%= pagination.totalItems %></strong> Spaces
        </div>
        <div class="tours-pagination-links">
          <a href="<%= pageUrl(pagination.page - 1) %>" class="tours-page-link <%= pagination.hasPrev ? '' : 'disabled' %>">Zurück</a>
          <% for (let p = startPage; p <= endPage; p++) { %>
            <a href="<%= pageUrl(p) %>" class="tours-page-link <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
          <% } %>
          <a href="<%= pageUrl(pagination.page + 1) %>" class="tours-page-link <%= pagination.hasNext ? '' : 'disabled' %>">Weiter</a>
        </div>
      </div>
      <% } %>
      <% } %>
    </main>
  </div>

  <div class="tm-modal-backdrop" id="linkModalBackdrop" onclick="closeLinkModal(event)">
    <div class="tm-modal" onclick="event.stopPropagation()">
      <div class="tm-modal-head">
        <h3 class="tm-modal-title">Matterport verknüpfen</h3>
        <button class="tm-modal-close" type="button" onclick="closeLinkModal()">&times;</button>
      </div>
      <div class="tm-modal-body">
        <div class="modal-meta" id="linkModalMeta">Space wird geladen…</div>
        <form method="post" action="/admin/link-matterport" id="linkModalForm">
          <input type="hidden" name="matterportSpaceId" id="modalMatterportSpaceId">
          <input type="hidden" name="coreCustomerId" id="modalCoreCustomerId" value="">
          <div class="modal-section modal-cannot-assign">
            <label>
              <input type="checkbox" name="cannotAssign" id="modalCannotAssign" value="1">
              Kann nicht zugewiesen werden
            </label>
            <div class="modal-archive-row" id="modalArchiveRow">
              <label>
                <input type="checkbox" name="archiveIt" id="modalArchiveIt" value="1" checked>
                Archivieren
              </label>
            </div>
          </div>
          <div class="modal-section" id="modalSectionBasis">
            <p class="modal-section-title">Basisdaten</p>
            <div class="modal-grid">
              <label class="full">
                Tour-Link *
                <input type="url" name="tourUrl" id="modalTourUrl" required placeholder="https://my.matterport.com/show/?m=...">
              </label>
              <label class="full">
                Bezeichnung / Objekt
                <input type="text" name="bezeichnung" id="modalBezeichnung" placeholder="z. B. Musterstrasse 12, Zürich">
              </label>
            </div>
          </div>

          <div class="modal-section" id="modalSectionFirmaKontakt">
            <p class="modal-section-title">Firma & Kontakt</p>
            <div class="modal-grid">
              <div class="full customer-search-group">
                <div class="customer-row">
                  <label style="margin:0;">
                    Suche (Firma oder Ansprechpartner)
                    <input type="text" id="modalCustomerSearch" autocomplete="off" placeholder="Firmenname, Kontaktname, E-Mail, Telefon …">
                  </label>
                  <button type="button" class="btn btn-ghost" id="modalClearCustomer">Zurücksetzen</button>
                </div>
                <p class="selected-customer" style="margin:0.35rem 0 0.25rem 0;">Vorschläge aus Ihrer <strong>Kundendatenbank</strong>: passende <strong>Firmen</strong> und passende <strong>Kontakte</strong> (Ansprechpartner). Auswahl übernimmt Daten fürs Verknüpfen; Kontakte können Sie danach noch per Adressbuch-Symbol anpassen.</p>
                <div class="suggestions" id="modalSuggestions"></div>
              </div>
              <div class="full selected-customer" id="modalSelectedCustomer">Keine Firma / kein Kontakt ausgewählt.</div>
            </div>
          </div>

          <div class="modal-section" id="modalSectionKundendaten">
            <p class="modal-section-title">Kundendaten</p>
            <div class="modal-grid">
              <label>
                Kundenname (Firma)
                <input type="text" name="customerName" id="modalCustomerName" placeholder="Aus Vorschlag oder manuell">
              </label>
              <label>
                Kunden-E-Mail
                <input type="email" name="customerEmail" id="modalCustomerEmail" placeholder="kontakt@kunde.ch">
              </label>
              <label class="full">
                Kontaktname
                <div class="contact-name-wrap">
                  <input type="text" name="customerContact" id="modalCustomerContact" placeholder="Ansprechperson">
                  <button type="button" class="contact-picker-toggle" id="modalContactPickerToggle" title="Kontakte anzeigen">
                    <i class="fa-solid fa-address-book"></i>
                  </button>
                </div>
              </label>
            </div>
          </div>
        </form>
      </div>
      <div class="tm-modal-foot">
        <button class="btn btn-ghost" type="button" onclick="closeLinkModal()">Abbrechen</button>
        <button class="btn btn-primary" type="submit" form="linkModalForm">Verknüpfen</button>
      </div>
    </div>
  </div>

  <div class="tm-modal-backdrop" id="contactPickerBackdrop" onclick="closeContactPicker(event)">
    <div class="tm-modal contact-picker-modal" onclick="event.stopPropagation()">
      <div class="tm-modal-head">
        <h3 class="tm-modal-title">Kontakt wählen</h3>
        <button class="tm-modal-close" type="button" onclick="closeContactPicker()">&times;</button>
      </div>
      <div class="tm-modal-body">
        <div class="contact-picker-list" id="modalContactSuggestions"></div>
      </div>
      <div class="tm-modal-foot">
        <button class="btn btn-ghost" type="button" onclick="closeContactPicker()">Schließen</button>
      </div>
    </div>
  </div>

  <% const _tmAdminMount = typeof basePath === 'string' ? basePath : ''; %>
  <script>
    (() => {
      /** Gleicher Präfix wie bei Links/Forms (Mount z. B. /tour-manager) – fetch() wird vom Header-Skript nicht umgeschrieben. */
      const TM_ADMIN_PREFIX = <%- JSON.stringify(_tmAdminMount) %>;
      const modalBackdrop = document.getElementById('linkModalBackdrop');
      const modalMeta = document.getElementById('linkModalMeta');
      const modalSpaceId = document.getElementById('modalMatterportSpaceId');
      const modalTourUrl = document.getElementById('modalTourUrl');
      const modalBezeichnung = document.getElementById('modalBezeichnung');
      const modalCoreCustomerId = document.getElementById('modalCoreCustomerId');
      const modalCustomerSearch = document.getElementById('modalCustomerSearch');
      const modalSuggestions = document.getElementById('modalSuggestions');
      const modalSelectedCustomer = document.getElementById('modalSelectedCustomer');
      const modalContactSuggestions = document.getElementById('modalContactSuggestions');
      const contactPickerBackdrop = document.getElementById('contactPickerBackdrop');
      const modalContactPickerToggle = document.getElementById('modalContactPickerToggle');
      const modalCustomerName = document.getElementById('modalCustomerName');
      const modalCustomerEmail = document.getElementById('modalCustomerEmail');
      const modalCustomerContact = document.getElementById('modalCustomerContact');
      const modalClearCustomer = document.getElementById('modalClearCustomer');
      const modalCannotAssign = document.getElementById('modalCannotAssign');
      const modalArchiveRow = document.getElementById('modalArchiveRow');
      const modalArchiveIt = document.getElementById('modalArchiveIt');
      const modalSectionFirmaKontakt = document.getElementById('modalSectionFirmaKontakt');
      const modalSectionKundendaten = document.getElementById('modalSectionKundendaten');
      let suggestionsState = { companies: [], contacts: [] };
      let searchTimer = null;
      let selectedCustomerLabel = '';
      let activeCustomer = null;

      function escHtml(s) {
        return String(s || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/"/g, '&quot;');
      }

      function renderSuggestions(container, { companies, contacts }) {
        const co = Array.isArray(companies) ? companies : [];
        const ct = Array.isArray(contacts) ? contacts : [];
        if (!co.length && !ct.length) {
          container.style.display = 'none';
          container.innerHTML = '';
          return;
        }
        let html = '';
        if (co.length) {
          html += '<div class="suggestion-section-title">Firmen</div>';
          co.forEach((customer, idx) => {
            const title = escHtml(customer.firmenname || customer.id || '');
            const refLine = customer.nummer
              ? `<div class="suggestion-sub">Ref. ${escHtml(String(customer.nummer))}</div>`
              : '';
            const sub = customer.email ? `<div class="suggestion-sub">${escHtml(customer.email)}</div>` : '';
            html += `<button type="button" class="suggestion-btn" data-pick="company" data-idx="${idx}">
              <div><span class="suggestion-kind firma">Firma</span><span class="suggestion-title">${title}</span></div>
              ${refLine}${sub}
            </button>`;
          });
        }
        if (ct.length) {
          html += '<div class="suggestion-section-title">Kontakte</div>';
          ct.forEach((hit, idx) => {
            const cname = escHtml(hit.contactName || 'Kontakt');
            const firma = escHtml(hit.firmenname || '');
            const mail = hit.contactEmail || hit.customerEmail;
            const sub = [firma, mail ? escHtml(mail) : ''].filter(Boolean).join(' · ');
            html += `<button type="button" class="suggestion-btn" data-pick="contact" data-idx="${idx}">
              <div><span class="suggestion-kind kontakt">Kontakt</span><span class="suggestion-title">${cname}</span></div>
              <div class="suggestion-sub">${sub || '—'}</div>
            </button>`;
          });
        }
        container.innerHTML = html;
        container.style.display = 'block';
      }

      function clearContactSelectionUI() {
        modalContactSuggestions.innerHTML = '';
        modalContactSuggestions.dataset.chips = '[]';
      }

      function renderContactSuggestions(customer) {
        const contacts = customer?.contacts || [];
        const chips = [];
        if (customer?.email) {
          chips.push({
            kind: 'organisation',
            title: customer.firmenname || 'Organisation',
            subtitle: customer.email,
            name: customer.firmenname || '',
            email: customer.email,
          });
        }
        contacts.forEach((ct) => {
          if (!ct?.name && !ct?.email) return;
          chips.push({
            kind: 'kontakt',
            title: ct.name || 'Kontakt',
            subtitle: ct.email || '',
            name: ct.name || '',
            email: ct.email || '',
          });
        });

        if (!chips.length) {
          modalContactSuggestions.innerHTML = '<div class="contact-picker-empty">Keine Kontaktvorschläge vorhanden.</div>';
          modalContactSuggestions.dataset.chips = '[]';
          return;
        }

        modalContactSuggestions.innerHTML = chips.map((chip, idx) => (
          `<button type="button" class="contact-chip" data-chip-index="${idx}">
            ${chip.kind === 'organisation' ? '<span class="contact-chip-tag">Firma</span>' : ''}
            ${chip.kind === 'kontakt' ? '<span class="contact-chip-tag" style="border-color:#93c5fd;background:#eff6ff;color:#1d4ed8;">Kontakt</span>' : ''}
            <span class="contact-chip-title">${chip.title || '-'}</span>
            ${chip.subtitle ? `<span class="contact-chip-sub">${chip.subtitle}</span>` : ''}
          </button>`
        )).join('');
        modalContactSuggestions.dataset.chips = JSON.stringify(chips);
      }

      function openContactPicker() {
        const chips = JSON.parse(modalContactSuggestions.dataset.chips || '[]');
        if (!chips.length) {
          modalContactSuggestions.innerHTML = '<div class="contact-picker-empty">Bitte zuerst eine Organisation auswählen.</div>';
        }
        contactPickerBackdrop.classList.add('open');
      }

      function closeContactPicker(event) {
        if (event && event.target && event.target.id !== 'contactPickerBackdrop') return;
        contactPickerBackdrop.classList.remove('open');
      }

      function clearCustomerSelection(keepSearchValue) {
        modalCoreCustomerId.value = '';
        selectedCustomerLabel = '';
        activeCustomer = null;
        if (!keepSearchValue) modalCustomerSearch.value = '';
        modalSelectedCustomer.textContent = 'Keine Firma / kein Kontakt ausgewählt.';
        clearContactSelectionUI();
      }

      function applyCannotAssignUi(checked) {
        if (modalArchiveRow) modalArchiveRow.style.display = checked ? 'block' : 'none';
        if (modalSectionFirmaKontakt) modalSectionFirmaKontakt.style.display = checked ? 'none' : '';
        if (modalSectionKundendaten) modalSectionKundendaten.style.display = checked ? 'none' : '';
        if (modalTourUrl) {
          if (checked) {
            modalTourUrl.removeAttribute('required');
          } else {
            modalTourUrl.setAttribute('required', 'required');
          }
        }
        if (!checked && modalArchiveIt) {
          modalArchiveIt.checked = true;
        }
      }

      window.openLinkModal = function openLinkModal(btn) {
        const spaceId = btn?.dataset?.spaceId || '';
        const spaceName = btn?.dataset?.spaceName || 'Ohne Namen';
        const spaceCreated = btn?.dataset?.spaceCreated || '-';
        const spaceUrl = btn?.dataset?.spaceUrl || '';
        modalMeta.textContent = `${spaceName} · ${spaceId} · erstellt ${spaceCreated}`;
        modalSpaceId.value = spaceId;
        modalTourUrl.value = spaceUrl;
        modalBezeichnung.value = spaceName || '';
        if (modalCannotAssign) {
          modalCannotAssign.checked = false;
        }
        if (modalArchiveIt) {
          modalArchiveIt.checked = true;
        }
        applyCannotAssignUi(false);
        clearCustomerSelection(false);
        modalCustomerName.value = '';
        modalCustomerEmail.value = '';
        modalCustomerContact.value = '';
        suggestionsState = { companies: [], contacts: [] };
        renderSuggestions(modalSuggestions, suggestionsState);
        modalBackdrop.classList.add('open');
      };

      window.closeLinkModal = function closeLinkModal(event) {
        if (event && event.target && event.target.id !== 'linkModalBackdrop') return;
        closeContactPicker();
        modalBackdrop.classList.remove('open');
      };
      window.closeContactPicker = closeContactPicker;

      modalCannotAssign?.addEventListener('change', () => {
        applyCannotAssignUi(!!modalCannotAssign.checked);
        if (modalCannotAssign.checked) {
          clearCustomerSelection(false);
          modalCustomerName.value = '';
          modalCustomerEmail.value = '';
          modalCustomerContact.value = '';
          suggestionsState = { companies: [], contacts: [] };
          renderSuggestions(modalSuggestions, suggestionsState);
        }
      });

      modalCustomerSearch?.addEventListener('input', () => {
        clearTimeout(searchTimer);
        const q = modalCustomerSearch.value.trim();
        if (selectedCustomerLabel && q !== selectedCustomerLabel) {
          clearCustomerSelection(true);
        }
        if (q.length < 2) {
          suggestionsState = { companies: [], contacts: [] };
          renderSuggestions(modalSuggestions, suggestionsState);
          return;
        }
        searchTimer = setTimeout(async () => {
          try {
            const url = `${TM_ADMIN_PREFIX}/admin/link-matterport/customer-search?q=${encodeURIComponent(q)}`;
            const response = await fetch(url, { credentials: 'same-origin' });
            const data = await response.json().catch(() => ({}));
            suggestionsState = {
              companies: Array.isArray(data.companies) ? data.companies : [],
              contacts: Array.isArray(data.contacts) ? data.contacts : [],
            };
            renderSuggestions(modalSuggestions, suggestionsState);
          } catch (e) {
            suggestionsState = { companies: [], contacts: [] };
            renderSuggestions(modalSuggestions, suggestionsState);
          }
        }, 180);
      });

      modalSuggestions?.addEventListener('click', async (event) => {
        const btn = event.target.closest('.suggestion-btn');
        if (!btn) return;
        const pick = btn.getAttribute('data-pick');
        const idx = parseInt(btn.getAttribute('data-idx'), 10);
        if (pick === 'company') {
          const customer = suggestionsState.companies[idx];
          if (!customer) return;
          activeCustomer = customer;
          modalCoreCustomerId.value = customer.id || '';
          selectedCustomerLabel = customer.firmenname || customer.id || '';
          modalCustomerSearch.value = selectedCustomerLabel;
          modalSelectedCustomer.textContent = `Firma: ${customer.firmenname || customer.id}${customer.nummer ? ` (Ref. ${customer.nummer})` : ''}`;
          modalCustomerName.value = customer.firmenname || modalCustomerName.value;
          modalCustomerEmail.value = customer.email || modalCustomerEmail.value;
          modalCustomerContact.value = '';
          renderContactSuggestions(customer);
          renderSuggestions(modalSuggestions, { companies: [], contacts: [] });
          return;
        }
        if (pick === 'contact') {
          const hit = suggestionsState.contacts[idx];
          if (!hit) return;
          modalCoreCustomerId.value = hit.customerId;
          selectedCustomerLabel = `${hit.contactName || ''} · ${hit.firmenname || ''}`.trim() || hit.firmenname;
          modalCustomerSearch.value = hit.contactName || hit.firmenname || '';
          modalSelectedCustomer.textContent = `Kontakt: ${hit.contactName || '—'} · Firma: ${hit.firmenname || '—'}`;
          modalCustomerName.value = hit.firmenname || modalCustomerName.value;
          modalCustomerEmail.value = hit.contactEmail || hit.customerEmail || modalCustomerEmail.value;
          modalCustomerContact.value = hit.contactName || '';
          try {
            const detailUrl = `${TM_ADMIN_PREFIX}/admin/link-matterport/customer-detail?customerId=${encodeURIComponent(hit.customerId)}`;
            const dr = await fetch(detailUrl, { credentials: 'same-origin' });
            const d = await dr.json().catch(() => ({}));
            if (d.customer) {
              activeCustomer = d.customer;
              renderContactSuggestions(d.customer);
            } else {
              activeCustomer = {
                id: hit.customerId,
                firmenname: hit.firmenname,
                email: hit.customerEmail,
                contacts: [],
              };
              renderContactSuggestions(activeCustomer);
            }
          } catch (e) {
            activeCustomer = {
              id: hit.customerId,
              firmenname: hit.firmenname,
              email: hit.customerEmail,
              contacts: [],
            };
            renderContactSuggestions(activeCustomer);
          }
          renderSuggestions(modalSuggestions, { companies: [], contacts: [] });
        }
      });

      modalContactSuggestions?.addEventListener('click', (event) => {
        const btn = event.target.closest('.contact-chip');
        if (!btn) return;
        const idx = parseInt(btn.dataset.chipIndex, 10);
        const chips = JSON.parse(modalContactSuggestions.dataset.chips || '[]');
        const chip = chips[idx];
        if (!chip) return;
        if (chip.name) modalCustomerContact.value = chip.name;
        if (chip.email) modalCustomerEmail.value = chip.email;
        closeContactPicker();
      });

      modalClearCustomer?.addEventListener('click', () => {
        clearCustomerSelection(false);
        modalCustomerName.value = '';
        modalCustomerEmail.value = '';
        modalCustomerContact.value = '';
        suggestionsState = { companies: [], contacts: [] };
        renderSuggestions(modalSuggestions, suggestionsState);
      });

      modalContactPickerToggle?.addEventListener('click', openContactPicker);
      modalCustomerContact?.addEventListener('focus', openContactPicker);

      const autoOpenSpace = <%- JSON.stringify(autoOpenSpace || null) %>;
      if (autoOpenSpace && autoOpenSpace.id) {
        const createdLabel = autoOpenSpace.created
          ? new Date(autoOpenSpace.created).toLocaleDateString('de-CH', { day: '2-digit', month: 'short', year: 'numeric' })
          : '-';
        const fallbackUrl = `https://my.matterport.com/show/?m=${autoOpenSpace.id}`;
        window.openLinkModal({
          dataset: {
            spaceId: autoOpenSpace.id,
            spaceName: autoOpenSpace.name || 'Ohne Namen',
            spaceCreated: createdLabel,
            spaceUrl: fallbackUrl,
          },
        });
      }

      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        closeContactPicker();
        window.closeLinkModal();
      });
    })();
  </script>
</body>
</html>
