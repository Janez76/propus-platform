<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Propus Tour Manager' %></title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; margin: 0; padding: 0; }
    nav { background: #333; color: #fff; padding: 0.75rem 1rem; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: #fff; text-decoration: none; }
    main { padding: 1rem; max-width: 1200px; margin: 0 auto; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 0.5rem; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #f5f5f5; }
    .badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.85rem; }
    .badge-ACTIVE { background: #4caf50; color: #fff; }
    .badge-EXPIRING_SOON { background: #ff9800; color: #fff; }
    .badge-CUSTOMER_ACCEPTED_AWAITING_PAYMENT { background: #2196f3; color: #fff; }
    .badge-CUSTOMER_DECLINED { background: #9e9e9e; color: #fff; }
    .badge-ARCHIVED { background: #607d8b; color: #fff; }
    .badge-EXPIRED_PENDING_ARCHIVE { background: #f44336; color: #fff; }
    .btn { display: inline-block; padding: 0.35rem 0.75rem; margin: 0.2rem; font-size: 0.9rem; text-decoration: none; background: #333; color: #fff; border: none; cursor: pointer; border-radius: 4px; }
    .btn:hover { background: #555; }
    .btn-small { padding: 0.2rem 0.5rem; font-size: 0.8rem; }
    .filters { margin-bottom: 1rem; }
    .filters a { margin-right: 0.5rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/admin/dashboard">
      <img src="https://propus.ch/wp-content/uploads/2024/06/Asset-2-2.png" alt="Propus" style="height:28px;width:auto;display:block;" loading="eager" decoding="async">
    </a>
    <form method="post" action="/logout" style="display:inline;">
      <button type="submit" class="btn btn-small">Abmelden</button>
    </form>
  </nav>
  <main>
    <%- body %>
  </main>
</body>
</html>
