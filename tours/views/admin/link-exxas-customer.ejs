<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kunde anpassen – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
  <style>
    .page-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    .page-head h1 { margin: 0; }
    .panel {
      border: 1px solid var(--border);
      border-radius: 8px;
      background: #fff;
      padding: 1.1rem 1.2rem;
      margin-bottom: 1rem;
      box-shadow: 0 8px 24px rgba(20, 19, 17, 0.04);
    }
    .tour-context {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.9rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      box-shadow: 0 8px 24px rgba(20, 19, 17, 0.04);
    }
    .tour-context .ctx-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 0.55rem;
    }
    .tour-context .ctx-item {
      display: flex;
      flex-direction: column;
      gap: 0.18rem;
      padding: 0.58rem 0.65rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg-subtle);
      min-height: 58px;
    }
    .tour-context .ctx-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); font-weight: 600; }
    .tour-context .ctx-val { color: var(--text); font-weight: 500; line-height: 1.35; }
    .tour-context .ctx-url {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
      font-size: 0.78rem;
      word-break: break-all;
    }
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem 1.5rem;
    }
    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
    }
    .field-group {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .field-group label {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .field-group input {
      width: 100%;
      box-sizing: border-box;
    }
    .form-actions {
      margin-top: 1.25rem;
      display: flex;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">
      <a href="/admin/tours/<%= tour.id %>" class="back">← Zurück zur Tour</a>
      <div class="page-head">
        <div>
          <h1>Kunde anpassen</h1>
        </div>
      </div>

      <% if (saved) { %>
      <div class="alert alert-success">Kundendaten wurden gespeichert.</div>
      <% } %>
      <% if (error === 'missing') { %>
      <div class="alert alert-error">Bitte mindestens den Kundennamen angeben.</div>
      <% } %>

      <!-- Tour-Kontext -->
      <div class="tour-context">
        <div class="ctx-row">
          <div class="ctx-item">
            <span class="ctx-label">Objekt</span>
            <span class="ctx-val"><%= tour.canonical_object_label || tour.object_label || tour.bezeichnung || ('Tour ' + tour.id) %></span>
          </div>
          <div class="ctx-item">
            <span class="ctx-label">Aktueller Kunde</span>
            <span class="ctx-val"><%= tour.canonical_customer_name || tour.customer_name || tour.kunde_ref || '–' %></span>
          </div>
          <div class="ctx-item">
            <span class="ctx-label">Aktueller Kontakt</span>
            <span class="ctx-val"><%= tour.customer_contact || tour.canonical_customer_name || tour.customer_name || '–' %></span>
          </div>
          <div class="ctx-item">
            <span class="ctx-label">Tour-Link</span>
            <span class="ctx-val ctx-url">
              <% if (tour.tour_url) { %>
              <a href="<%= tour.tour_url %>" target="_blank" rel="noopener" style="color:var(--accent);"><%= tour.tour_url.length > 60 ? tour.tour_url.slice(0, 60) + '…' : tour.tour_url %></a>
              <% } else { %>–<% } %>
            </span>
          </div>
        </div>
      </div>

      <!-- Bearbeitungsformular -->
      <div class="panel">
        <form method="post" action="/admin/tours/<%= tour.id %>/link-exxas-customer">
          <div class="form-grid">
            <div class="field-group">
              <label for="customer_name">Kundenname</label>
              <input
                type="text"
                id="customer_name"
                name="customer_name"
                value="<%= tour.customer_name || '' %>"
                placeholder="Firmenname oder Kundenname…"
                autofocus
              >
            </div>
            <div class="field-group">
              <label for="customer_contact">Ansprechpartner</label>
              <input
                type="text"
                id="customer_contact"
                name="customer_contact"
                value="<%= tour.customer_contact || '' %>"
                placeholder="Vor- und Nachname…"
              >
            </div>
            <div class="field-group">
              <label for="customer_email">E-Mail</label>
              <input
                type="email"
                id="customer_email"
                name="customer_email"
                value="<%= tour.customer_email || '' %>"
                placeholder="E-Mail-Adresse…"
              >
            </div>
            <div class="field-group">
              <label for="kunde_ref">Kundennummer (optional)</label>
              <input
                type="text"
                id="kunde_ref"
                name="kunde_ref"
                value="<%= tour.kunde_ref || '' %>"
                placeholder="z. B. 10042"
              >
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Speichern</button>
            <a href="/admin/tours/<%= tour.id %>" class="btn btn-ghost">Abbrechen</a>
          </div>
        </form>
      </div>

    </main>
  </div>
</body>
</html>
