<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portal-Rollen – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
  <style>
    /* Tabs */
    .pr-tabs { display:flex; gap:0; border-bottom:2px solid var(--border); margin-bottom:1.5rem; }
    .pr-tab {
      padding:0.6rem 1.25rem; font-size:0.88rem; font-weight:600;
      color:var(--text-muted); cursor:pointer; text-decoration:none;
      border-bottom:2px solid transparent; margin-bottom:-2px;
      display:flex; align-items:center; gap:0.4rem; transition:color .15s;
    }
    .pr-tab:hover { color:var(--text); }
    .pr-tab.active { color:var(--primary,#C5A059); border-bottom-color:var(--primary,#C5A059); }
    .pr-tab-badge {
      display:inline-flex; align-items:center; justify-content:center;
      min-width:18px; height:18px; border-radius:9px; font-size:0.68rem; font-weight:700;
      padding:0 5px; background:var(--primary-muted,rgba(197,160,89,.15)); color:var(--primary,#C5A059);
    }

    /* Intro */
    .pr-intro { color:var(--text-muted); margin:0 0 1.25rem 0; max-width:720px; font-size:0.88rem; line-height:1.6; }

    /* Liste */
    .pr-list { border:1px solid var(--border); border-radius:12px; background:var(--bg-card,#fff); overflow:hidden; margin-bottom:1.25rem; }
    .pr-row { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:0.85rem 1rem; border-top:1px solid var(--border); flex-wrap:wrap; }
    .pr-row:first-child { border-top:none; }
    .pr-avatar {
      width:32px; height:32px; border-radius:50%; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-size:0.7rem; font-weight:700;
    }
    .pr-avatar-intern { background:rgba(99,102,241,.13); color:#a5b4fc; }
    .pr-avatar-extern { background:rgba(197,160,89,.13); color:#C5A059; }
    .pr-row-left { display:flex; align-items:center; gap:0.7rem; }
    .pr-email { font-weight:600; color:var(--text); font-size:0.88rem; }
    .pr-meta  { font-size:0.76rem; color:var(--text-muted); margin-top:2px; }
    .pr-badge {
      display:inline-flex; align-items:center; gap:3px;
      padding:2px 7px; border-radius:20px; font-size:0.7rem; font-weight:600;
    }
    .pr-badge-intern { background:rgba(99,102,241,.12); color:#a5b4fc; }
    .pr-badge-admin  { background:rgba(197,160,89,.12); color:#C5A059; }
    .pr-badge-inhaber{ background:rgba(34,197,94,.12); color:#22c55e; }

    /* Form */
    .pr-form { display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end; margin-top:0.25rem; }
    .pr-form label { display:grid; gap:0.3rem; font-size:0.82rem; color:var(--text-muted); }
    .pr-form input, .pr-form select {
      padding:0.48rem 0.65rem; border-radius:10px; border:1px solid var(--border);
      background:var(--bg); color:var(--text); font-size:0.88rem;
    }
    .pr-form input[type="email"], .pr-form input[type="text"] { min-width:250px; }
    .pr-form select { min-width:200px; }

    /* Firma-Autocomplete */
    .firma-ac-wrap { position:relative; min-width:280px; }
    .firma-ac-input {
      width:100%; padding:0.48rem 0.65rem 0.48rem 2rem; border-radius:10px;
      border:1px solid var(--border); background:var(--bg); color:var(--text);
      font-size:0.88rem; box-sizing:border-box;
    }
    .firma-ac-icon {
      position:absolute; left:0.6rem; top:50%; transform:translateY(-50%);
      color:var(--text-muted); font-size:0.8rem; pointer-events:none;
    }
    .firma-ac-list {
      position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:200;
      background:var(--bg-card,#fff); border:1px solid var(--border); border-radius:10px;
      box-shadow:0 4px 16px rgba(0,0,0,.12); max-height:260px; overflow-y:auto;
      display:none;
    }
    .firma-ac-list.open { display:block; }
    .firma-ac-item {
      padding:0.55rem 0.75rem; cursor:pointer; font-size:0.85rem;
      display:flex; flex-direction:column; gap:1px;
      border-bottom:1px solid var(--border-subtle,var(--border));
    }
    .firma-ac-item:last-child { border-bottom:none; }
    .firma-ac-item:hover, .firma-ac-item.active { background:var(--row-hover,rgba(197,160,89,.08)); }
    .firma-ac-item-name { font-weight:600; color:var(--text); }
    .firma-ac-item-email { font-size:0.76rem; color:var(--text-muted); }
    .firma-ac-item em { font-style:normal; color:var(--primary,#C5A059); font-weight:700; }
    .firma-ac-empty { padding:0.75rem; font-size:0.83rem; color:var(--text-muted); text-align:center; }

    /* Kontakt-Chips */
    .contact-suggestion-list { display:flex; flex-direction:column; gap:0.3rem; margin-top:0.4rem; }
    .contact-chip {
      display:flex; align-items:center; gap:0.6rem; padding:0.45rem 0.7rem;
      border:1px solid var(--border); border-radius:8px; background:var(--bg);
      cursor:pointer; transition:background .1s, border-color .1s; font-size:0.83rem;
    }
    .contact-chip:hover { background:var(--row-hover,rgba(197,160,89,.08)); border-color:var(--primary,#C5A059); }
    .contact-chip.selected { background:rgba(197,160,89,.12); border-color:var(--primary,#C5A059); box-shadow:0 0 0 1px rgba(197,160,89,.2); }
    .contact-chip-check { flex-shrink:0; display:flex; align-items:center; }
    .contact-chip-avatar {
      width:28px; height:28px; border-radius:50%; flex-shrink:0;
      background:rgba(197,160,89,.15); color:var(--primary,#C5A059);
      font-size:0.65rem; font-weight:700; display:flex; align-items:center; justify-content:center;
    }
    .contact-chip-info { flex:1; min-width:0; }
    .contact-chip-name { font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .contact-chip-sub  { font-size:0.73rem; color:var(--text-muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* Group header for extern */
    .pr-group-header {
      padding:0.5rem 1rem; font-size:0.75rem; font-weight:700; letter-spacing:.04em;
      color:var(--text-muted); background:var(--bg-subtle,rgba(0,0,0,.03)); text-transform:uppercase;
      border-bottom:1px solid var(--border);
    }

    /* empty */
    .pr-empty { padding:1.5rem 1rem; color:var(--text-muted); font-size:0.85rem; text-align:center; }
  </style>
</head>
<body>
<% const bp = typeof basePath === 'string' ? basePath : ''; %>
<% function initials(s) {
   const parts = String(s||'').trim().split(/[\s@.]+/).filter(Boolean).slice(0,2);
   return parts.map(p=>p[0].toUpperCase()).join('') || 'P';
} %>
<% function fmtDate(d) {
   if (!d) return '–';
   return new Date(d).toLocaleDateString('de-CH',{day:'2-digit',month:'2-digit',year:'2-digit'});
} %>

  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">
      <div style="margin-bottom:1.25rem;">
        <h1 style="margin:0 0 0.25rem 0;">Portal-Rollen</h1>
        <p style="margin:0;color:var(--text-muted);font-size:0.88rem;">
          Zentrale Verwaltung interner Tour-Manager und externer Kunden-Admins.
        </p>
      </div>

      <!-- Alerts -->
      <% if (saved) { %><div class="alert alert-success" style="margin-bottom:1rem;">Tour-Manager wurde hinzugefügt.</div><% } %>
      <% if (removed) { %><div class="alert alert-success" style="margin-bottom:1rem;">Interner Eintrag wurde entfernt.</div><% } %>
      <% if (externSaved) { %><div class="alert alert-success" style="margin-bottom:1rem;">Kunden-Admin wurde gesetzt.</div><% } %>
      <% if (externRemoved) { %><div class="alert alert-success" style="margin-bottom:1rem;">Admin-Rolle wurde zurückgestuft.</div><% } %>
      <% if (error) { %><div class="alert alert-error" style="margin-bottom:1rem;"><%= error %></div><% } %>

      <!-- Tabs -->
      <div class="pr-tabs">
        <a href="<%= bp %>/admin/portal-roles?tab=intern"
           class="pr-tab <%= tab === 'intern' ? 'active' : '' %>">
          <i class="fa-solid fa-user-shield"></i>
          Intern (Tour-Manager)
          <% if (staffRows && staffRows.length > 0) { %>
            <span class="pr-tab-badge"><%= staffRows.length %></span>
          <% } %>
        </a>
        <a href="<%= bp %>/admin/portal-roles?tab=extern"
           class="pr-tab <%= tab === 'extern' ? 'active' : '' %>">
          <i class="fa-solid fa-users"></i>
          Extern (Kunden-Admins)
          <% const adminCount = (externRows||[]).filter(r=>r.role==='admin').length; %>
          <% if (adminCount > 0) { %>
            <span class="pr-tab-badge"><%= adminCount %></span>
          <% } %>
        </a>
      </div>

      <!-- ═══ TAB INTERN ═══ -->
      <% if (tab === 'intern') { %>
        <p class="pr-intro">
          Interne Tour-Manager sehen im Kundenportal <strong>alle</strong> Touren aller Kunden und können
          Zuständigkeiten wie Arbeitsbereichs-Admins setzen. Die Vergabe erfolgt zentral hier –
          die Rolle wird nicht über Teameinladungen vergeben.
        </p>
        <% if (typeof logtoPortalEnabled !== 'undefined' && logtoPortalEnabled) { %>
          <p class="pr-intro" style="margin-top:-0.5rem;">
            <i class="fa-solid fa-shield-check" style="color:var(--primary,#C5A059);"></i>
            <strong>Logto-SSO</strong> ist aktiv. Interne Nutzer melden sich unter
            <a href="<%= bp %>/portal/login">Kundenportal-Login</a> mit „Mit Propus-Konto anmelden" an.
          </p>
        <% } %>

        <div class="section" style="padding:0;">
          <div style="padding:0.75rem 1rem;border-bottom:1px solid var(--border);font-size:0.82rem;font-weight:600;color:var(--text-muted);">
            Tour-Manager (<%= (staffRows||[]).length %>)
          </div>
          <div class="pr-list" style="border:none;border-radius:0;margin:0;">
            <% if (!staffRows || staffRows.length === 0) { %>
              <div class="pr-empty">
                <i class="fa-solid fa-user-shield" style="font-size:1.5rem;opacity:.2;display:block;margin-bottom:0.5rem;"></i>
                Noch keine internen Tour-Manager eingetragen.
              </div>
            <% } else { %>
              <% staffRows.forEach((row) => { %>
                <div class="pr-row">
                  <div class="pr-row-left">
                    <div class="pr-avatar pr-avatar-intern"><%= initials(row.email_norm) %></div>
                    <div>
                      <div class="pr-email"><%= row.email_norm %></div>
                      <div class="pr-meta">
                        <span class="pr-badge pr-badge-intern"><i class="fa-solid fa-user-shield"></i> Tour-Manager</span>
                        &nbsp;seit <%= fmtDate(row.created_at) %>
                      </div>
                    </div>
                  </div>
                  <form method="post" action="<%= bp %>/admin/portal-roles/remove" style="margin:0;"
                        onsubmit="return confirm('Tour-Manager-Rechte für diese E-Mail entfernen?');">
                    <input type="hidden" name="email" value="<%= row.email_norm %>">
                    <button type="submit" class="btn btn-soft-danger btn-small">
                      <i class="fa-solid fa-trash"></i> Entfernen
                    </button>
                  </form>
                </div>
              <% }) %>
            <% } %>
          </div>

          <div style="padding:1rem;border-top:1px solid var(--border);">
            <div style="font-size:0.82rem;font-weight:600;color:var(--text-muted);margin-bottom:0.5rem;">
              Tour-Manager hinzufügen
            </div>
            <form method="post" action="<%= bp %>/admin/portal-roles/add" class="pr-form">
              <label>
                E-Mail (Propus-intern)
                <input type="email" name="email" required placeholder="name@propus.ch" autocomplete="off">
              </label>
              <button type="submit" class="btn btn-primary" style="align-self:flex-end;">
                <i class="fa-solid fa-user-plus"></i> Als Tour-Manager speichern
              </button>
            </form>
          </div>
        </div>

      <!-- ═══ TAB EXTERN ═══ -->
      <% } else { %>
        <p class="pr-intro">
          Kunden-Admins sind externe Nutzer, die im Kundenportal ihr eigenes Team verwalten dürfen
          (Mitglieder einladen, Rollen setzen). Pro Workspace (Kunden-E-Mail) kann es einen oder
          mehrere Admins geben. Der Workspace-Inhaber hat immer vollen Zugriff.
        </p>

        <div class="section" style="padding:0;">
          <!-- Gruppenweise nach Workspace -->
          <%
            // Gruppieren nach customer_id (bevorzugt) oder owner_email als Fallback
            const grouped = {};
            const groupOrder = [];
            (externRows||[]).forEach(r => {
              const k = r.customer_id ? `cid:${r.customer_id}` : `email:${r.owner_email}`;
              if (!grouped[k]) {
                grouped[k] = { customer_name: r.customer_name, customer_id: r.customer_id, owner_email: r.owner_email, members: [] };
                groupOrder.push(k);
              } else if (!grouped[k].customer_name && r.customer_name) {
                grouped[k].customer_name = r.customer_name;
              }
              grouped[k].members.push(r);
            });
            const groupKeys = groupOrder;
          %>

          <% if (groupKeys.length === 0) { %>
            <div class="pr-empty" style="padding:2.5rem;">
              <i class="fa-solid fa-users" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:0.5rem;"></i>
              Noch keine externen Kunden-Admins gesetzt.
            </div>
          <% } else { %>
            <% groupKeys.forEach(groupKey => {
                const g = grouped[groupKey];
            %>
              <div class="pr-group-header">
                <% if (g.customer_id) { %>
                  <a href="<%= bp %>/admin/customers/<%= g.customer_id %>" style="color:inherit;">
                    <%= g.customer_name %></a>
                <% } else { %>
                  <%= g.customer_name %>
                <% } %>
              </div>
              <% g.members.forEach(m => { %>
                <div class="pr-row">
                  <div class="pr-row-left">
                    <div class="pr-avatar pr-avatar-extern"><%= initials(m.display_name || m.member_email) %></div>
                    <div>
                      <div class="pr-email">
                        <%= m.display_name || m.member_email %>
                        <% if (m.display_name) { %>
                          <span style="font-weight:400;color:var(--text-muted);font-size:0.8rem;"> · <%= m.member_email %></span>
                        <% } %>
                      </div>
                      <div class="pr-meta">
                        <% if (m.role === 'inhaber') { %>
                          <span class="pr-badge pr-badge-inhaber"><i class="fa-solid fa-crown"></i> Inhaber</span>
                        <% } else { %>
                          <span class="pr-badge pr-badge-admin"><i class="fa-solid fa-user-gear"></i> Kunden-Admin</span>
                        <% } %>
                        &nbsp;aktiv seit <%= fmtDate(m.accepted_at || m.created_at) %>
                      </div>
                    </div>
                  </div>
                  <% if (m.role !== 'inhaber') { %>
                    <form method="post" action="<%= bp %>/admin/portal-roles/extern-remove" style="margin:0;"
                          onsubmit="return confirm('Admin-Rolle entfernen und auf Mitarbeiter zurückstufen?');">
                      <input type="hidden" name="owner_email"  value="<%= m.owner_email %>">
                      <input type="hidden" name="member_email" value="<%= m.member_email %>">
                      <button type="submit" class="btn btn-soft-danger btn-small">
                        <i class="fa-solid fa-arrow-down"></i> Zurückstufen
                      </button>
                    </form>
                  <% } else { %>
                    <span style="font-size:0.75rem;color:var(--text-muted);">Inhaber kann nicht entfernt werden</span>
                  <% } %>
                </div>
              <% }) %>
            <% }) %>
          <% } %>

          <!-- Form: Kunden-Admin direkt setzen -->
          <div style="padding:1.25rem 1rem;border-top:1px solid var(--border);">
            <div style="font-size:0.82rem;font-weight:600;color:var(--text-muted);margin-bottom:1rem;">
              Kunden-Admin direkt setzen
            </div>
            <form method="post" action="<%= bp %>/admin/portal-roles/extern-set" id="externSetForm">

              <!-- Schritt 1: Firma suchen -->
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.85rem;align-items:start;">
                <div>
                  <div style="font-size:0.78rem;color:var(--text-muted);margin-bottom:0.3rem;">
                    <span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:var(--primary,#C5A059);color:#fff;font-size:0.65rem;font-weight:700;margin-right:5px;">1</span>
                    Firma / Kunde suchen
                  </div>
                  <div class="firma-ac-wrap">
                    <i class="fa-solid fa-magnifying-glass firma-ac-icon"></i>
                    <input type="text" id="firmaSearch" class="firma-ac-input"
                           placeholder="Firmenname oder Kunde suchen…" autocomplete="off">
                    <input type="hidden" name="owner_email" id="externOwnerEmail">
                    <ul class="firma-ac-list" id="firmaAcList"></ul>
                  </div>
                  <div id="firmaSelected" style="display:none;margin-top:0.4rem;padding:0.4rem 0.65rem;background:rgba(197,160,89,.08);border:1px solid rgba(197,160,89,.3);border-radius:8px;font-size:0.82rem;">
                    <i class="fa-solid fa-building" style="color:var(--primary,#C5A059);margin-right:5px;"></i>
                    <span id="firmaSelectedName"></span>
                    <button type="button" onclick="clearFirma()" style="float:right;background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:0.75rem;padding:0;">
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                  </div>
                </div>

                <!-- Schritt 2: Kontakte als Firmen-Manager wählen (Multi-Select) -->
                <div>
                  <div style="font-size:0.78rem;color:var(--text-muted);margin-bottom:0.3rem;">
                    <span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:var(--primary,#C5A059);color:#fff;font-size:0.65rem;font-weight:700;margin-right:5px;">2</span>
                    Firmen-Manager wählen <span style="font-weight:400;font-size:0.72rem;">(mehrere möglich)</span>
                  </div>
                  <div id="memberEmailsContainer"></div>

                  <div id="contactSuggestions" style="display:none;margin-top:0.25rem;">
                    <div style="font-size:0.74rem;color:var(--text-muted);margin-bottom:0.35rem;">
                      <i class="fa-solid fa-address-book"></i> Kontakte dieser Firma:
                    </div>
                    <div class="contact-suggestion-list" id="contactChipList"></div>
                  </div>
                  <div id="contactLoading" style="display:none;font-size:0.78rem;color:var(--text-muted);padding:0.5rem 0;">
                    <i class="fa-solid fa-spinner fa-spin"></i> Lade Kontakte…
                  </div>
                </div>
              </div>

              <div style="margin-top:1rem;display:flex;gap:0.6rem;align-items:center;">
                <button type="submit" class="btn btn-primary" id="externSetSubmit" disabled>
                  <i class="fa-solid fa-user-gear"></i> Als Kunden-Admin setzen
                </button>
                <span style="font-size:0.77rem;color:var(--text-muted);" id="externSetHint">
                  Wähle Firma → Kontaktperson als Firmen-Manager auswählen
                </span>
              </div>
            </form>
          </div>

          <script>
          (function() {
            const bp = '<%= bp %>';
            const form = document.getElementById('externSetForm');

            const allFirmen = <%- JSON.stringify((ownerList||[]).map(o => ({
              email: o.owner_email,
              name: o.customer_name,
              firma: o.firma || '',
              customerId: o.customer_id || null,
              id: o.customer_id
            }))) %>;

            const searchInput   = document.getElementById('firmaSearch');
            const hiddenEmail   = document.getElementById('externOwnerEmail');
            const acList        = document.getElementById('firmaAcList');
            const selectedBox   = document.getElementById('firmaSelected');
            const selectedName  = document.getElementById('firmaSelectedName');

            const memberContainer = document.getElementById('memberEmailsContainer');
            const contactSugg     = document.getElementById('contactSuggestions');
            const chipList        = document.getElementById('contactChipList');
            const contactLoading  = document.getElementById('contactLoading');
            const submitBtn       = document.getElementById('externSetSubmit');
            const submitHint      = document.getElementById('externSetHint');

            let activeIdx = -1, filtered = [];
            let allContacts = [];
            let selectedEmails = new Set();

            function esc(s) { return String(s||'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
            function hi(str, q) {
              if (!q) return esc(str);
              const re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi');
              return esc(str).replace(re, '<em>$1</em>');
            }
            function initials(s) {
              return String(s||'').trim().split(/[\s@.]+/).filter(Boolean).slice(0,2).map(p=>p[0].toUpperCase()).join('') || '?';
            }

            function updateSubmitState() {
              const n = selectedEmails.size;
              submitBtn.disabled = n === 0;
              if (n === 0) submitHint.textContent = 'Wähle Firma → Kontakte als Firmen-Manager anklicken';
              else if (n === 1) submitHint.textContent = '1 Kontakt ausgewählt';
              else submitHint.textContent = n + ' Kontakte ausgewählt';

              memberContainer.innerHTML = '';
              for (const email of selectedEmails) {
                const inp = document.createElement('input');
                inp.type = 'hidden'; inp.name = 'member_email'; inp.value = email;
                memberContainer.appendChild(inp);
              }
            }

            // ── Firma Autocomplete ──
            function renderList(q) {
              const lq = q.trim().toLowerCase();
              filtered = lq
                ? allFirmen.filter(f => (f.name||'').toLowerCase().includes(lq) || (f.firma||'').toLowerCase().includes(lq))
                : allFirmen.slice(0, 50);
              if (filtered.length === 0) {
                acList.innerHTML = '<li class="firma-ac-empty">Keine Treffer</li>';
              } else {
                acList.innerHTML = filtered.map((f, i) => `
                  <li class="firma-ac-item${i===activeIdx?' active':''}" data-idx="${i}">
                    <span class="firma-ac-item-name">${hi(f.name, lq)}</span>
                  </li>`).join('');
              }
              acList.classList.add('open');
            }
            searchInput.addEventListener('input', () => { activeIdx = -1; renderList(searchInput.value); });
            searchInput.addEventListener('focus', () => { if (!hiddenEmail.value) renderList(searchInput.value); });
            searchInput.addEventListener('keydown', e => {
              if (!acList.classList.contains('open')) return;
              if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(activeIdx+1, filtered.length-1); renderList(searchInput.value); }
              else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = Math.max(activeIdx-1, 0); renderList(searchInput.value); }
              else if (e.key === 'Enter') { e.preventDefault(); if (activeIdx>=0 && filtered[activeIdx]) selectFirma(filtered[activeIdx]); }
              else if (e.key === 'Escape') { acList.classList.remove('open'); }
            });
            acList.addEventListener('mousedown', e => {
              const li = e.target.closest('.firma-ac-item');
              if (!li) return;
              e.preventDefault();
              selectFirma(filtered[parseInt(li.dataset.idx)]);
            });
            document.addEventListener('click', e => {
              if (!e.target.closest('.firma-ac-wrap')) acList.classList.remove('open');
            });

            function selectFirma(f) {
              hiddenEmail.value = f.email;
              searchInput.value = '';
              selectedName.textContent = f.name;
              selectedBox.style.display = '';
              searchInput.style.display = 'none';
              acList.classList.remove('open');
              selectedEmails.clear();
              allContacts = [];
              updateSubmitState();
              loadContacts(f.email, f.customerId);
            }

            window.clearFirma = function() {
              hiddenEmail.value = '';
              searchInput.value = '';
              searchInput.style.display = '';
              selectedBox.style.display = 'none';
              selectedEmails.clear();
              allContacts = [];
              contactSugg.style.display = 'none';
              contactLoading.style.display = 'none';
              chipList.innerHTML = '';
              updateSubmitState();
              searchInput.focus();
            };

            // ── Kontakt-Chips mit Checkbox ──
            function toggleContact(email) {
              if (selectedEmails.has(email)) selectedEmails.delete(email);
              else selectedEmails.add(email);
              renderChips();
              updateSubmitState();
            }

            function renderChips() {
              chipList.innerHTML = '';
              if (!allContacts.length) {
                chipList.innerHTML = '<span style="font-size:0.78rem;color:var(--text-muted);">Keine Kontakte mit E-Mail gefunden.</span>';
                return;
              }
              allContacts.forEach(c => {
                const isSelected = selectedEmails.has(c.email.toLowerCase());
                const chip = document.createElement('div');
                chip.className = 'contact-chip' + (isSelected ? ' selected' : '');
                chip.style.cursor = 'pointer';
                chip.innerHTML = `
                  <div class="contact-chip-check">
                    <i class="fa-${isSelected ? 'solid fa-square-check' : 'regular fa-square'}" style="font-size:1.1rem;color:${isSelected ? 'var(--primary,#C5A059)' : 'var(--text-muted)'};"></i>
                  </div>
                  <div class="contact-chip-avatar">${initials(c.name || c.email)}</div>
                  <div class="contact-chip-info">
                    <div class="contact-chip-name">${esc(c.name || c.email)}</div>
                    <div class="contact-chip-sub">${c.position ? esc(c.position) + ' · ' : ''}${esc(c.email)}</div>
                  </div>`;
                chip.addEventListener('click', () => toggleContact(c.email.toLowerCase()));
                chipList.appendChild(chip);
              });
            }

            async function loadContacts(ownerEmail, customerId) {
              contactLoading.style.display = '';
              contactSugg.style.display = 'none';
              chipList.innerHTML = '';
              try {
                const qs = new URLSearchParams();
                if (ownerEmail) qs.set('owner_email', ownerEmail);
                if (customerId) qs.set('customer_id', String(customerId));
                const resp = await fetch(bp + '/admin/portal-roles/extern-contacts?' + qs.toString());
                const data = await resp.json();
                allContacts = (data.contacts || []);
                contactLoading.style.display = 'none';
                contactSugg.style.display = '';
                renderChips();
              } catch(e) {
                contactLoading.style.display = 'none';
                contactSugg.style.display = '';
                chipList.innerHTML = '<span style="font-size:0.78rem;color:#f87171;">Fehler beim Laden der Kontakte.</span>';
              }
            }

            // ── Form-Submit: mehrere member_emails als einzelne Requests ──
            form.addEventListener('submit', async function(e) {
              e.preventDefault();
              if (selectedEmails.size === 0 || !hiddenEmail.value) return;
              submitBtn.disabled = true;
              submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Speichere…';
              const ownerEmail = hiddenEmail.value;
              let lastErr = null;
              for (const email of selectedEmails) {
                try {
                  const fd = new URLSearchParams();
                  fd.set('owner_email', ownerEmail);
                  fd.set('member_email', email);
                  const r = await fetch(bp + '/admin/portal-roles/extern-set', {
                    method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
                    body: fd.toString(), redirect: 'manual',
                  });
                  if (r.status >= 400) lastErr = 'HTTP ' + r.status;
                } catch(err) { lastErr = err.message; }
              }
              window.location.href = bp + '/admin/portal-roles?tab=extern' +
                (lastErr ? '&error=' + encodeURIComponent(lastErr) : '&externSaved=1');
            });
          })();
          </script>
        </div>
      <% } %>

    </main>
  </div>
</body>
</html>
