<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bankdaten-Upload – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">
      <a href="/admin/invoices" class="back">← Zurück zu Rechnungen</a>
      <h1>Bankdaten-Upload</h1>
      <p style="color:var(--text-muted);margin:0 0 1rem 0;">Upload für UBS `camt.054` (XML) oder CSV. Exakte Treffer werden automatisch als bezahlt markiert, unsichere Treffer landen in der Prüfung.</p>

      <section class="card" style="padding:1rem;margin-bottom:1rem;">
        <form method="post" action="/admin/bank-import/upload" enctype="multipart/form-data" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
          <input type="file" name="bankFile" accept=".xml,.csv,text/xml,text/csv" required>
          <button type="submit" class="btn btn-primary">Datei importieren</button>
        </form>
      </section>

      <section class="card" style="padding:1rem;margin-bottom:1rem;">
        <h2 style="margin:0 0 0.75rem 0;font-size:1rem;">Letzte Importläufe</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Zeit</th>
                <th>Format</th>
                <th>Datei</th>
                <th>Zeilen</th>
                <th>Exakt</th>
                <th>Review</th>
                <th>Ohne Treffer</th>
                <th>Benutzer</th>
              </tr>
            </thead>
            <tbody>
              <% if (!runs || runs.length === 0) { %>
              <tr><td colspan="9" class="empty">Noch keine Imports vorhanden.</td></tr>
              <% } %>
              <% (runs || []).forEach((run) => { %>
              <tr>
                <td><code><%= run.id %></code></td>
                <td><%= run.created_at ? new Date(run.created_at).toLocaleString('de-CH') : '-' %></td>
                <td><%= run.source_format || '-' %></td>
                <td><%= run.file_name || '-' %></td>
                <td><%= run.total_rows || 0 %></td>
                <td><%= run.exact_rows || 0 %></td>
                <td><%= run.review_rows || 0 %></td>
                <td><%= run.none_rows || 0 %></td>
                <td><%= run.created_by || '-' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card" style="padding:1rem;">
        <h2 style="margin:0 0 0.75rem 0;font-size:1rem;">Unsichere Treffer (Review)</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Transaktion</th>
                <th>Referenz</th>
                <th>Betrag</th>
                <th>Vorschlag</th>
                <th>Grund</th>
                <th>Aktion</th>
              </tr>
            </thead>
            <tbody>
              <% if (!reviewRows || reviewRows.length === 0) { %>
              <tr><td colspan="6" class="empty">Keine offenen Review-Treffer.</td></tr>
              <% } %>
              <% (reviewRows || []).forEach((row) => { %>
              <tr>
                <td>
                  <code>#<%= row.id %></code><br>
                  <span style="font-size:0.8rem;color:var(--text-muted);"><%= row.booking_date ? new Date(row.booking_date).toLocaleDateString('de-CH') : '-' %> · <%= row.debtor_name || '-' %></span>
                </td>
                <td><%= row.reference_raw || '-' %></td>
                <td><%= row.amount_chf != null ? ('CHF ' + Number(row.amount_chf).toFixed(2)) : '-' %></td>
                <td>
                  <% if (row.matched_invoice_id) { %>
                    <code><%= row.invoice_number || row.matched_invoice_id %></code><br>
                    <span style="font-size:0.8rem;color:var(--text-muted);"><%= row.tour_label || '-' %> · <%= row.customer_email || '-' %></span>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td><%= row.match_reason || '-' %></td>
                <td>
                  <% if (row.matched_invoice_id) { %>
                  <form method="post" action="/admin/bank-import/transactions/<%= row.id %>/confirm" style="display:flex;gap:0.35rem;flex-wrap:wrap;">
                    <input type="hidden" name="invoiceId" value="<%= row.matched_invoice_id %>">
                    <button type="submit" class="btn btn-primary" style="padding:0.28rem 0.52rem;font-size:0.78rem;">Als bezahlt buchen</button>
                  </form>
                  <% } %>
                  <form method="post" action="/admin/bank-import/transactions/<%= row.id %>/ignore" style="margin-top:0.35rem;">
                    <button type="submit" class="btn btn-ghost" style="padding:0.24rem 0.48rem;font-size:0.75rem;">Ignorieren</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
