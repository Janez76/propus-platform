<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
<style>
  /* Propus Tour Manager Admin – gleiche Design-Tokens wie platform/frontend (index.css) */
  :root {
    --propus-gold: #B68E20;
    --propus-gold-hover: #9a7619;
    --propus-gold-light: #c9a22a;
    --propus-gold-dark: #d4b860;
    --propus-beige: #F1F2EA;
    --propus-beige-alt: #ECEAE3;
    --propus-font-heading: 'Montserrat', system-ui, sans-serif;
    --propus-font-body: 'Roboto', system-ui, sans-serif;

    --text-main: #111111;
    --text-muted: #555555;
    --text-subtle: #888888;
    --surface: #ffffff;
    --surface-raised: #F7F6F3;
    --border-soft: #e8e6e2;
    --border-strong: #d4d0c8;
    --accent: var(--propus-gold);
    --accent-hover: var(--propus-gold-hover);
    --accent-subtle: color-mix(in srgb, var(--propus-gold) 12%, transparent);

    /* Legacy-Aliase (bestehende EJS / Partials) */
    --gold-50: color-mix(in srgb, var(--propus-beige) 92%, var(--propus-gold) 8%);
    --gold-100: color-mix(in srgb, var(--propus-beige) 85%, var(--propus-gold) 15%);
    --gold-200: color-mix(in srgb, var(--border-soft) 70%, var(--propus-gold) 30%);
    --gold-300: color-mix(in srgb, var(--propus-gold) 45%, white);
    --gold-400: var(--propus-gold-light);
    --gold-500: var(--propus-gold);
    --gold-600: var(--propus-gold);
    --gold-700: var(--propus-gold-hover);
    --gold-800: #5c4a12;
    --gold-900: #111111;

    --gray-25: var(--propus-beige);
    --gray-50: var(--surface-raised);
    --gray-100: var(--propus-beige-alt);
    --gray-200: var(--border-soft);
    --gray-300: var(--border-strong);
    --gray-400: var(--text-subtle);
    --gray-500: var(--text-muted);
    --gray-600: #524e47;
    --gray-700: #3b3833;
    --gray-800: var(--text-main);
    --gray-900: #0f1012;

    --bg: var(--propus-beige);
    --bg-card: var(--surface);
    --bg-elevated: var(--surface-raised);
    --bg-hover: color-mix(in srgb, var(--propus-gold) 8%, var(--propus-beige));
    --bg-raised: var(--surface);
    --text: var(--text-main);
    --accent-soft: var(--accent-subtle);
    --link: #2563eb;
    --success: #16a34a;
    --warning: #d97706;
    --danger: #dc2626;
    --exxas: #4f46e5;
    --matterport: var(--propus-gold);
    --border: var(--border-soft);
    --radius: 12px;
    --radius-lg: 16px;
    --shadow: 0 12px 32px rgba(17, 17, 17, 0.06);
  }
  * { box-sizing: border-box; }
  body {
    font-family: var(--propus-font-body);
    margin: 0;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.55;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--propus-font-heading);
    color: var(--text-main);
  }

  /* App-Shell: volle Höhe, kein Seiten-Scroll – nur rechts (admin-main) scrollt (wie Portal) */
  html:has(.admin-shell),
  body:has(.admin-shell) {
    height: 100%;
    overflow: hidden;
  }
  .admin-shell {
    display: flex;
    align-items: stretch;
    height: 100vh;
    max-height: 100vh;
    min-height: 0;
    overflow: hidden;
  }
  .admin-sidebar {
    position: relative;
    top: auto;
    align-self: stretch;
    width: 260px;
    flex-shrink: 0;
    min-height: 0;
    height: auto;
    max-height: none;
    overflow: hidden;
    --bg: #0f1012;
    --bg-card: #161719;
    --bg-elevated: #1c1d1f;
    --bg-hover: #242528;
    --text: #f0ece4;
    --text-muted: #c0bbb4;
    --text-subtle: rgba(240, 236, 228, 0.42);
    --border: rgba(255,255,255,0.1);
    --accent: var(--propus-gold-dark);
    --accent-soft: color-mix(in srgb, var(--propus-gold-dark) 18%, transparent);
    background: #0f1012;
    border-right: 1px solid var(--border-soft);
    padding: 1.5rem 0;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
  }
  .admin-sidebar nav {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .admin-sidebar .logo {
    padding: 0 1.5rem 1.5rem;
    color: var(--text);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 1rem;
  }
  .admin-sidebar .logo .admin-logo-img {
    display: block;
    width: 170px;
    max-width: 100%;
    height: auto;
  }
  .admin-sidebar-back-wrap {
    padding: 0 1rem 0.85rem;
    margin-bottom: 0.15rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .admin-sidebar a.admin-back-to-spa {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.04);
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }
  .admin-sidebar a.admin-back-to-spa:hover {
    color: var(--text);
    background: var(--accent-subtle);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }
  .admin-sidebar a.admin-back-to-spa i {
    font-size: 0.85rem;
    opacity: 0.95;
  }
  .admin-sidebar nav a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s;
    border-left: 3px solid transparent;
  }
  .admin-sidebar nav a i {
    width: 18px;
    text-align: center;
    font-size: 0.95rem;
    opacity: 0.9;
  }
  .admin-sidebar nav a:hover { color: var(--text); background: rgba(255,255,255,0.06); }
  .admin-sidebar nav a.active { color: var(--text); background: var(--accent-subtle); border-left-color: var(--accent); }
  .admin-sidebar nav .nav-link-logout:hover { color: #fff !important; background: rgba(255,255,255,0.06); }
  .nav-section-label {
    padding: 0.12rem 1.5rem 0.45rem;
    color: #8f8a82;
    font-size: 0.67rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 700;
  }
  .nav-link-logout {
    all: unset;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1.5rem;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    width: 100%;
    box-sizing: border-box;
  }
  .nav-link-logout i { width: 18px; text-align: center; font-size: 0.95rem; opacity: 0.95; }
  .nav-link-logout-bottom { margin-top: auto; padding-top: 0.2rem; }
  .admin-sidebar .nav-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 0.75rem 1rem; }
  .admin-sidebar .logout-wrap { padding: 1rem 1.5rem; margin-top: auto; }
  <%- include('../partials/_portal-sidebar-footer-styles') %>
  .admin-main {
    flex: 1;
    min-width: 0;
    min-height: 0;
    padding: 1.65rem 2.1rem;
    overflow-x: auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    background: var(--gray-50);
  }
  .admin-main > .back + h1,
  .admin-main > h1 {
    margin-bottom: 1.1rem;
  }

  /* Global Search */
  .global-search-wrap { position: relative; padding: 0 1rem 1rem; }
  .global-search-box { position: relative; display: flex; align-items: center; }
  .global-search-box .search-icon {
    position: absolute;
    left: 0.75rem;
    color: #9d9890;
    pointer-events: none;
    flex-shrink: 0;
    z-index: 1;
    line-height: 1;
  }
  .global-search-box .search-clear {
    position: absolute;
    right: 0.45rem;
    width: 24px;
    height: 24px;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    color: #c8c3bb;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 0.76rem;
  }
  .global-search-box .search-clear:hover { background: rgba(255,255,255,0.16); color: #fff; }
  .global-search-box .global-search-input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius);
    color: #f7f4ee;
    font-family: inherit;
    font-size: 0.875rem;
    padding: 0.52rem 2rem 0.52rem 2.35rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .global-search-input::placeholder { color: #9d9890; }
  .global-search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent); }
  .global-search-dropdown {
    position: absolute;
    top: calc(100% + 0.4rem);
    left: 1rem;
    right: 1rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    z-index: 999;
    max-height: 420px;
    overflow-y: auto;
  }
  .gs-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: var(--gray-800);
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }
  .gs-item:last-child { border-bottom: none; }
  .gs-item:hover, .gs-item.gs-active { background: var(--bg-hover); }
  .gs-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .gs-badge-tour { background: var(--gold-100); color: var(--gold-700); }
  .gs-badge-invoice { background: rgba(79,70,229,0.14); color: var(--exxas); }
  .gs-content { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .gs-title { font-size: 0.85rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .gs-sub { font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .gs-status { font-size: 0.72rem; color: var(--text-muted); flex-shrink: 0; }
  .gs-empty { padding: 0.75rem; font-size: 0.875rem; color: var(--text-muted); text-align: center; }
  .admin-main h1 { font-size: 1.72rem; font-weight: 700; margin: 0 0 1rem 0; letter-spacing: -0.01em; color: var(--text-main); font-family: var(--propus-font-heading); }
  .tm-page-subtitle { color: var(--text-muted); font-size: 0.9rem; margin: 0 0 1rem 0; font-family: var(--propus-font-body); max-width: 52rem; line-height: 1.5; }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    box-shadow: none;
  }
  .btn i { font-size: 0.85em; }
  .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
  .btn-primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); transform: translateY(-1px); }
  .btn-ghost { background: var(--surface); color: var(--text-main); border: 1px solid var(--border-soft); }
  .btn-ghost:hover { background: var(--surface-raised); color: var(--text-main); border-color: var(--accent); }
  .btn-danger { background: #fff; color: var(--danger); border: 1px solid rgba(239,68,68,0.4); }
  .btn-danger:hover { background: var(--danger); color: #fff; }
  .btn-logout { background: transparent; color: #d6d2ca; border: 1px solid rgba(255,255,255,0.2); padding: 0.4rem 0.9rem; border-radius: 8px; font-family: inherit; font-size: 0.875rem; cursor: pointer; }
  .btn-logout:hover { background: rgba(255,255,255,0.07); color: #fff; }

  /* Stats cards */
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .stat-card:hover { transform: translateY(-2px); border-color: var(--accent); box-shadow: var(--shadow); }
  .stat-card .label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.25rem; }
  .stat-card .value { font-size: 1.5rem; font-weight: 700; }
  .stat-card.active .value { color: var(--success); }
  .stat-card.expiring .value { color: var(--warning); }
  .stat-card.awaiting .value { color: var(--link); }
  .stat-card.unlinked .value { color: var(--warning); }

  /* Filters */
  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
  .filters a {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-muted);
    background: #fff;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .filters a:hover { color: var(--text-main); border-color: var(--accent); }
  .filters a.active { background: var(--accent-subtle); color: var(--text-main); border-color: color-mix(in srgb, var(--accent) 35%, var(--border-soft)); }

  /* Tables */
  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(17, 17, 17, 0.05);
  }
  table { width: 100%; border-collapse: collapse; }
  th {
    text-align: left;
    padding: 1rem 1.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: var(--surface-raised);
    border-bottom: 1px solid var(--border-soft);
    font-family: var(--propus-font-heading);
  }
  td { padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: color-mix(in srgb, var(--propus-gold) 6%, var(--surface)); }
  tr.row-unlinked { border-left: 3px solid var(--warning); }
  tr.row-unlinked td { background: rgba(245,158,11,0.06); }
  tr.row-fremde { border-left: 3px solid var(--warning); }
  tr.row-fremde td { background: rgba(245,158,11,0.04); }
  .customer-name { font-weight: 600; }
  .customer-object { font-size: 0.875rem; color: var(--text-muted); margin-top: 0.2rem; }
  .days { font-weight: 600; font-variant-numeric: tabular-nums; }
  .days.negative { color: var(--danger); }
  .days.soon { color: var(--warning); }
  .days.ok { color: var(--success); }

  /* Badges */
  .badge {
    display: inline-flex;
    padding: 0.28rem 0.6rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .badge-ACTIVE { background: rgba(22,179,100,0.13); color: #0f8c4f; }
  .badge-EXPIRING_SOON { background: rgba(239,140,33,0.14); color: #b7610b; }
  .badge-CUSTOMER_ACCEPTED_AWAITING_PAYMENT { background: rgba(37,99,235,0.13); color: #1e56ca; }
  .badge-CUSTOMER_DECLINED, .badge-ARCHIVED { background: var(--gray-100); color: var(--gray-600); }
  .badge-EXPIRED_PENDING_ARCHIVE { background: rgba(239,68,68,0.13); color: #c72f2f; }
  .badge-sent { background: rgba(37,99,235,0.12); color: #1e56ca; }
  .badge-overdue { background: rgba(239,68,68,0.13); color: #c72f2f; }
  .badge-paid { background: rgba(22,179,100,0.12); color: #0f8c4f; }
  .badge-draft, .badge-cancelled { background: var(--gray-100); color: var(--gray-600); }

  /* Alerts */
  .alert { padding: 1rem 1.25rem; border-radius: var(--radius); margin-bottom: 1rem; font-size: 0.9rem; }
  .alert-success { background: rgba(22,179,100,0.1); border: 1px solid rgba(22,179,100,0.35); color: #0f8c4f; }
  .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.38); color: #be2f2f; }
  .alert-warning { background: rgba(239,140,33,0.1); border: 1px solid rgba(239,140,33,0.34); color: #b7610b; }
  .alert-info { background: var(--gold-50); border: 1px solid var(--gold-300); color: var(--gold-700); }

  /* Forms */
  input[type="text"]:not(.global-search-input), input[type="url"], input[type="email"], input[type="password"], select, textarea {
    background: #fff;
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
  }
  textarea { width: 100%; resize: vertical; min-height: 88px; }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent); }
  .search-bar { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .search-bar input { min-width: 200px; }
  .form-inline { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }

  /* Sections */
  .section {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 6px 24px rgba(17, 17, 17, 0.05);
  }
  .section h2 { font-size: 1rem; margin: 0 0 1rem 0; color: var(--text-muted); font-weight: 600; font-family: var(--propus-font-heading); }
  .section h2.exxas { color: var(--exxas); }
  .section h2.matterport { color: var(--matterport); }

  /* Sortable headers */
  th.sortable { cursor: pointer; user-select: none; white-space: nowrap; }
  th.sortable a { color: inherit; text-decoration: none; display: block; }
  th.sortable a:hover { color: var(--gold-700); }
  th .sort-icon { opacity: 0.5; font-size: 0.7em; margin-left: 0.2rem; }
  th.sort-active .sort-icon { opacity: 1; color: var(--accent); }

  .empty { text-align: center; padding: 3rem; color: var(--text-muted); }
  .back { color: var(--text-muted); text-decoration: none; font-size: 0.9rem; display: inline-block; margin-bottom: 1rem; }
  .back:hover { color: var(--accent); }

  /* Toast container */
  #toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; }
  .toast { padding: 1rem 1.25rem; border-radius: var(--radius); font-size: 0.9rem; animation: toastIn 0.3s ease; max-width: 360px; }
  .toast.success { background: var(--accent); color: #fff; }
  .toast.error { background: var(--danger); color: #fff; }
  @keyframes toastIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 768px) {
    html:has(.admin-shell),
    body:has(.admin-shell) {
      height: auto;
      overflow: auto;
    }
    .admin-shell {
      flex-direction: column;
      align-items: stretch;
      height: auto;
      max-height: none;
      min-height: 100vh;
      min-height: 100dvh;
      overflow: visible;
    }
    .admin-sidebar {
      position: relative;
      top: auto;
      height: auto;
      max-height: none;
      overflow: visible;
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      padding: 0.75rem 1rem;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .admin-sidebar .logo { padding: 0 1rem 0 0; margin-bottom: 0; border-bottom: none; color:#fff; }
    .admin-sidebar nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      flex-wrap: nowrap;
      overflow: visible;
      width: 100%;
      gap: 0;
    }
    .portal-nav-main { overflow-y: visible; flex: 0 1 auto; }
    .admin-sidebar nav a { padding: 0.5rem 0.75rem; font-size: 0.85rem; border-left: none; border-bottom: 2px solid transparent; }
    .admin-sidebar nav a.active { border-bottom-color: var(--accent); }
    .admin-sidebar .logout-wrap { margin: 0; padding: 0.5rem 0 0 1rem; }
    .admin-main { padding: 1rem; overflow: visible; min-height: 0; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .table-wrap { overflow-x: auto; }
  }
</style>
