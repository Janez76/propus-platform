<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>E-Mail-Templates – Propus Tour Manager</title>
  <%- include('_admin-styles') %>
  <style>
    .templates-intro { color: var(--text-muted); margin-bottom: 1.1rem; max-width: 980px; }
    .templates-list {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: #fff;
      overflow: hidden;
    }
    .template-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.8rem;
      align-items: center;
      padding: 0.88rem 1rem;
      border-top: 1px solid var(--border);
    }
    .template-row:first-child { border-top: none; }
    .template-row-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--gray-900);
      margin: 0 0 0.12rem;
    }
    .template-row-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin: 0;
      line-height: 1.4;
    }
    .template-row-meta {
      display: flex;
      gap: 0.35rem;
      align-items: center;
      margin-top: 0.34rem;
      flex-wrap: wrap;
    }
    .template-tag {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text-muted);
      border-radius: 8px;
      font-size: 0.67rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 0.08rem 0.36rem;
    }
    .template-key {
      font-size: 0.73rem;
      color: var(--text-muted);
      border: 1px dashed var(--border);
      border-radius: 8px;
      padding: 0.08rem 0.34rem;
      background: #fcfcfb;
    }
    .template-updated {
      display: none;
      color: #137347;
      border: 1px solid rgba(22, 179, 100, 0.28);
      background: rgba(22, 179, 100, 0.08);
      border-radius: 8px;
      font-size: 0.67rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 0.08rem 0.36rem;
    }
    .template-updated.show { display: inline-flex; }
    .template-hidden-field { display: none; }

    .tm-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(15, 15, 18, 0.5);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .tm-modal-backdrop.open { display: flex; }
    .tm-modal {
      width: min(980px, 100%);
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 24px 45px rgba(20, 19, 17, 0.2);
      overflow: hidden;
      max-height: calc(100vh - 2rem);
      display: flex;
      flex-direction: column;
    }
    .tm-modal-head {
      padding: 0.9rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.6rem;
      background: var(--gray-50);
    }
    .tm-modal-title {
      margin: 0;
      font-size: 1rem;
      color: var(--gray-900);
    }
    .tm-modal-subtitle {
      margin: 0.2rem 0 0;
      color: var(--text-muted);
      font-size: 0.8rem;
      max-width: 720px;
      line-height: 1.4;
    }
    .tm-modal-close {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text-muted);
      border-radius: 8px;
      width: 30px;
      height: 30px;
      cursor: pointer;
      line-height: 1;
      font-size: 1rem;
      flex: 0 0 auto;
    }
    .tm-modal-close:hover { color: var(--gray-900); border-color: var(--gold-300); }
    .tm-modal-body { padding: 0.95rem 1rem; overflow: auto; }
    .tm-modal-foot {
      padding: 0.85rem 1rem 0.95rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: 0.45rem;
      background: #fff;
    }
    .template-field {
      margin-bottom: 0.72rem;
      padding-bottom: 0.72rem;
      border-bottom: 1px solid var(--border);
    }
    .template-field label {
      display: block;
      font-weight: 600;
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 0.32rem;
    }
    .template-subject {
      width: 100%;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--gray-800);
      font: inherit;
      padding: 0.42rem 0.62rem;
      min-height: 2.15rem;
    }
    .tab-row {
      display: flex;
      gap: 0.45rem;
      flex-wrap: wrap;
      margin: 0.1rem 0 0.72rem;
      padding-bottom: 0.72rem;
      border-bottom: 1px solid var(--border);
    }
    .tab-btn {
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-muted);
      border-radius: 8px;
      padding: 0.34rem 0.7rem;
      cursor: pointer;
      font: inherit;
      font-size: 0.8rem;
    }
    .tab-btn.active {
      color: var(--text);
      border-color: var(--gold-300);
      background: var(--gold-50);
    }
    .editor-pane { display: none; }
    .editor-pane.active {
      display: block;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fcfcfb;
      padding: 0.68rem 0.72rem;
    }
    .toolbar {
      display: flex;
      gap: 0.45rem;
      flex-wrap: wrap;
      margin-bottom: 0.58rem;
      padding-bottom: 0.58rem;
      border-bottom: 1px dashed var(--border);
    }
    .toolbar button {
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text);
      border-radius: 7px;
      padding: 0.28rem 0.56rem;
      cursor: pointer;
      font: inherit;
      font-size: 0.78rem;
    }
    .toolbar button:hover { border-color: var(--accent); }
    .template-editor {
      width: 100%;
      min-height: 310px;
      resize: none;
      padding: 0.85rem 0.92rem;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--text);
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 0.83rem;
      line-height: 1.55;
    }
    .toolbar-meta {
      margin-left: auto;
      font-size: 0.73rem;
      color: var(--text-muted);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    .preview-shell {
      border: 1px solid var(--border);
      border-radius: 30px;
      background: radial-gradient(circle at top right, rgba(196,163,90,0.12), transparent 32%), linear-gradient(180deg, #f7f5f0 0%, #efe9dd 100%);
      min-height: 420px;
      overflow: hidden;
    }
    .preview-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.7rem 0.9rem;
      border-bottom: 1px solid rgba(148, 136, 108, 0.18);
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(4px);
    }
    .preview-title {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--gray-800);
      margin: 0;
    }
    .preview-subtitle {
      font-size: 0.72rem;
      color: var(--text-muted);
      margin: 0.12rem 0 0;
    }
    .preview-device {
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
      padding: 0.34rem 0.58rem;
      border-radius: 999px;
      background: #fff;
      border: 1px solid var(--border);
      font-size: 0.72rem;
      color: var(--text-muted);
    }
    .preview-stage {
      padding: 1rem;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 360px;
    }
    .preview-iframe {
      width: 100%;
      min-height: 720px;
      border: 1px solid #ddd6c6;
      border-radius: 32px;
      background: #fff;
      box-shadow: 0 22px 54px rgba(20, 19, 17, 0.12);
    }
    .preview-wrap.preview-text {
      white-space: pre-wrap;
      color: var(--text);
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.1rem;
      min-height: 240px;
      line-height: 1.65;
    }
    .placeholders-hint {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 0.72rem;
      padding-top: 0.72rem;
      border-top: 1px solid var(--border);
      line-height: 1.4;
    }
    .placeholders-hint code {
      background: var(--bg-hover);
      padding: 0.12rem 0.35rem;
      border-radius: 4px;
      font-size: 0.75rem;
      margin: 0 0.22rem 0.22rem 0;
      display: inline-block;
      cursor: pointer;
      border: 1px solid var(--border);
    }
    .placeholders-hint code:hover { border-color: var(--gold-300); }
  </style>
</head>
<body>
  <div class="admin-shell">
    <%- include('_header') %>
    <main class="admin-main">
      <h1>E-Mail-Templates</h1>
      <% if (typeof saved === 'boolean' && saved) { %><div class="alert alert-success">Templates wurden gespeichert.</div><% } %>

      <p class="templates-intro">
        Hier können alle E-Mail-Templates zentral verwaltet und angepasst werden.
        Über <strong>Bearbeiten</strong> lassen sich Betreff, HTML, Text und Vorschau je Vorlage bearbeiten.
      </p>

      <form method="post" action="/admin/email-templates" id="templatesForm">
        <% const keys = Object.keys(templates || {}); %>
        <div class="templates-list">
          <% for (const key of keys) { %>
            <%
              const t = templates[key] || {};
              const placeholders = placeholderHints && placeholderHints[key] ? placeholderHints[key] : [];
            %>
            <section class="template-row" data-template-row="<%= key %>" data-template-name="<%= t.name || key %>" data-template-desc="<%= t.description || '' %>">
              <div>
                <p class="template-row-title"><%= t.name || key %></p>
                <% if (t.description) { %><p class="template-row-desc"><%= t.description %></p><% } %>
                <div class="template-row-meta">
                  <span class="template-tag"><%= t.category || 'aktiv' %></span>
                  <span class="template-key"><%= key %></span>
                  <span class="template-updated" id="<%= key %>_updated">Geändert</span>
                </div>
              </div>
              <div>
                <button type="button" class="btn btn-ghost" data-edit-template="<%= key %>">Bearbeiten</button>
              </div>

              <input class="template-hidden-field" type="hidden" name="<%= key %>_subject" id="<%= key %>_subject_hidden" value="<%= t.subject || '' %>">
              <textarea class="template-hidden-field" name="<%= key %>_html" id="<%= key %>_html_hidden"><%- String(t.html || '').replace(/<\/textarea>/gi, '</\u200Btextarea>') %></textarea>
              <textarea class="template-hidden-field" name="<%= key %>_text" id="<%= key %>_text_hidden"><%- String(t.text || '').replace(/<\/textarea>/gi, '</\u200Btextarea>') %></textarea>
              <input class="template-hidden-field" type="hidden" id="<%= key %>_subject_default" value="<%= (defaultTemplates && defaultTemplates[key] && defaultTemplates[key].subject) || '' %>">
              <textarea class="template-hidden-field" id="<%= key %>_html_default"><%- String((defaultTemplates && defaultTemplates[key] && defaultTemplates[key].html) || '').replace(/<\/textarea>/gi, '</\u200Btextarea>') %></textarea>
              <textarea class="template-hidden-field" id="<%= key %>_text_default"><%- String((defaultTemplates && defaultTemplates[key] && defaultTemplates[key].text) || '').replace(/<\/textarea>/gi, '</\u200Btextarea>') %></textarea>
              <textarea class="template-hidden-field" id="<%= key %>_placeholders_hidden"><%- JSON.stringify(placeholders || []) %></textarea>
            </section>
          <% } %>
        </div>

      </form>
    </main>
  </div>

  <div class="tm-modal-backdrop" id="templateModalBackdrop" onclick="closeTemplateModal(event)">
    <div class="tm-modal" onclick="event.stopPropagation()">
      <div class="tm-modal-head">
        <div>
          <h3 class="tm-modal-title" id="modalTemplateTitle">Template bearbeiten</h3>
          <p class="tm-modal-subtitle" id="modalTemplateSubtitle"></p>
        </div>
        <button class="tm-modal-close" type="button" onclick="closeTemplateModal()">&times;</button>
      </div>
      <div class="tm-modal-body">
        <div class="template-field">
          <label for="modalTemplateSubject">Betreff</label>
          <input class="template-subject" id="modalTemplateSubject" type="text" placeholder="Betreff">
        </div>

        <div class="toolbar" style="margin-bottom:0.72rem;">
          <button type="button" id="modalLoadDefaultBtn"><i class="fa-regular fa-star"></i> Profi-Standard laden</button>
          <span class="toolbar-meta"><i class="fa-solid fa-wand-magic-sparkles"></i> lädt das neue Propus-Layout für dieses Template</span>
        </div>

        <div class="tab-row">
          <button class="tab-btn active" type="button" data-modal-tab="html">HTML</button>
          <button class="tab-btn" type="button" data-modal-tab="text">Text</button>
          <button class="tab-btn" type="button" data-modal-tab="preview_html">HTML-Vorschau</button>
          <button class="tab-btn" type="button" data-modal-tab="preview_text">Text-Vorschau</button>
        </div>

        <div class="editor-pane active" data-modal-pane="html">
          <div class="toolbar">
            <button type="button" data-editor-action="wrap" data-editor-target="html" data-before="<p>" data-after="</p>">Absatz</button>
            <button type="button" data-editor-action="wrap" data-editor-target="html" data-before="<strong>" data-after="</strong>">Fett</button>
            <button type="button" data-editor-action="wrap" data-editor-target="html" data-before="<em>" data-after="</em>">Kursiv</button>
            <button type="button" data-editor-action="insert" data-editor-target="html" data-value="<br>">Zeilenumbruch</button>
            <button type="button" data-editor-action="insert" data-editor-target="html" data-value="<div style=&quot;height:1px;background:#ece5d7;margin:18px 0;&quot;></div>">Trenner</button>
            <button type="button" data-editor-action="insert" data-editor-target="html" data-value="<div style=&quot;background:#faf7f1;border:1px solid #ece5d7;border-radius:16px;padding:16px 18px;&quot;><strong>Info</strong><br>Text hier…</div>">Info-Box</button>
            <button type="button" data-editor-action="insert" data-editor-target="html" data-value="<a href=&quot;https://...&quot;>Link</a>">Link</button>
            <button type="button" data-editor-action="insert" data-editor-target="html" data-value="<a href=&quot;{{yesUrl}}&quot; style=&quot;display:inline-block;padding:10px 16px;background:#967530;color:#fff;text-decoration:none;border-radius:8px;font-weight:600;&quot;>Button</a>">Button</button>
          </div>
          <textarea class="template-editor" id="modalTemplateHtml"></textarea>
        </div>

        <div class="editor-pane" data-modal-pane="text">
          <div class="toolbar">
            <button type="button" data-editor-action="insert" data-editor-target="text" data-value="\n\n">Absatz</button>
            <button type="button" data-editor-action="insert" data-editor-target="text" data-value="---\n">Trenner</button>
            <button type="button" data-editor-action="insert" data-editor-target="text" data-value="• ">Bullet</button>
          </div>
          <textarea class="template-editor" id="modalTemplateText"></textarea>
        </div>

        <div class="editor-pane" data-modal-pane="preview_html">
          <div class="preview-shell">
            <div class="preview-topbar">
              <div>
                <p class="preview-title">HTML-E-Mail live</p>
                <p class="preview-subtitle">Desktop-Vorschau mit eingebetteter E-Mail-Ansicht</p>
              </div>
              <div class="preview-device"><i class="fa-regular fa-envelope"></i> 720 px Layout</div>
            </div>
            <div class="preview-stage">
              <iframe id="modalPreviewHtmlFrame" class="preview-iframe" title="HTML-E-Mail-Vorschau"></iframe>
            </div>
          </div>
        </div>

        <div class="editor-pane" data-modal-pane="preview_text">
          <div class="preview-wrap preview-text" id="modalPreviewText"></div>
        </div>

        <p class="placeholders-hint" id="modalPlaceholders"></p>
      </div>
      <div class="tm-modal-foot">
        <button class="btn btn-ghost" type="button" onclick="closeTemplateModal()">Abbrechen</button>
        <button class="btn btn-primary" type="button" id="modalApplyBtn">Speichern</button>
      </div>
    </div>
  </div>

  <script>
    const templateModalBackdrop = document.getElementById('templateModalBackdrop');
    const modalTitle = document.getElementById('modalTemplateTitle');
    const modalSubtitle = document.getElementById('modalTemplateSubtitle');
    const modalSubject = document.getElementById('modalTemplateSubject');
    const modalHtml = document.getElementById('modalTemplateHtml');
    const modalText = document.getElementById('modalTemplateText');
    const modalPreviewHtmlFrame = document.getElementById('modalPreviewHtmlFrame');
    const modalPreviewText = document.getElementById('modalPreviewText');
    const modalPlaceholders = document.getElementById('modalPlaceholders');
    const modalApplyBtn = document.getElementById('modalApplyBtn');
    const modalLoadDefaultBtn = document.getElementById('modalLoadDefaultBtn');
    const templatesForm = document.getElementById('templatesForm');
    const modalTabButtons = Array.from(document.querySelectorAll('[data-modal-tab]'));
    const modalPanes = Array.from(document.querySelectorAll('[data-modal-pane]'));
    let activeTemplateKey = null;

    function getHiddenField(key, field) {
      return document.getElementById(`${key}_${field}_hidden`);
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getDefaultField(key, field) {
      return document.getElementById(`${key}_${field}_default`);
    }

    function buildPreviewContext(placeholders) {
      const context = {
        objectLabel: 'Sädlenweg 6, 8055 Zürich',
        customerGreeting: 'Guten Tag Frau Muster,',
        tourLinkHtml: '<strong>Virtueller Rundgang:</strong> <a href="https://my.matterport.com/show/?m=FxL1yXMDTBD" style="color:#8c6d2b;">Matterport-Tour öffnen</a><br>',
        tourLinkText: 'Virtueller Rundgang: https://my.matterport.com/show/?m=FxL1yXMDTBD',
        termEndFormatted: '10. April 2026',
        portalUrl: 'https://tour.propus.ch/portal',
        portalLinkHtml: '<a href="https://tour.propus.ch/portal" style="color:#8c6d2b;font-weight:700;">Kundenportal öffnen</a>',
        portalLinkText: 'Kundenportal: https://tour.propus.ch/portal',
        createdAt: '10. Oktober 2025',
        amount: '59.00',
        yesUrl: 'https://tour.propus.ch/action/yes-demo',
        noUrl: 'https://tour.propus.ch/action/no-demo',
        inviteLink: 'https://tour.propus.ch/accept-invite?token=demo-token',
        invitedByEmail: 'admin@propus.ch',
        appName: 'Propus Tour Manager',
      };
      (placeholders || []).forEach((key) => {
        if (!(key in context)) context[key] = `{{${key}}}`;
      });
      return context;
    }

    function renderTemplateString(template, context, { htmlMode = false } = {}) {
      const safeKeys = new Set(['tourLinkHtml', 'portalLinkHtml']);
      return String(template || '').replace(/\{\{(\w+)\}\}/g, (_, key) => {
        const value = context[key];
        if (value === undefined || value === null) return '';
        if (htmlMode && safeKeys.has(key)) return String(value);
        return htmlMode ? escapeHtml(String(value)) : String(value);
      });
    }

    function buildPreviewDocument(subject, html) {
      const trimmed = String(html || '').trim();
      if (/<!doctype html/i.test(trimmed) || /<html[\s>]/i.test(trimmed)) {
        return trimmed;
      }
      return `<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; background: #f5f1e8; font-family: Arial, sans-serif; color: #1f2937; }
    .preview-page { padding: 24px; }
    .preview-header {
      max-width: 720px; margin: 0 auto 14px; display: flex; justify-content: space-between; gap: 12px;
      align-items: center; color: #7c6c48; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase;
    }
    .preview-header strong { color: #1f2937; font-size: 13px; letter-spacing: 0; text-transform: none; }
    .preview-mail { max-width: 720px; margin: 0 auto; background: #fff; border: 1px solid #dfd6c6; border-radius: 22px; overflow: hidden; box-shadow: 0 18px 50px rgba(20,19,17,0.08); }
    .preview-subject { padding: 16px 22px; border-bottom: 1px solid #ece5d7; background: linear-gradient(180deg, #fffdfa 0%, #f8f4ea 100%); }
    .preview-subject-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a7550; margin-bottom: 6px; }
    .preview-subject-value { font-size: 18px; line-height: 1.4; color: #111827; font-weight: 700; }
  </style>
</head>
<body>
  <div class="preview-page">
    <div class="preview-header">
      <span>Propus Vorschau</span>
      <strong>${escapeHtml(subject || 'Ohne Betreff')}</strong>
    </div>
    <div class="preview-mail">
      <div class="preview-subject">
        <div class="preview-subject-label">Betreff</div>
        <div class="preview-subject-value">${escapeHtml(subject || 'Ohne Betreff')}</div>
      </div>
      ${html || '<div style="padding:28px;color:#6b7280;">Keine HTML-Vorschau vorhanden.</div>'}
    </div>
  </div>
</body>
</html>`;
    }

    function updatePreview() {
      const placeholders = activeTemplateKey ? parsePlaceholders(activeTemplateKey) : [];
      const context = buildPreviewContext(placeholders);
      const renderedSubject = renderTemplateString(modalSubject.value, context);
      const renderedHtml = renderTemplateString(modalHtml.value, context, { htmlMode: true });
      if (modalPreviewHtmlFrame) {
        modalPreviewHtmlFrame.srcdoc = buildPreviewDocument(renderedSubject, renderedHtml);
      }
      modalPreviewText.textContent = renderTemplateString(modalText.value, context) || 'Keine Text-Vorschau vorhanden.';
    }

    function setModalTab(tabName) {
      modalTabButtons.forEach((btn) => btn.classList.toggle('active', btn.dataset.modalTab === tabName));
      modalPanes.forEach((pane) => pane.classList.toggle('active', pane.dataset.modalPane === tabName));
      updatePreview();
    }

    function insertAtSelection(textarea, before, after = '') {
      if (!textarea) return;
      const start = textarea.selectionStart || 0;
      const end = textarea.selectionEnd || 0;
      const selected = textarea.value.slice(start, end);
      const replacement = `${before}${selected}${after}`;
      textarea.value = `${textarea.value.slice(0, start)}${replacement}${textarea.value.slice(end)}`;
      textarea.focus();
      textarea.selectionStart = start + before.length;
      textarea.selectionEnd = start + before.length + selected.length;
      updatePreview();
    }

    function parsePlaceholders(key) {
      try {
        const raw = document.getElementById(`${key}_placeholders_hidden`)?.value || '[]';
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch (_) {
        return [];
      }
    }

    function writeModalToHidden() {
      if (!activeTemplateKey) return;
      const subjectField = getHiddenField(activeTemplateKey, 'subject');
      const htmlField = getHiddenField(activeTemplateKey, 'html');
      const textField = getHiddenField(activeTemplateKey, 'text');
      if (subjectField) subjectField.value = modalSubject.value;
      if (htmlField) htmlField.value = modalHtml.value;
      if (textField) textField.value = modalText.value;
      const changedBadge = document.getElementById(`${activeTemplateKey}_updated`);
      if (changedBadge) changedBadge.classList.add('show');
    }

    function openTemplateModal(key) {
      const row = document.querySelector(`[data-template-row="${key}"]`);
      if (!row) return;
      activeTemplateKey = key;
      modalTitle.textContent = row.dataset.templateName || key;
      modalSubtitle.textContent = row.dataset.templateDesc || 'Vorlage bearbeiten';
      modalSubject.value = getHiddenField(key, 'subject')?.value || '';
      modalHtml.value = getHiddenField(key, 'html')?.value || '';
      modalText.value = getHiddenField(key, 'text')?.value || '';

      const placeholders = parsePlaceholders(key);
      if (placeholders.length) {
        modalPlaceholders.innerHTML = `Platzhalter: ${placeholders.map((p) => `<code data-placeholder="{{${p}}}">{{${p}}}</code>`).join('')}`;
      } else {
        modalPlaceholders.textContent = '';
      }

      setModalTab('html');
      templateModalBackdrop.classList.add('open');
    }

    function loadProfessionalDefaults() {
      if (!activeTemplateKey) return;
      modalSubject.value = getDefaultField(activeTemplateKey, 'subject')?.value || modalSubject.value;
      modalHtml.value = getDefaultField(activeTemplateKey, 'html')?.value || modalHtml.value;
      modalText.value = getDefaultField(activeTemplateKey, 'text')?.value || modalText.value;
      updatePreview();
      setModalTab('preview_html');
    }

    function closeTemplateModal(event) {
      if (event && event.target && event.target.id !== 'templateModalBackdrop') return;
      templateModalBackdrop.classList.remove('open');
      activeTemplateKey = null;
    }

    document.querySelectorAll('[data-edit-template]').forEach((button) => {
      button.addEventListener('click', () => openTemplateModal(button.dataset.editTemplate));
    });

    modalTabButtons.forEach((btn) => {
      btn.addEventListener('click', () => setModalTab(btn.dataset.modalTab));
    });

    document.querySelectorAll('[data-editor-action]').forEach((button) => {
      button.addEventListener('click', () => {
        const target = button.dataset.editorTarget === 'text' ? modalText : modalHtml;
        if (button.dataset.editorAction === 'wrap') {
          insertAtSelection(target, button.dataset.before || '', button.dataset.after || '');
        } else {
          insertAtSelection(target, button.dataset.value || '');
        }
      });
    });

    modalPlaceholders.addEventListener('click', (event) => {
      const code = event.target.closest('code[data-placeholder]');
      if (!code) return;
      const activePane = document.querySelector('.editor-pane.active');
      const target = activePane && activePane.dataset.modalPane === 'text' ? modalText : modalHtml;
      insertAtSelection(target, code.dataset.placeholder || '');
    });

    modalSubject.addEventListener('input', updatePreview);
    modalHtml.addEventListener('input', updatePreview);
    modalText.addEventListener('input', updatePreview);

    modalApplyBtn.addEventListener('click', () => {
      writeModalToHidden();
      closeTemplateModal();
      if (templatesForm) templatesForm.submit();
    });

    if (modalLoadDefaultBtn) {
      modalLoadDefaultBtn.addEventListener('click', loadProfessionalDefaults);
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeTemplateModal();
    });
  </script>
</body>
</html>
