    font-size: 0.74rem;
  }
  .sidebar-ai-action-meta {
    width: 100%;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: -0.1rem;
  }
  .sidebar-ai-actions .btn { font-size:0.76rem; padding:0.32rem 0.7rem; }
  .sidebar-ai-input-wrap { margin-top: 0.45rem; display:flex; flex-direction:column; gap:0.35rem; }
  .sidebar-ai-input-wrap textarea {
    width: 100%;
    resize: none;
    min-height: 90px;
    max-height: 220px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    border-radius: 8px;
    padding: 0.4rem 0.5rem;
    font-size: 0.78rem;
    font-family: inherit;
  }
</style>
<script>
(() => {
  const STORAGE_KEY = 'sidebarAiStateV2';
  const DEFAULT_GREETING = 'Frag mich etwas zu Touren, Rechnungen, Kundenmails, Matterport oder Exxas. Ich nutze DB + Live-Daten aus Matterport, Exxas und Exchange, wenn verfuegbar.';
  let history = [];
  let persistedMessages = [];
  let pendingAction = null;
  const panel = document.getElementById('sidebarAiPanel');
  const msgWrap = document.getElementById('sidebarAiMessages');
  const input = document.getElementById('sidebarAiInput');
  const sendBtn = document.getElementById('sidebarAiSend');
  const modelSel = document.getElementById('sidebarAiModel');
  const toggleBtn = document.getElementById('sidebarAiToggle');
  const overlay = document.getElementById('sidebarAiOverlay');
  if (!panel || !msgWrap || !input || !sendBtn || !modelSel || !overlay) return;

  function saveState() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        history: history.slice(-20),
        messages: persistedMessages.slice(-30),
        pendingAction,
        panelOpen: panel.classList.contains('open'),
        model: modelSel.value,
      }));
    } catch (e) {}
  }

  function restoreState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  try {
    const savedHeight = localStorage.getItem('sidebarAiMessagesHeight');
    if (savedHeight) {
      msgWrap.style.height = savedHeight;
    }
  } catch (e) {}

  let resizeSaveTimer = null;
  const saveMessageHeight = () => {
    try {
      localStorage.setItem('sidebarAiMessagesHeight', `${msgWrap.offsetHeight}px`);
    } catch (e) {}
  };
  if (typeof ResizeObserver !== 'undefined') {
    const observer = new ResizeObserver(() => {
      clearTimeout(resizeSaveTimer);
      resizeSaveTimer = setTimeout(saveMessageHeight, 120);
    });
    observer.observe(msgWrap);
  }

  function renderMessages() {
    msgWrap.innerHTML = '';
    const messages = persistedMessages.length ? persistedMessages : [{ role: 'ai', text: DEFAULT_GREETING }];
    messages.forEach((entry) => {
      const div = document.createElement('div');
      div.className = `sidebar-ai-msg ${entry.role}`;
      div.textContent = entry.text;
      msgWrap.appendChild(div);
    });
    msgWrap.scrollTop = msgWrap.scrollHeight;
  }

  function hydrateFromStorage() {
    const state = restoreState();
    if (!state) {
      persistedMessages = [{ role: 'ai', text: DEFAULT_GREETING }];
      renderMessages();
      return;
    }
    history = Array.isArray(state.history) ? state.history : [];
    persistedMessages = Array.isArray(state.messages) && state.messages.length
      ? state.messages
      : [{ role: 'ai', text: DEFAULT_GREETING }];
    pendingAction = state.pendingAction || null;
    if (state.model) modelSel.value = state.model;
    if (state.panelOpen) openSidebarAiChat(false);
    renderMessages();
    if (pendingAction) addActionControls(pendingAction);
  }

  window.openSidebarAiChat = function(shouldFocus = true) {
    panel.classList.add('open');
    overlay.classList.add('open');
    if (toggleBtn) toggleBtn.classList.add('active');
    document.body.style.overflow = 'hidden';
    saveState();
    if (shouldFocus) input.focus();
  };

  window.closeSidebarAiChat = function() {
    panel.classList.remove('open');
    overlay.classList.remove('open');
    if (toggleBtn) toggleBtn.classList.remove('active');
    document.body.style.overflow = '';
    saveState();
  };

  window.toggleSidebarAiChat = function(event) {
    if (event && typeof event.preventDefault === 'function') event.preventDefault();
    if (panel.classList.contains('open')) {
      closeSidebarAiChat();
      return;
    }
    openSidebarAiChat(true);
  };

  function addMsg(role, text, persist = true) {
    const div = document.createElement('div');
    div.className = `sidebar-ai-msg ${role}`;
    div.textContent = text;
    msgWrap.appendChild(div);
    msgWrap.scrollTop = msgWrap.scrollHeight;
    if (persist) {
      persistedMessages.push({ role, text });
      saveState();
    }
    return div;
  }

  function clearActionControls() {
    msgWrap.querySelectorAll('.sidebar-ai-actions').forEach((el) => el.remove());
  }

  function addActionControls(action) {
    clearActionControls();
    const label = action?.label || action?.labelShort || action?.type || 'Aktion zur Ausführung bereit';
    const riskText = action?.riskLabel ? `Risiko: ${action.riskLabel}` : null;
    const confirmText = action?.needsConfirmation === false ? 'ohne Bestätigung' : 'Bestätigung erforderlich';
    const wrap = document.createElement('div');
    wrap.className = 'sidebar-ai-actions';
    wrap.innerHTML = `
      <div class="sidebar-ai-action-card">${label || 'Aktion zur Ausführung bereit'}</div>
      <div class="sidebar-ai-action-meta">${[riskText, confirmText].filter(Boolean).join(' · ')}</div>
      <button type="button" class="btn btn-primary" id="sidebarAiConfirmBtn">Ausführen</button>
      <button type="button" class="btn btn-ghost" id="sidebarAiCancelBtn">Abbrechen</button>
    `;
    msgWrap.appendChild(wrap);
    msgWrap.scrollTop = msgWrap.scrollHeight;
    document.getElementById('sidebarAiConfirmBtn').addEventListener('click', confirmSidebarAiAction);
    document.getElementById('sidebarAiCancelBtn').addEventListener('click', cancelSidebarAiAction);
  }

  async function confirmSidebarAiAction() {
    if (!pendingAction) return;
    clearActionControls();
    const loading = addMsg('ai', 'Führe Aktion aus...', false);
    try {
      const response = await fetch('/admin/chat-assistant/confirm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({}),
      });
      const data = await response.json();
      if (!response.ok || data.error) {
        loading.textContent = `Fehler: ${data.error || 'Unbekannt'}`;
        persistedMessages.push({ role: 'ai', text: loading.textContent });
      } else {
        loading.textContent = data.answer || 'Aktion ausgeführt.';
        history.push({ role: 'assistant', content: data.answer || 'Aktion ausgeführt.' });
        persistedMessages.push({ role: 'ai', text: loading.textContent });
      }
    } catch (err) {
      loading.textContent = `Fehler: ${err.message}`;
      persistedMessages.push({ role: 'ai', text: loading.textContent });
    }
    pendingAction = null;
    saveState();
  }

  async function cancelSidebarAiAction() {
    if (!pendingAction) return;
    clearActionControls();
    try {
      await fetch('/admin/chat-assistant/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({}),
      });
    } catch (err) {}
    addMsg('ai', 'Aktion verworfen.');
    pendingAction = null;
    saveState();
  }

  window.sendSidebarAiChat = async function() {
    const message = (input.value || '').trim();
    if (!message) return;
    input.value = '';
    input.disabled = true;
    sendBtn.disabled = true;
    modelSel.disabled = true;

    addMsg('user', message);
    history.push({ role: 'user', content: message });
    clearActionControls();
    const loading = addMsg('ai', 'Denke nach...', false);

    try {
      const response = await fetch('/admin/chat-assistant', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message,
          model: modelSel.value,
          history: history.slice(0, -1),
          activePage: '<%= typeof activePage !== "undefined" ? activePage : "" %>',
          path: window.location.pathname + window.location.search,
        }),
      });
      const data = await response.json();
      if (!response.ok || data.error) {
        loading.textContent = `Fehler: ${data.error || 'Unbekannt'}`;
        history.pop();
        persistedMessages.push({ role: 'ai', text: loading.textContent });
      } else {
        loading.textContent = data.answer || '(Keine Antwort)';
        history.push({ role: 'assistant', content: data.answer || '' });
        persistedMessages.push({ role: 'ai', text: loading.textContent });
        if (data.needsConfirmation && data.proposedAction) {
          pendingAction = data.proposedAction;
          addActionControls(data.proposedAction);
        } else {
          pendingAction = null;
        }
      }
    } catch (err) {
      loading.textContent = `Fehler: ${err.message}`;
      history.pop();
      persistedMessages.push({ role: 'ai', text: loading.textContent });
    }

    input.disabled = false;
    sendBtn.disabled = false;
    modelSel.disabled = false;
    saveState();
    input.focus();
  };

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel.classList.contains('open')) {
      e.preventDefault();
      closeSidebarAiChat();
      return;
    }
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendSidebarAiChat();
    }
  });

  hydrateFromStorage();
})();
</script>

<script>
(function() {
  const panel = document.getElementById('customerSearchPanel');
  const overlay = document.getElementById('customerSearchOverlay');
  const toggle = document.getElementById('customerViewToggle');

  function isOpen() {
    return panel && panel.style.transform === 'translateX(0%)';
  }
  function openPanel() {
    if (!panel || !overlay) return;
    overlay.style.display = 'block';
    panel.style.transform = 'translateX(0%)';
    if (toggle) toggle.classList.add('active');
  }
  window.closeCustomerSearchPanel = function() {
    if (!panel || !overlay) return;
    panel.style.transform = 'translateX(100%)';
    overlay.style.display = 'none';
    if (toggle) toggle.classList.remove('active');
  };

  window.toggleCustomerSearch = function(e) {
    e.preventDefault();
    const inp = document.getElementById('customerSearchInput');
    if (!isOpen()) {
      openPanel();
      setTimeout(() => inp && inp.focus(), 80);
    } else {
      window.closeCustomerSearchPanel();
    }
  };

  if (overlay) {
    overlay.addEventListener('click', () => window.closeCustomerSearchPanel());
  }

  document.addEventListener('DOMContentLoaded', function() {
    const inp  = document.getElementById('customerSearchInput');
    const drop = document.getElementById('customerSearchDropdown');
    if (!inp || !drop) return;

    function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    let timer = null;
    inp.addEventListener('input', function() {
      clearTimeout(timer);
      const q = inp.value.trim();
      if (q.length < 2) { drop.style.display = 'none'; return; }
      timer = setTimeout(async function() {
        try {
          const r = await fetch('/admin/customers/search?q=' + encodeURIComponent(q));
          const items = await r.json();
          if (!items.length) {
            drop.innerHTML = '<div style="padding:0.6rem 0.75rem;color:var(--text-muted);font-size:0.82rem;">Keine Treffer</div>';
          } else {
            drop.innerHTML = items.map(c => `
              <a href="/admin/impersonate?email=${encodeURIComponent(c.email)}"
                 style="display:block;padding:0.5rem 0.75rem;text-decoration:none;color:var(--text);
                        font-size:0.82rem;border-bottom:1px solid var(--border);"
                 onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background=''">
                <div style="font-weight:600;">${esc(c.name !== c.email ? c.name : '')}</div>
                <div style="color:var(--text-muted);font-size:0.78rem;">${esc(c.email)}
                  <span style="margin-left:0.4rem;background:rgba(99,102,241,0.2);color:#a5b4fc;
                         border-radius:999px;padding:0.05rem 0.4rem;font-size:0.72rem;">${c.count} Tour${c.count !== 1 ? 'en' : ''}</span>
                </div>
              </a>`).join('');
          }
          drop.style.display = 'block';
        } catch(e) { drop.style.display = 'none'; }
      }, 200);
    });

    document.addEventListener('click', function(e) {
      if (!e.target.closest('#customerSearchPanel')) drop.style.display = 'none';
    });

    inp.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (drop.style.display === 'none') {
          window.closeCustomerSearchPanel();
        } else {
          drop.style.display = 'none';
        }
        inp.blur();
      }
    });
  });
})();
</script>
