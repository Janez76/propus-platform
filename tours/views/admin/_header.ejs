<aside id="customerSearchPanel" style="
  position:fixed;top:0;right:0;bottom:0;width:min(420px,100vw);
  background:var(--bg-card,#16161a);border-left:1px solid var(--border);
  box-shadow:-8px 0 32px rgba(0,0,0,0.5);z-index:1100;
  transform:translateX(100%);transition:transform 0.24s ease;
  display:flex;flex-direction:column;overflow:hidden;">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.1rem;border-bottom:1px solid var(--border);">
    <div style="font-weight:700;font-size:0.95rem;">Kunden-Portal</div>
    <button type="button" onclick="closeCustomerSearchPanel()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.25rem;line-height:1;padding:0.1rem 0.3rem;">✕</button>
  </div>
  <div style="padding:1rem;position:relative;">
    <input type="text" id="customerSearchInput" placeholder="E-Mail oder Name…"
      autocomplete="off" spellcheck="false"
      style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:10px;
             padding:0.6rem 0.75rem;color:var(--text);font-size:0.88rem;box-sizing:border-box;">
    <div id="customerSearchDropdown" style="display:none;position:absolute;left:1rem;right:1rem;top:calc(1rem + 46px);
         background:var(--bg-card);border:1px solid var(--border);border-radius:10px;
         box-shadow:0 8px 24px rgba(0,0,0,0.4);z-index:2;max-height:300px;overflow-y:auto;"></div>
  </div>
</aside>

<script>
(function() {
  const input = document.getElementById('globalSearch');
  const dropdown = document.getElementById('globalSearchDropdown');
  const clearBtn = document.getElementById('globalSearchClear');
  if (!input || !dropdown) return;

  const STATUS_LABELS = {
    ACTIVE: 'Aktiv', EXPIRING_SOON: 'Läuft bald ab',
    CUSTOMER_ACCEPTED_AWAITING_PAYMENT: 'Wartet auf Zahlung',
    CUSTOMER_DECLINED: 'Keine Verlängerung', ARCHIVED: 'Archiviert',
    AWAITING_CUSTOMER_DECISION: 'Wartet auf Kunde',
    EXPIRED_PENDING_ARCHIVE: 'Abgelaufen',
  };
  const TYPE_LABELS = { tour: 'Tour', invoice: 'Rechnung' };

  let timer = null;
  let activeIdx = -1;
  let lastResults = [];

  function renderResults(results) {
    lastResults = results;
    activeIdx = -1;
    if (!results.length) {
      dropdown.innerHTML = '<div class="gs-empty">Keine Treffer</div>';
      dropdown.style.display = 'block';
      return;
    }
    dropdown.innerHTML = results.map((r, i) => `
      <a href="${r.url}" class="gs-item" data-idx="${i}">
        <span class="gs-badge gs-badge-${r.type}">${TYPE_LABELS[r.type] || r.type}</span>
        <span class="gs-content">
          <span class="gs-title">${esc(r.title)}</span>
          ${r.sub ? `<span class="gs-sub">${esc(r.sub)}</span>` : ''}
        </span>
        ${r.status ? `<span class="gs-status">${STATUS_LABELS[r.status] || r.status}</span>` : ''}
      </a>`).join('');
    dropdown.style.display = 'block';
  }

  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function close() {
    dropdown.style.display = 'none';
    activeIdx = -1;
  }
  function updateClearVisibility() {
    if (!clearBtn) return;
    clearBtn.style.display = input.value.trim() ? 'flex' : 'none';
  }

  function setActive(idx) {
    const items = dropdown.querySelectorAll('.gs-item');
    items.forEach((el, i) => el.classList.toggle('gs-active', i === idx));
    activeIdx = idx;
  }

  input.addEventListener('input', () => {
    clearTimeout(timer);
    const q = input.value.trim();
    updateClearVisibility();
    if (q.length < 2) { close(); return; }
    timer = setTimeout(async () => {
      try {
        const resp = await fetch('/admin/search?q=' + encodeURIComponent(q));
        const data = await resp.json();
        renderResults(data);
      } catch(e) { close(); }
    }, 180);
  });

  input.addEventListener('keydown', (e) => {
    const items = dropdown.querySelectorAll('.gs-item');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, items.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIdx - 1, 0));
    } else if (e.key === 'Enter') {
      if (activeIdx >= 0 && items[activeIdx]) {
        window.location.href = items[activeIdx].href;
      }
    } else if (e.key === 'Escape') {
      close();
      input.blur();
    }
  });

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.global-search-wrap')) close();
  });

  input.addEventListener('focus', () => {
    if (lastResults.length) dropdown.style.display = 'block';
    updateClearVisibility();
  });

  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      input.value = '';
      updateClearVisibility();
      close();
      input.focus();
    });
  }
})();
</script>

<%/* ===== GLOBALES DETAIL-PANEL ===== */%>
<div id="detailPanel" style="
  position:fixed;top:0;right:0;bottom:0;width:min(520px,100vw);
  background:var(--bg-card,#16161a);border-left:1px solid var(--border);
  box-shadow:-8px 0 32px rgba(0,0,0,0.5);z-index:1000;
  transform:translateX(100%);transition:transform 0.26s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;overflow:hidden;">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border);flex-shrink:0;">
    <span id="panelTitle" style="font-weight:700;font-size:1rem;">Details</span>
    <div style="display:flex;gap:0.5rem;align-items:center;">
      <a id="panelOpenFull" href="#" target="_blank" style="font-size:0.8rem;color:var(--link);text-decoration:none;padding:0.25rem 0.5rem;border:1px solid var(--border);border-radius:6px;">↗ Vollansicht</a>
      <button onclick="closePanel()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.3rem;line-height:1;padding:0.1rem 0.3rem;">✕</button>
    </div>
  </div>
  <div id="panelBody" style="flex:1;overflow-y:auto;padding:1.25rem;"></div>
</div>
<div id="panelOverlay" onclick="closePanel()" style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:999;display:none;"></div>

<style>
  #detailPanel.open { transform: translateX(0); }
  .panel-section { margin-bottom:1.25rem; }
  .panel-section h3 { font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin:0 0 0.5rem 0; }
  .panel-kv { display:flex;justify-content:space-between;gap:0.5rem;padding:0.25rem 0;border-bottom:1px solid var(--border);font-size:0.875rem; }
  .panel-kv:last-child { border-bottom:none; }
  .panel-kv .pk { color:var(--text-muted); }
  .panel-kv .pv { font-weight:600;text-align:right; }
  .panel-mail-row { padding:0.4rem 0;border-bottom:1px solid var(--border);font-size:0.835rem; }
  .panel-mail-row:last-child { border-bottom:none; }
  .panel-mail-subj { font-weight:600;margin-bottom:0.1rem; }
  .panel-mail-meta { color:var(--text-muted);font-size:0.76rem; }
  .panel-mail-preview { color:var(--text-muted);font-size:0.77rem;margin-top:0.15rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%; }
  .panel-inv { display:flex;justify-content:space-between;align-items:center;gap:0.5rem;padding:0.3rem 0;border-bottom:1px solid var(--border);font-size:0.84rem; }
  .panel-inv:last-child { border-bottom:none; }
  .pinv-paid { color:#22c55e; }
  .pinv-open { color:#f59e0b; }
  .pinv-overdue { color:#ef4444; }
  .panel-badge { display:inline-block;padding:0.15rem 0.5rem;border-radius:5px;font-size:0.74rem;font-weight:600; }
  .panel-badge.pb-open { background:rgba(59,130,246,0.2);color:#60a5fa; }
  .panel-badge.pb-paid { background:rgba(34,197,94,0.2);color:#4ade80; }
  .panel-badge.pb-overdue { background:rgba(239,68,68,0.2);color:#f87171; }
  .panel-badge.pb-default { background:rgba(113,113,122,0.2);color:var(--text-muted); }
  .panel-days-ok { color:#22c55e; }
  .panel-days-warn { color:#f59e0b; }
  .panel-days-danger { color:#ef4444; }
  .panel-loading { display:flex;align-items:center;justify-content:center;height:120px;color:var(--text-muted);font-size:0.9rem; }
  .panel-actions { display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.75rem; }
</style>

<script>
(function() {
  const STATUS_LABELS = {
    ACTIVE:'Aktiv', EXPIRING_SOON:'Läuft bald ab',
    CUSTOMER_ACCEPTED_AWAITING_PAYMENT:'Wartet auf Zahlung',
    CUSTOMER_DECLINED:'Keine Verlängerung', ARCHIVED:'Archiviert',
    AWAITING_CUSTOMER_DECISION:'Wartet auf Kunde',
    EXPIRED_PENDING_ARCHIVE:'Abgelaufen',
  };
  const INTENT_LABELS = {
    renew_yes:'Will verlängern', renew_no:'Nicht verlängern',
    transfer_requested:'Transfer', billing_question:'Rechnungsfrage', unclear:'Unklar',
  };

  function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString('de-CH',{day:'2-digit',month:'2-digit',year:'numeric'}) : '-'; }
  function fmtDateTime(d) { return d ? new Date(d).toLocaleString('de-CH',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'}) : '-'; }

  window.openPanel = async function(tourId) {
    const panel = document.getElementById('detailPanel');
    const overlay = document.getElementById('panelOverlay');
    const body = document.getElementById('panelBody');
    const title = document.getElementById('panelTitle');
    const fullLink = document.getElementById('panelOpenFull');

    body.innerHTML = '<div class="panel-loading">Laden…</div>';
    title.textContent = 'Details';
    fullLink.href = `/admin/tours/${tourId}`;
    panel.classList.add('open');
    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';

    try {
      const resp = await fetch(`/admin/tours/${tourId}/panel`);
      const d = await resp.json();
      if (!resp.ok) {
        // Cloudflare/WAF kann XHR auf /panel blockieren (403 Challenge).
        // Dann sauber auf die normale Detailseite wechseln.
        window.location.href = `/admin/tours/${tourId}`;
        return;
      }

      title.textContent = d.tourName;
      fullLink.href = `/admin/tours/${d.id}`;

      const today = new Date();
      const daysLeft = d.daysUntilRenewal;
      const daysClass = daysLeft === null ? '' : (daysLeft < 0 ? 'panel-days-danger' : (daysLeft <= 30 ? 'panel-days-warn' : 'panel-days-ok'));
      const daysText = daysLeft === null ? '-' : (daysLeft < 0 ? `Abgelaufen vor ${Math.abs(daysLeft)} Tagen` : `Noch ${daysLeft} Tage`);

      let html = '';

      // Stammdaten
      html += `<div class="panel-section">
        <h3>Tour</h3>
        <div class="panel-kv"><span class="pk">Kunde</span><span class="pv">${esc(d.customerName||'-')}</span></div>
        ${d.customerEmail ? `<div class="panel-kv"><span class="pk">Kontakt</span><span class="pv">${esc(d.customerEmail)}</span></div>` : ''}
        <div class="panel-kv"><span class="pk">Status</span><span class="pv">${esc(STATUS_LABELS[d.status]||d.status)}</span></div>
        ${d.matterportCreatedAt ? `<div class="panel-kv"><span class="pk">Tour erstellt</span><span class="pv">${fmtDate(d.matterportCreatedAt)}</span></div>` : ''}
        ${d.termEndDate ? `<div class="panel-kv"><span class="pk">Aboende</span><span class="pv">${fmtDate(d.termEndDate)}</span></div>` : ''}
        <div class="panel-kv"><span class="pk">Verbleibend</span><span class="pv ${daysClass}">${daysText}</span></div>
        ${d.customerIntent ? `<div class="panel-kv"><span class="pk">Kundenabsicht</span><span class="pv">${esc(INTENT_LABELS[d.customerIntent]||d.customerIntent)}${d.customerIntentConfidence ? ` (${Math.round(d.customerIntentConfidence*100)}%)` : ''}</span></div>` : ''}
        ${d.matterportId ? `<div class="panel-kv"><span class="pk">Matterport</span><span class="pv"><a href="https://my.matterport.com/show/?m=${esc(d.matterportId)}" target="_blank" style="color:var(--link);">${esc(d.matterportId)}</a></span></div>` : ''}
      </div>`;

      // Aktionen
      html += `<div class="panel-actions">
        <a href="/admin/tours/${d.id}" class="btn btn-ghost" style="font-size:0.82rem;">Vollansicht</a>
        <button class="btn btn-ghost" style="font-size:0.82rem;" onclick="panelSendMail(${d.id})">Mail senden</button>
        <button class="btn btn-ghost" style="font-size:0.82rem;" onclick="panelCheckPayment(${d.id})">Zahlung prüfen</button>
      </div>`;

      // Exxas-Rechnungen
      if (d.exxasInvoices && d.exxasInvoices.length > 0) {
        html += `<div class="panel-section" style="margin-top:1rem;"><h3>Exxas-Rechnungen</h3>`;
        d.exxasInvoices.forEach(inv => {
          const cls = inv.statusClass === 'paid' ? 'pinv-paid' : (inv.statusClass === 'overdue' ? 'pinv-overdue' : 'pinv-open');
          html += `<div class="panel-inv">
            <span style="font-weight:600;">${esc(inv.nummer||'-')}</span>
            <span class="${cls}" style="font-size:0.82rem;">${esc(inv.statusText)}</span>
            ${inv.betrag ? `<span style="font-size:0.82rem;font-weight:600;">CHF ${esc(inv.betrag)}</span>` : ''}
          </div>`;
        });
        html += `</div>`;
      } else {
        html += `<div class="panel-section" style="margin-top:1rem;"><h3>Exxas-Rechnungen</h3><div style="color:var(--text-muted);font-size:0.84rem;">Keine Rechnungen gefunden.</div></div>`;
      }

      // Eingegangene Mails
      if (d.incomingEmails && d.incomingEmails.length > 0) {
        html += `<div class="panel-section"><h3>Eingegangene Mails</h3>`;
        d.incomingEmails.forEach(m => {
          html += `<div class="panel-mail-row">
            <div class="panel-mail-subj">${esc(m.subject||'(kein Betreff)')}</div>
            <div class="panel-mail-meta">${esc(m.from_name||m.from_email||'-')} · ${fmtDateTime(m.received_at)}</div>
            ${m.body_preview ? `<div class="panel-mail-preview">${esc((m.body_preview||'').slice(0,120))}</div>` : ''}
          </div>`;
        });
        html += `</div>`;
      }

      // Gesendete Mails
      if (d.outgoingEmails && d.outgoingEmails.length > 0) {
        html += `<div class="panel-section"><h3>Gesendete Mails</h3>`;
        d.outgoingEmails.forEach(m => {
          html += `<div class="panel-mail-row">
            <div class="panel-mail-subj">${esc(m.subject||m.template_key||'-')}</div>
            <div class="panel-mail-meta">An: ${esc(m.recipient_email||'-')} · ${fmtDateTime(m.sent_at)}</div>
          </div>`;
        });
        html += `</div>`;
      }

      body.innerHTML = html;
    } catch(e) {
      // Netzwerk-/WAF-Problem -> harter Fallback zur Vollansicht
      window.location.href = `/admin/tours/${tourId}`;
    }
  };

  window.openPanelSafe = function(tourId, evt) {
    if (evt && typeof evt.preventDefault === 'function') evt.preventDefault();
    if (typeof window.openPanel === 'function') {
      window.openPanel(tourId);
      return false;
    }
    window.location.href = `/admin/tours/${tourId}`;
    return false;
  };

  window.closePanel = function() {
    document.getElementById('detailPanel').classList.remove('open');
    document.getElementById('panelOverlay').style.display = 'none';
    document.body.style.overflow = '';
  };

  window.panelSendMail = function(id) {
    fetch('/api/tours/'+id+'/send-renewal-email', { method:'POST', credentials:'include' })
      .then(r=>r.json()).then(d=>{ if(typeof toast==='function') toast(d.yesUrl?'E-Mail gesendet':(d.error||'Fehler'), d.yesUrl?'success':'error'); }).catch(()=>{});
  };
  window.panelCheckPayment = function(id) {
    fetch('/api/tours/'+id+'/check-payment', { method:'POST', credentials:'include' })
      .then(r=>r.json()).then(()=>{ if(typeof toast==='function') toast('Prüfung durchgeführt'); }).catch(()=>{});
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
  });
})();
</script>
