    height: 30px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text-muted);
    cursor: pointer;
    font-size: 1.2rem;
    line-height: 1;
  }
  .sidebar-ai-close:hover { color: var(--text); border-color: var(--gold-300); }
  .sidebar-ai-head {
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:0.4rem;
    font-size:0.82rem;
    padding: 0 0.15rem 0.55rem;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-ai-head select {
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    border-radius: 6px;
    font-size: 0.76rem;
    padding: 0.2rem 0.35rem;
  }
  .sidebar-ai-help {
    margin-top: 0.45rem;
    font-size: 0.72rem;
    line-height: 1.45;
    color: var(--text-muted);
  }
  .sidebar-ai-help code { font-size: 0.71rem; }
  .sidebar-ai-messages {
    margin-top: 0.55rem;
    min-height: 320px;
    height: 58vh;
    max-height: none;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem;
    background: rgba(255,255,255,0.01);
  }
  .sidebar-ai-msg {
    font-size: 0.76rem;
    line-height: 1.45;
    border-radius: 8px;
    padding: 0.4rem 0.5rem;
    white-space: pre-wrap;
  }
  .sidebar-ai-msg.ai { background: var(--bg); border:1px solid var(--border); color: var(--text); }
  .sidebar-ai-msg.user { background: rgba(196,163,90,0.15); border:1px solid rgba(196,163,90,0.32); color: var(--text); }
  .sidebar-ai-actions { display:flex; gap:0.4rem; margin-top:0.4rem; flex-wrap:wrap; }
  .sidebar-ai-action-card {
    width: 100%;
    padding: 0.45rem 0.5rem;
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--text-muted);
