<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Neues Passwort – Propus Kundenportal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <style>
    :root {
      --white: #fff;
      --gray-400: #a09b92;
      --gray-500: #706b63;
      --gray-700: #3b3833;
      --gray-900: #141311;
      --gold-600: #967530;
      --gold-700: #7a5e26;
      --error-50: #fef3f2;
      --error-700: #b42318;
      --success-50: #ecfdf3;
      --success-700: #027a48;
      --border: #e8e6e1;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: #fafaf8;
      color: var(--gray-700);
      padding: 1.5rem;
    }
    .card {
      width: 100%;
      max-width: 460px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 2rem;
      box-shadow: 0 12px 28px rgba(20, 19, 17, 0.06);
    }
    .brand { text-align: center; margin-bottom: 1.5rem; }
    .brand img { height: 52px; width: auto; }
    h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.7rem;
      color: var(--gray-900);
      text-align: center;
      margin-bottom: 0.5rem;
    }
    .sub { color: var(--gray-500); text-align: center; line-height: 1.55; margin-bottom: 1.5rem; }
    .alert {
      padding: 0.8rem 0.9rem;
      border-radius: 10px;
      margin-bottom: 1rem;
      font-size: 0.88rem;
    }
    .alert-error { background: var(--error-50); color: var(--error-700); border: 1px solid #fee4e2; }
    .alert-success { background: var(--success-50); color: var(--success-700); border: 1px solid #abefc6; }
    label { display: block; margin-bottom: 0.35rem; color: var(--gray-500); font-size: 0.84rem; }
    input {
      width: 100%;
      padding: 0.78rem 0.95rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      font: inherit;
      margin-bottom: 1rem;
    }
    input:focus {
      outline: none;
      border-color: var(--gold-600);
      box-shadow: 0 0 0 3px rgba(176, 140, 62, 0.15);
    }
    button {
      width: 100%;
      border: 0;
      border-radius: 10px;
      padding: 0.82rem 1rem;
      background: var(--gold-600);
      color: #fff;
      font: inherit;
      font-weight: 600;
      cursor: pointer;
    }
    button:hover { background: var(--gold-700); }
    .meta {
      font-size: 0.82rem;
      color: var(--gray-400);
      margin-top: -0.5rem;
      margin-bottom: 1rem;
      text-align: center;
    }
    .back {
      margin-top: 1rem;
      text-align: center;
      font-size: 0.84rem;
    }
    .back a { color: var(--gold-600); text-decoration: none; font-weight: 600; }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">
      <img src="https://propus.ch/wp-content/uploads/2024/06/Asset-2-2.png" alt="Propus">
    </div>
    <h1>Neues Passwort</h1>
    <p class="sub">Setzen Sie ein neues Passwort für Ihr Kundenportal-Konto.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (isValid) { %>
      <% if (email) { %><div class="meta"><%= email %></div><% } %>
      <form method="post" action="/portal/reset-password">
        <input type="hidden" name="token" value="<%= token %>">
        <label for="password">Neues Passwort</label>
        <input type="password" id="password" name="password" minlength="8" required autocomplete="new-password">

        <label for="passwordRepeat">Neues Passwort wiederholen</label>
        <input type="password" id="passwordRepeat" name="passwordRepeat" minlength="8" required autocomplete="new-password">

        <button type="submit">Passwort speichern</button>
      </form>
    <% } else { %>
      <div class="back">
        <a href="/portal/forgot-password">Neuen Link anfordern</a>
      </div>
    <% } %>

    <div class="back">
      <a href="/portal/login">Zurück zum Login</a>
    </div>
  </div>
</body>
</html>
