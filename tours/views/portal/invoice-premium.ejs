<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rechnung <%= invLabel %> – Propus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-dark: #111827;
            --brand-gray: #6B7280;
            --brand-accent: #005A70;
            --brand-accent-soft: #F0F7F9;
            --status-pending-bg: #FFFBEB;
            --status-pending-text: #92400E;
            --status-paid-bg: #ECFDF5;
            --status-paid-text: #047857;
            --status-overdue-bg: #FEF2F2;
            --status-overdue-text: #B91C1C;
            --status-draft-bg: #F3F4F6;
            --status-draft-text: #6B7280;
            --status-cancelled-bg: #FEE2E2;
            --status-cancelled-text: #991B1B;
            --page-width: 210mm;
            --page-height: 297mm;
            --margin-outer: 20mm;
            --border-radius: 4px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        body {
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            color: var(--brand-dark);
            background-color: #F3F4F6;
            line-height: 1.5;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 24px;
            min-height: 100vh;
        }

        .invoice-card {
            background: #ffffff;
            width: var(--page-width);
            min-height: var(--page-height);
            padding: var(--margin-outer);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
            position: relative;
            display: flex;
            flex-direction: column;
        }

        @media print {
            body { background: none; padding: 0; }
            .invoice-card {
                width: 100%;
                min-height: auto;
                box-shadow: none;
                margin: 0;
                padding: 15mm;
            }
            .no-print { display: none !important; }
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 70px;
        }

        .logo-block h1 {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -1.5px;
            text-transform: lowercase;
            color: var(--brand-dark);
            margin-bottom: 5px;
        }

        .logo-block h1 span {
            color: var(--brand-accent);
        }

        .company-contact {
            font-size: 11px;
            color: var(--brand-gray);
            line-height: 1.5;
        }

        .invoice-meta-top {
            text-align: right;
        }

        .invoice-label {
            font-size: 24px;
            font-weight: 500;
            margin-bottom: 10px;
            letter-spacing: -0.5px;
            color: var(--brand-dark);
        }

        .status-pill {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-pill.sent { background-color: var(--status-pending-bg); color: var(--status-pending-text); }
        .status-pill.paid { background-color: var(--status-paid-bg); color: var(--status-paid-text); }
        .status-pill.overdue { background-color: var(--status-overdue-bg); color: var(--status-overdue-text); }
        .status-pill.draft { background-color: var(--status-draft-bg); color: var(--status-draft-text); }
        .status-pill.cancelled { background-color: var(--status-cancelled-bg); color: var(--status-cancelled-text); }

        .info-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            margin-bottom: 60px;
        }

        .section-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--brand-gray);
            letter-spacing: 1px;
            margin-bottom: 15px;
            display: block;
        }

        .address-box {
            font-size: 15px;
            line-height: 1.6;
        }

        .details-list {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 8px 20px;
            font-size: 13px;
        }

        .details-list dt {
            color: var(--brand-gray);
        }

        .details-list dd {
            font-weight: 600;
            text-align: right;
        }

        .items-container {
            flex-grow: 1;
        }

        .invoice-table {
            width: 100%;
            border-collapse: collapse;
        }

        .invoice-table th {
            text-align: left;
            padding: 12px 0;
            border-bottom: 2px solid var(--brand-dark);
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .invoice-table td {
            padding: 20px 0;
            border-bottom: 1px solid #F3F4F6;
            vertical-align: top;
        }

        .col-pos { width: 45px; color: var(--brand-gray); }
        .col-qty { width: 70px; text-align: center; }
        .col-price { width: 120px; text-align: right; }
        .col-total { width: 120px; text-align: right; font-weight: 600; }

        .item-main {
            font-weight: 600;
            font-size: 14px;
            display: block;
            margin-bottom: 4px;
        }

        .item-sub {
            font-size: 12px;
            color: var(--brand-gray);
            line-height: 1.4;
        }

        .summary-block {
            display: flex;
            justify-content: flex-end;
            margin-top: 30px;
        }

        .summary-table {
            width: 320px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
        }

        .summary-row.total {
            margin-top: 15px;
            padding-top: 20px;
            border-top: 1px solid var(--brand-dark);
            font-size: 18px;
            font-weight: 800;
            color: var(--brand-accent);
        }

        .payment-footer {
            margin-top: 50px;
            padding: 30px;
            background-color: var(--brand-accent-soft);
            border-radius: var(--border-radius);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .payment-footer h4 {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
            color: var(--brand-accent);
        }

        .payment-footer p {
            font-size: 12px;
            line-height: 1.6;
        }

        .payment-footer ul {
            list-style: none;
            margin: 0;
            padding: 0;
            font-size: 12px;
            line-height: 1.6;
        }

        .payment-footer .payment-note {
            margin-top: 10px;
            color: var(--brand-gray);
        }

        .bottom-bar {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 10px;
            color: var(--brand-gray);
            border-top: 1px solid #F3F4F6;
            padding-top: 20px;
        }

        .thanks {
            font-size: 12px;
            font-weight: 500;
            color: var(--brand-dark);
        }

        .no-print {
            width: 100%;
            max-width: var(--page-width);
            margin-top: 24px;
            padding: 20px 0 0;
            border-top: 1px solid #E5E7EB;
            display: flex;
            flex-direction: row;
            justify-content: flex-start;
            gap: 12px;
            flex-wrap: wrap;
        }

        .no-print button,
        .no-print a {
            padding: 10px 18px;
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            border-radius: 4px;
            cursor: pointer;
            border: 1px solid var(--brand-accent);
            background: var(--brand-accent);
            color: #fff;
            transition: background 0.2s, color 0.2s;
        }

        .no-print button:hover,
        .no-print a:not(.btn-ghost):hover {
            background: #004a5a;
        }

        .no-print a.btn-ghost {
            background: #fff;
            color: var(--brand-accent);
            border-color: #D1D5DB;
        }

        .no-print a.btn-ghost:hover {
            background: var(--brand-accent-soft);
            border-color: var(--brand-accent);
        }
    </style>
</head>
<body>
    <div class="invoice-card">
        <header class="header">
            <div class="logo-block">
                <h1>propus<span>.</span>ch</h1>
                <div class="company-contact">
                    <%= creditor.name %><br>
                    <%= creditor.email %> | <%= creditor.website %>
                </div>
            </div>
            <div class="invoice-meta-top">
                <div class="invoice-label">Rechnung</div>
                <% const statusClass = { 'Ausstehend': 'sent', 'Bezahlt': 'paid', 'Überfällig': 'overdue', 'Entwurf': 'draft', 'Storniert': 'cancelled' }[statusLabel] || 'sent'; %>
                <span class="status-pill <%= statusClass %>"><%= statusLabel %></span>
            </div>
        </header>

        <section class="info-section">
            <div>
                <span class="section-label">Rechnungsempfänger</span>
                <div class="address-box">
                    <strong><%= customerName || '-' %></strong><br>
                    <% if (customerEmail) { %><%= customerEmail %><br><% } %>
                </div>
                <div class="address-box" style="margin-top:0.75rem;font-size:13px;">
                    <strong>Tour / Objekt:</strong> <%= tourLabel || '-' %><br>
                    <% if (tourAddress) { %><strong>Adresse:</strong> <%= tourAddress %><br><% } %>
                    <% if (tourLink) { %><strong>Link:</strong> <a href="<%= tourLink %>" target="_blank" rel="noopener noreferrer"><%= tourLink %></a><br><% } %>
                    <strong>Periode:</strong> <%= billingPeriodLabel || '-' %>
                </div>
            </div>
            <div>
                <span class="section-label">Details</span>
                <dl class="details-list">
                    <dt>Rechnungs-Nr.</dt>
                    <dd><%= invLabel %></dd>
                    <dt>Datum</dt>
                    <dd><%= invoiceDate %></dd>
                    <dt>Zahlungsfrist</dt>
                    <dd><%= paymentDueLabel %></dd>
                    <dt>UID / MWST</dt>
                    <dd><%= creditor.vatId %></dd>
                </dl>
            </div>
        </section>

        <div class="items-container">
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th class="col-pos">Pos.</th>
                        <th>Beschreibung</th>
                        <th class="col-qty">Anz.</th>
                        <th class="col-price">Einzel</th>
                        <th class="col-total">Betrag</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="col-pos">1</td>
                        <td>
                            <span class="item-main"><%= bezeichnung || 'Virtueller Rundgang – Verlängerung (6 Monate)' %></span>
                            <% if (itemSub) { %><span class="item-sub"><%= itemSub %></span><% } %>
                        </td>
                        <td class="col-qty">1</td>
                        <td class="col-price"><%= amount %></td>
                        <td class="col-total"><%= amount %></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="summary-block">
            <div class="summary-table">
                <div class="summary-row">
                    <span>Zwischensumme</span>
                    <span>CHF <%= amount %></span>
                </div>
                <div class="summary-row">
                    <span>Mehrwertsteuer (0%)</span>
                    <span>0.00</span>
                </div>
                <div class="summary-row total">
                    <span>Totalbetrag</span>
                    <span>CHF <%= amount %></span>
                </div>
            </div>
        </div>

        <section class="payment-footer">
            <div>
                <h4>Zahlungsinformationen</h4>
                <p>
                    Bitte verwenden Sie bei der Bankzahlung die QR-Referenz <strong><%= qrReferenceFormatted %></strong>.
                </p>
                <p class="payment-note">
                    Der normgerechte QR-Zahlteil ist im PDF-Download enthalten und kann direkt für Druck oder Versand verwendet werden.
                </p>
            </div>
            <div>
                <h4>Bankverbindung</h4>
                <ul>
                    <li><strong><%= creditor.name %></strong></li>
                    <li><%= creditorLines[1] %></li>
                    <li><%= creditorLines[2] %></li>
                    <li>IBAN: <%= creditorIbanFormatted %></li>
                    <li>Referenz: <%= qrReferenceFormatted %></li>
                    <li>Total: <%= qrCurrency %> <%= qrAmount %></li>
                </ul>
            </div>
        </section>

        <footer class="bottom-bar">
            <div class="thanks">Vielen Dank für Ihren geschätzten Auftrag.</div>
            <div><%= creditor.vatId %> MWST | <%= creditor.name %></div>
        </footer>
    </div>

    <div class="no-print">
        <button type="button" onclick="window.print();">Drucken</button>
        <a href="<%= pdfUrl %>" class="btn-ghost" download>PDF herunterladen</a>
        <a href="/portal/tours/<%= tour.id %>" class="btn-ghost">← Zurück zur Tour</a>
    </div>

    <script>
        if (window.location.search.includes('print=1')) {
            window.onload = function() { window.print(); };
        }
    </script>
</body>
</html>
