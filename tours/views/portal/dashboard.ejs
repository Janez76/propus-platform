<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard – Propus Kundenportal</title>
  <%- include('_styles') %>
</head>
<body>
  <div class="portal-shell">
    <%- include('_topbar', { isAdminView, email }) %>
    <div class="portal-body">
    <%- include('_header', { activePage: 'dashboard', email, isAdminView, organizationName, portalNav }) %>
    <main class="portal-main">
      <h1 style="margin-bottom:0.35rem;">Willkommen<% if (typeof welcomeFirstName === 'string' && welcomeFirstName) { %>, <%= welcomeFirstName %><% } %></h1>
      <p style="color:var(--text-muted);font-size:0.9rem;margin:0 0 1.25rem 0;">
        <% if (typeof organizationName === 'string' && organizationName) { %>
        <strong style="color:var(--text);font-weight:600;"><%= organizationName %></strong>
        <span style="color:var(--text-muted);"> · </span>
        <% } %>
        Kurzüberblick zu Ihren Touren und Rechnungen.
      </p>

      <%
        const activeCount = (activeTours || []).length;
        const totalCount = (tours || []).length;
        const openInvCount = (openInvoices || []).length;
        const invLabels = { paid:'Bezahlt', sent:'Ausstehend', overdue:'Überfällig', draft:'Entwurf', cancelled:'Storniert' };
      %>
      <div class="stats" style="margin-bottom:1.25rem;">
        <div class="stat-card" style="cursor:default;pointer-events:none;"><div class="label">Touren</div><div class="value"><%= totalCount %></div></div>
        <div class="stat-card" style="cursor:default;pointer-events:none;"><div class="label">Aktiv</div><div class="value"><%= activeCount %></div></div>
        <div class="stat-card" style="cursor:default;pointer-events:none;"><div class="label">Offene Rechnungen</div><div class="value"><%= openInvCount %></div></div>
      </div>

      <div class="section">
        <h2>Nächste Abläufe</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Tour</th>
                <th>Ablaufdatum</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!nextExpiryTours || nextExpiryTours.length === 0) { %>
              <tr><td colspan="3"><div class="empty">Keine Laufzeiten hinterlegt.</div></td></tr>
              <% } else { %>
              <% nextExpiryTours.forEach((tour) => { %>
              <%
                const label = tour.canonical_object_label || tour.bezeichnung || `Tour #${tour.id}`;
                const termDate = tour.canonical_term_end_date || tour.ablaufdatum;
              %>
              <tr>
                <td>
                  <div class="customer-name"><%= label %></div>
                </td>
                <td style="color:var(--text-muted);font-size:0.9rem;"><%= termDate ? new Date(termDate).toLocaleDateString('de-CH',{ day:'2-digit', month:'short', year:'numeric' }) : '-' %></td>
                <td style="text-align:right;"><a href="/portal/tours/<%= tour.id %>" class="btn btn-primary btn-sm">Details</a></td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="section">
        <h2>Letzte Rechnungen</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rechnung</th>
                <th>Datum</th>
                <th>Betrag</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!invoices || invoices.length === 0) { %>
              <tr><td colspan="5"><div class="empty">Keine Rechnungen.</div></td></tr>
              <% } else { %>
              <% invoices.slice(0, 5).forEach((inv) => { %>
              <tr>
                <td><div class="customer-name"><%= inv.exxas_document_id || `Rechnung #${inv.id}` %></div></td>
                <td style="color:var(--text-muted);font-size:0.9rem;"><%= inv.invoice_date ? new Date(inv.invoice_date).toLocaleDateString('de-CH', { day:'2-digit', month:'short', year:'numeric' }) : '-' %></td>
                <td>CHF <%= Number(inv.betrag || inv.preis_brutto || 0).toFixed(2) %></td>
                <td><span class="badge badge-<%= inv.invoice_status %>"><%= invLabels[inv.invoice_status] || inv.invoice_status %></span></td>
                <td style="text-align:right;white-space:nowrap;">
                  <% if ((inv.invoice_status === 'sent' || inv.invoice_status === 'overdue') && payrexxConfigured) { %>
                  <a href="/portal/tours/<%= inv.tour_id %>/pay/<%= inv.id %>" class="btn btn-primary btn-sm">Bezahlen</a>
                  <% } else { %>
                  <a href="/portal/invoices" class="btn btn-ghost btn-sm">Ansehen</a>
                  <% } %>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
    </div>
  </div>
</body>
</html>
