<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rechnungen – Propus Kundenportal</title>
  <%- include('_styles') %>
</head>
<body>
  <div class="portal-shell">
    <%- include('_topbar', { isAdminView, email }) %>
    <div class="portal-body">
    <%- include('_header', { activePage: 'invoices', email, isAdminView, organizationName, portalNav }) %>
    <main class="portal-main">
      <div class="hero">
        <h1>Rechnungen</h1>
        <p>Alle Rechnungen inkl. Status, PDF und direkter Zahlungsoption.</p>
      </div>
      <%
        const invLabels = { paid:'Bezahlt', sent:'Ausstehend', overdue:'Überfällig', draft:'Entwurf', cancelled:'Storniert' };
      %>
      <% if (!invoices || invoices.length === 0) { %>
      <div class="card"><div class="empty-state"><p>Keine Rechnungen vorhanden.</p></div></div>
      <% } else { %>
      <div class="table-wrap">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Rechnung</th>
              <th>Tour</th>
              <th>Datum</th>
              <th>Betrag</th>
              <th>Status</th>
              <th>Aktion</th>
            </tr>
          </thead>
          <tbody>
            <% invoices.forEach((inv) => { %>
            <tr>
              <td><strong><%= inv.exxas_document_id || `Rechnung #${inv.id}` %></strong></td>
              <td><%= inv.tourLabel %></td>
              <td><%= inv.invoice_date ? new Date(inv.invoice_date).toLocaleDateString('de-CH', { day:'2-digit', month:'short', year:'numeric' }) : '-' %></td>
              <td>CHF <%= Number(inv.betrag || inv.preis_brutto || 0).toFixed(2) %></td>
              <td><span class="badge badge-<%= inv.invoice_status %>"><%= invLabels[inv.invoice_status] || inv.invoice_status %></span></td>
              <td>
                <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                  <a href="/portal/tours/<%= inv.tour_id %>/invoices/<%= inv.id %>/print" target="_blank" class="btn btn-ghost btn-sm">Drucken</a>
                  <a href="/portal/tours/<%= inv.tour_id %>/invoices/<%= inv.id %>/pdf" class="btn btn-ghost btn-sm">PDF</a>
                  <% if ((inv.invoice_status === 'sent' || inv.invoice_status === 'overdue') && payrexxConfigured) { %>
                  <a href="/portal/tours/<%= inv.tour_id %>/pay/<%= inv.id %>" class="btn btn-pay btn-sm">Bezahlen</a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </main>
    </div>
  </div>
</body>
</html>
