<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Touren – Propus Kundenportal</title>
  <%- include('_styles') %>
</head>
<body>
  <div class="portal-shell">
    <%- include('_topbar', { isAdminView, email }) %>
    <div class="portal-body">
    <%- include('_header', { activePage: 'tours', email, isAdminView, organizationName, portalNav }) %>
    <main class="portal-main">
      <!-- Begrüssung -->
      <% const greetHour = new Date().getHours(); %>
      <% const greetWord = greetHour < 12 ? 'Guten Morgen' : greetHour < 18 ? 'Guten Tag' : 'Guten Abend'; %>
      <% const greetName = typeof welcomeFirstName !== 'undefined' && welcomeFirstName ? welcomeFirstName : (typeof portalNav !== 'undefined' ? portalNav.displayName : email); %>
      <div style="margin-bottom:1.5rem;">
        <h1 style="margin:0 0 0.2rem 0;"><%= greetWord %><% if (greetName) { %>, <%= greetName %><% } %> 👋</h1>
        <p style="color:var(--text-muted);font-size:0.9rem;margin:0;">Hier sehen Sie alle Ihre virtuellen Rundgänge mit Status und Ablaufdatum.</p>
      </div>

      <%
        const successMessages = {
          archived: 'Tour wurde archiviert.',
          deleted: 'Tour wurde gelöscht.',
          paid: 'Zahlung erfolgreich. Vielen Dank.',
          extended: 'Verlängerung eingeleitet. Die Rechnung wurde per E-Mail zugestellt.',
          reactivation_requested: 'Reaktivierung eingeleitet. Die Rechnung wurde per E-Mail zugestellt.',
          zustaendigkeit_ok: 'Zuständigkeit wurde gespeichert.',
        };
        const errorMessages = {
          cancelled: 'Zahlung abgebrochen.',
          payment_failed: 'Zahlung konnte nicht verarbeitet werden.',
          payrexx_not_configured: 'Online-Zahlung ist momentan nicht verfügbar.',
          ungueltig: 'Ungültige Anfrage.',
        };
        const ab = typeof assigneeBundle !== 'undefined' && assigneeBundle ? assigneeBundle : { assigneeByTourId: {}, canManageByTourId: {}, candidatesByWorkspace: {} };
        const statusLabels = {
          ACTIVE: 'Aktiv',
          EXPIRING_SOON: 'Läuft bald ab',
          CUSTOMER_ACCEPTED_AWAITING_PAYMENT: 'Wartet auf Zahlung',
          CUSTOMER_DECLINED: 'Abgelehnt',
          ARCHIVED: 'Archiviert',
          AWAITING_CUSTOMER_DECISION: 'Entscheidung ausstehend',
          EXPIRED_PENDING_ARCHIVE: 'Abgelaufen',
        };
      %>
      <% if (success && successMessages[success]) { %><div class="alert alert-success"><%= successMessages[success] %></div><% } %>
      <% if (error) { %>
        <% if (errorMessages[error]) { %><div class="alert alert-error"><%= errorMessages[error] %></div>
        <% } else { %><div class="alert alert-error"><%= error %></div><% } %>
      <% } %>

      <div class="portal-tours-notice">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        <div>
          <p class="portal-tours-notice-title">Laufzeit &amp; Preise</p>
          <p>Für jede Tour beträgt die Laufzeit <strong>6 Monate</strong>, gerechnet ab dem <strong>Erstellungsdatum in Matterport</strong>.</p>
          <ul>
            <li><strong>Verlängerung:</strong> CHF 59.00 für weitere 6 Monate</li>
            <li><strong>Reaktivierung:</strong> CHF 74.00 (archivierte Tour wieder aktivieren)</li>
          </ul>
        </div>
      </div>

      <% if (!tours || tours.length === 0) { %>
      <div class="section">
        <h2>Übersicht</h2>
        <div class="table-wrap">
          <table>
            <tbody><tr><td><div class="empty">Keine Touren gefunden. Wenden Sie sich an uns, falls Sie Touren erwarten.</div></td></tr></tbody>
          </table>
        </div>
      </div>
      <% } else { %>
      <div class="section">
        <h2>Übersicht</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Tour</th>
                <th>Status</th>
                <th>Ablaufdatum</th>
                <th>Zuständig</th>
                <th>Rechnungen</th>
                <th style="text-align:right;">Aktionen</th>
              </tr>
            </thead>
            <tbody>
              <% tours.forEach((tour) => { %>
              <%
                const label = tour.canonical_object_label || tour.bezeichnung || `Tour #${tour.id}`;
                const termDate = tour.canonical_term_end_date || tour.ablaufdatum;
                const termLabel = termDate ? new Date(termDate).toLocaleDateString('de-CH', { day:'2-digit', month:'short', year:'numeric' }) : '–';
                const tourInvoices = invoices.filter(inv => inv.tour_id === tour.id);
                const openInvoices = tourInvoices.filter(inv => inv.invoice_status === 'sent' || inv.invoice_status === 'overdue');
                const invWord = tourInvoices.length === 1 ? 'Rechnung' : 'Rechnungen';
                const wsKey = String(tour.customer_email || '').trim().toLowerCase();
                const assign = ab.assigneeByTourId[tour.id];
                const canAssign = !!ab.canManageByTourId[tour.id];
                const assignCands = ab.candidatesByWorkspace[wsKey] || [];
              %>
              <tr>
                <td class="portal-tours-title-cell">
                  <div class="customer-name"><%= label %></div>
                </td>
                <td><span class="badge badge-<%= tour.status %>"><%= statusLabels[tour.status] || tour.status %></span></td>
                <td style="color:var(--text-muted);font-size:0.9rem;white-space:nowrap;"><%= termLabel %></td>
                <td class="portal-tours-zustaendig-cell">
                  <%
                    const selfEm = typeof selfEmail !== 'undefined' ? selfEmail : email;
                    // Prüfe ob selfEmail in den Kandidaten ist
                    const selfInCands = assignCands.some(c => c.email && c.email.toLowerCase() === (selfEm||'').toLowerCase());
                  %>
                  <% if (canAssign && assignCands.length) { %>
                  <form method="post" action="/portal/tours/<%= tour.id %>/assignee" class="portal-tours-assignee-form">
                    <input type="hidden" name="from" value="list">
                    <select name="assigneeEmail" id="assignee-<%= tour.id %>" class="portal-tours-assignee-select" aria-label="Zuständige Person für diese Tour" onchange="this.form.submit()">
                      <option value="">— Nicht zugewiesen —</option>
                      <% assignCands.forEach((c) => { %>
                      <%
                        // Wenn kein Assignee explizit gesetzt, self-Email als Default vorwählen
                        const isSelected = assign
                          ? (assign.email && assign.email.toLowerCase() === c.email.toLowerCase())
                          : (selfInCands && c.email.toLowerCase() === (selfEm||'').toLowerCase());
                      %>
                      <option value="<%= c.email %>" <%= isSelected ? 'selected' : '' %>><%= c.label %></option>
                      <% }) %>
                    </select>
                  </form>
                  <% } else if (assign) { %>
                  <span class="portal-tours-assignee-readonly" title="<%= assign.email %>"><%= assign.label %></span>
                  <% } else { %>
                  <span class="portal-tours-assignee-empty">—</span>
                  <% } %>
                </td>
                <td>
                  <% if (tourInvoices.length === 0) { %>
                  <span style="color:var(--text-muted);font-size:0.88rem;">–</span>
                  <% } else { %>
                  <span style="font-size:0.88rem;"><%= tourInvoices.length %> <%= invWord %></span>
                  <% if (openInvoices.length > 0) { %>
                  <span class="badge badge-sent" style="margin-left:0.35rem;font-size:0.65rem;">Offen</span>
                  <% } %>
                  <% } %>
                </td>
                <td>
                  <div class="portal-tours-actions">
                    <a href="/portal/tours/<%= tour.id %>" class="btn btn-primary btn-sm">Details</a>
                    <% if (tour.matterport_space_id) { %>
                    <a href="https://my.matterport.com/show/?m=<%= tour.matterport_space_id %>" target="_blank" rel="noopener" class="btn btn-ghost btn-sm">Öffnen</a>
                    <% } else if (tour.tour_url) { %>
                    <a href="<%= tour.tour_url %>" target="_blank" rel="noopener" class="btn btn-ghost btn-sm">Öffnen</a>
                    <% } %>
                    <% if (openInvoices.length > 0 && payrexxConfigured) { %>
                    <a href="/portal/tours/<%= tour.id %>/pay/<%= openInvoices[0].id %>" class="btn btn-pay btn-sm">Bezahlen</a>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
    </main>
    </div>
  </div>
</body>
</html>
