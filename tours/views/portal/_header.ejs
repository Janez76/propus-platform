<% const bp = typeof basePath === 'string' ? basePath : ''; %>
<% const active = typeof activePage === 'string' ? activePage : 'dashboard'; %>
<% const pnav = (typeof portalNav === 'object' && portalNav) ? portalNav : { displayName: '', email: typeof email === 'string' ? email : '', organizationName: null }; %>
<% const dn = String(pnav.displayName || '').trim(); %>
<aside class="admin-sidebar">
  <div class="logo">
    <img
      src="https://propus.ch/wp-content/uploads/2024/06/Asset-2-2.png"
      alt="Propus"
      class="admin-logo-img"
      loading="eager"
      decoding="async"
    >
    <div style="font-size:0.72rem;color:var(--text-muted);font-weight:500;margin-top:0.28rem;letter-spacing:0.02em;">Kundenportal</div>
  </div>

  <nav>
    <div class="portal-nav-main">
      <a href="<%= bp %>/portal/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">
        <i class="fa-solid fa-gauge-high"></i>
        Dashboard
      </a>
      <div class="nav-divider"></div>

      <div class="nav-section-label">Übersicht</div>
      <a href="<%= bp %>/portal/tours" class="<%= active === 'tours' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i>
        Touren
      </a>
      <a href="<%= bp %>/portal/invoices" class="<%= active === 'invoices' ? 'active' : '' %>">
        <i class="fa-regular fa-file-lines"></i>
        Rechnungen
      </a>
      <a href="<%= bp %>/portal/team" class="<%= active === 'team' ? 'active' : '' %>">
        <i class="fa-solid fa-users"></i>
        Team
      </a>
    </div>

    <div class="portal-nav-footer">
      <div class="nav-divider portal-nav-footer-divider"></div>
      <%- include('../partials/_sidebar-user-card', { displayName: dn, organizationName: pnav.organizationName, variant: 'portal', hasProfilePhoto: !!pnav.hasProfilePhoto, profilePhotoVersion: pnav.profilePhotoVersion || 0 }) %>
      <div class="nav-divider"></div>
      <%- include('../partials/_theme-toggle') %>
      <form method="get" action="<%= bp %>/portal/logout" class="portal-logout-form">
        <button type="submit" class="nav-link-logout">
          <i class="fa-solid fa-right-from-bracket"></i>
          Abmelden
        </button>
      </form>
    </div>
  </nav>
</aside>
<%- include('../partials/_profile-edit-modal', { variant: 'portal' }) %>
<% if (typeof basePath === 'string' && basePath) { %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var B = "<%= basePath %>";
  function fix(sel, attr) {
    document.querySelectorAll(sel).forEach(function(el) {
      var v = el.getAttribute(attr);
      if (!v) return;
      if (v.indexOf('http') === 0) return;
      if (v.startsWith('/api')) return;
      if (v.startsWith('/')) {
        if (B && (v === B || v.startsWith(B + '/'))) return;
        el.setAttribute(attr, B + v);
      }
    });
  }
  fix('a[href^="/"]', 'href');
  fix('form[action^="/"]', 'action');
  fix('img[src^="/"]', 'src');
});
</script>
<% } %>
