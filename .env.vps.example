# ---------------------------------------------------------------------------
# Propus Platform - VPS production environment (single source of truth)
#
# Seit 2026-05-07: .env.vps ist die EINZIGE Env-Datei der Platform. Sie liegt
# manuell auf dem VPS unter /opt/propus-platform/.env.vps, wird vom CI-Deploy
# nicht überschrieben (nur als Bootstrap geschrieben, falls die Datei fehlt;
# siehe .github/workflows/deploy-vps-and-booking-smoke.yml — Step
# "Bootstrap VPS env file (only if missing)").
#
# Bearbeiten: ssh propus-vps, vi /opt/propus-platform/.env.vps, danach
#   docker compose -f docker-compose.vps.yml --env-file .env.vps \
#     up -d --force-recreate platform
#
# Legacy: .env.vps.secrets wird aus historischen Gründen weiterhin als
# optionaler Fallback geladen (docker-compose.vps.yml), kann aber in einem
# späteren Cleanup-Schritt entfernt werden.
# ---------------------------------------------------------------------------

# --- VPS / deploy metadata --------------------------------------------------
VPS_IP=87.106.24.107
VPS_USER=propus
VPS_PROJECT_ROOT=/opt/propus-platform
VPS_COMPOSE_PROJECT=propus-platform
VPS_ENV_FILE=/opt/propus-platform/.env.vps

# --- Cloudflare -------------------------------------------------------------
CF_ZONE=
CF_EMAIL=
CF_KEY=
CF_TUNNEL_TOKEN=

# --- Platform ports (bound to 127.0.0.1 on the VPS) ------------------------
PLATFORM_PORT=3100
PROPUS_PG_PORT=5435

# --- Main PostgreSQL --------------------------------------------------------
POSTGRES_USER=propus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_MAIN_DB_PASSWORD
POSTGRES_DB=propus

# --- Booking / tours sessions -----------------------------------------------
BOOKING_SESSION_SECRET=CHANGE_ME_STRONG_BOOKING_SESSION_SECRET
TOURS_SESSION_SECRET=CHANGE_ME_STRONG_TOURS_SESSION_SECRET
# Kunden-Portal (Mail-Links, Payrexx-Return) und Session-Cookie über beide Hosts
PORTAL_BASE_URL=https://portal.propus.ch
# Empfohlen: .propus.ch — Login auf portal + admin-booking teilt die Session
SESSION_COOKIE_DOMAIN=.propus.ch
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=0

# --- Admin-Hauptbenutzer (wird beim Start automatisch angelegt/aktualisiert) --
# Bestehende admin_users-Eintraege erhalten nur Stammdaten-Updates.
# Passwortaenderungen bitte direkt in admin_users oder ueber das Admin-Tool.
ADMIN_USER=janez
ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD
ADMIN_EMAIL=js@propus.ch
ADMIN_NAME=Janez
ADMIN_ROLE=super_admin

# --- Einmaliger Setup-Endpunkt (nach Setup auf "" setzen!) ------------------
# POST https://admin-booking.propus.ch/api/admin/first-setup
# Body: { "token": "<ADMIN_SETUP_TOKEN>", ... }
ADMIN_SETUP_TOKEN=

# --- URLs behind Cloudflare -------------------------------------------------
FRONTEND_URL=https://booking.propus.ch
ADMIN_PANEL_URL=https://admin-booking.propus.ch

# --- Mail / Microsoft Graph -------------------------------------------------
MAIL_FROM=
OFFICE_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
# Microsoft Graph webhook-clientState (Posteingang-Webhook, tours/routes/posteingang-webhook.js).
# WICHTIG: Wenn LEER, akzeptiert verifyClientState() jeden Webhook — nur OK weil Graph
# der einzige Sender ist, aber bitte einen zufälligen 32+-Zeichen-String setzen.
# GRAPH_WEBHOOK_SECRET=

# --- Cron / external automation auth tokens ---------------------------------
# Geschützen die /api/cron/* (self-learning) und /api/tours/* (n8n) Endpunkte.
# Wenn leer: 401/403 — Cron läuft nicht, n8n-Automationen brechen.
# Werte: zufällige 32+ Zeichen Strings (z. B. `openssl rand -hex 32`).
# CRON_SECRET=
# CRON_API_KEY=
# N8N_API_KEY=

# --- Propus Assistant --------------------------------------------------------
# WICHTIG: Beide Keys MUESSEN im GitHub-Secret VPS_ENV_FILE gesetzt sein.
# Sind sie leer, antwortet der Assistant mit "ANTHROPIC_API_KEY ist nicht
# gesetzt" (Chat/Briefing) bzw. klarer Hinweis zu fehlender OPENAI_API_KEY
# (nur Spracheingabe / Whisper). Kein DB-Fallback vorhanden.
ANTHROPIC_API_KEY=
# Optional; default: claude-sonnet-4-6
ANTHROPIC_MODEL=
OPENAI_API_KEY=
# Auto-Escalation: startet mit Haiku, eskaliert bei Bedarf zu Sonnet/Opus
ASSISTANT_AUTO_ESCALATION=true
ASSISTANT_MAX_MODEL_TIER=opus
ASSISTANT_ENABLE_OPUS_ESCALATION=true

# --- Business integrations --------------------------------------------------
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net
# EXXAS App-Login (Fallback wenn API-Token nicht vorhanden / personalisierte Auth):
# EXXAS_APP_PASSWORD wird in booking/server.js + tours/lib/exxas.js geprüft.
# EXXAS_AUTH_MODE: "token" (default) oder "app" — steuert welcher Pfad genutzt wird.
# EXXAS_APP_PASSWORD=
# EXXAS_AUTH_MODE=token

# Google Business Profile OAuth (Reviews-Sync, Posts via booking/gbp-client.js).
# OAuth-App in Google Cloud Console; Redirect-URI muss exakt mit GBP_REDIRECT_URI matchen.
# GBP_CLIENT_ID=
# GBP_CLIENT_SECRET=
# GBP_REDIRECT_URI=https://admin-booking.propus.ch/api/admin/gbp/callback

# --- Payrexx (Online-Zahlung für Tour-Reaktivierungen) ----------------------
PAYREXX_INSTANCE=
PAYREXX_API_SECRET=
PAYREXX_WEBHOOK_SECRET=
# PAYREXX_PAYMENT_METHODS=curated

# --- Matterport / Google ---------------------------------------------------
MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=
# Reviews-Fallback (Places API): Place-ID + API-Key erforderlich.
# API-Key: entweder GOOGLE_PLACES_API_KEY oder (Fallback) GOOGLE_MAPS_API_KEY.
# In Google Cloud die "Places API (New)" aktivieren (inkl. Billing).
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_REVIEWS_PLACE_ID=ChIJCXJ70_ZCiisRJDlGdaYk66Y

# --- Propus Website (www.propus.ch / Astro) ---------------------------------
WEBSITE_PORT=4343
WEBSITE_SUPABASE_URL=
WEBSITE_SUPABASE_SERVICE_ROLE_KEY=
WEBSITE_ADMIN_USER=admin
WEBSITE_ADMIN_PASSWORD=
WEBSITE_ADMIN_SECRET=
# Interne Guidelines (/guideline): Session-Cookie, nicht mit CMS-Admin verwechseln
WEBSITE_GUIDELINE_SECRET=
WEBSITE_GUIDELINE_PASSWORD=
# Optional wenn guideline.propus.ch auf dieselbe Astro-Instanz zeigt (CSRF-Origin für POST /api/guideline/login)
# WEBSITE_GUIDELINE_CSRF_ORIGINS=https://guideline.propus.ch

# Kontaktformular /kontakt → POST /api/contact (Cloudflare Turnstile + SMTP).
# Site-Key ins Image: PUBLIC_TURNSTILE_SITE_KEY als Build-Arg (siehe website/Dockerfile + docker-compose.vps.yml).
# Secret + Mail: Runtime im Website-Container (oft in .env.vps.secrets zusätzlich zu .env.vps).
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
CONTACT_SMTP_HOST=smtp.office365.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
CONTACT_FROM="Propus Website <office@propus.ch>"
CONTACT_TO=office@propus.ch

# --- Newsletter www.propus.ch (MailerLite Popup) ----------------------------
# Nach Änderung: docker compose ... up -d --force-recreate website
# Mehrere Gruppen: IDs kommagetrennt. BKBN-Listenimport nutzt nur BKBN (nicht LinkedIn mischen).
# Website-Popup z. B. BKBN + Kunden; LinkedIn nur wenn eigener Kanal.
MAILERLITE_API_KEY=
MAILERLITE_NEWSLETTER_GROUP_ID=
# Optional:
# NEWSLETTER_VOUCHER_CODE=

# --- Upload / backup paths on the VPS --------------------------------------
BOOKING_UPLOAD_REQUIRE_MOUNT=true
BOOKING_UPLOAD_STAGING_HOST_PATH=/opt/propus-upload-staging
BOOKING_UPLOAD_CUSTOMER_HOST_PATH=/mnt/propus-nas-customers
BOOKING_UPLOAD_RAW_HOST_PATH=/mnt/propus-nas-raw

# --- Nextcloud-Integration (automatische Freigabelinks für Kundenordner) ----
# Nextcloud läuft auf dem UGREEN NAS (192.168.1.5), extern via Cloudflare Tunnel:
# https://cloud.propus.ch  —  NICHT auf dem VPS!
# NEXTCLOUD_CUSTOMER_FOLDER_PATH = Nextcloud-Pfad, der auf BOOKING_UPLOAD_CUSTOMER_HOST_PATH zeigt.
NEXTCLOUD_URL=https://cloud.propus.ch
NEXTCLOUD_USER=Janez
NEXTCLOUD_PASS=
NEXTCLOUD_CUSTOMER_FOLDER_PATH=/Immobilien Fotografie Propusimmo/Kunden

# ─── Bookkeeper / Paperless-Proxy ────────────────────────────────────────
# Backend für die Admin-Buchhaltungs-Page (/admin/finance/bookkeeper).
# Token: bookkeeper-service-User aus Paperless-NGX (siehe Y:\Arhive\Paperless\bookkeeper.env).
# Quelle gehört in .env.vps.secrets — NICHT in .env.vps committen.
PAPERLESS_BOOKKEEPER_URL=https://paperless.propus.ch
PAPERLESS_BOOKKEEPER_TOKEN=

BACKUP_RESTORE_TARGET=/opt/propus-platform
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_VOLUMES=0
BACKUP_VOLUME_PATHS=/data/state:/app/logs:/upload_staging
BACKUP_NAS_TARGET=/volume1/backup/propus-platform/data
BACKUP_NAS_LOG_PATH=/data/backups/.nas-sync.log
BACKUP_NAS_SCHEDULE=0 2 * * *

# --- Runtime / logging ------------------------------------------------------
TIMEZONE=Europe/Zurich
WORK_START=08:00
WORK_END=18:00
LOG_LEVEL=info
LOG_PRETTY=false
LOG_REDACT=true
LOG_CONSOLE_ENABLED=false
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs/platform.log
LOG_RETENTION_DAYS=30
FRONTEND_LOG_RATE_LIMIT_PER_MIN=120

NEXT_PUBLIC_PICDROP_NOTIFY_EMAIL=office@propus.ch
