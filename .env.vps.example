# ---------------------------------------------------------------------------
# Propus Platform - VPS production environment
# Copy to ".env.vps" on the VPS and fill in the real values.
# ---------------------------------------------------------------------------

# --- VPS / deploy metadata --------------------------------------------------
VPS_IP=87.106.24.107
VPS_USER=propus
VPS_PROJECT_ROOT=/opt/propus-platform
VPS_COMPOSE_PROJECT=propus-platform
VPS_ENV_FILE=/opt/propus-platform/.env.vps

# --- Cloudflare -------------------------------------------------------------
CF_ZONE=
CF_EMAIL=
CF_KEY=
CF_TUNNEL_TOKEN=

# --- Platform ports (bound to 127.0.0.1 on the VPS) ------------------------
PLATFORM_PORT=3100
PROPUS_PG_PORT=5435

# --- Main PostgreSQL --------------------------------------------------------
POSTGRES_USER=propus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_MAIN_DB_PASSWORD
POSTGRES_DB=propus

# --- Booking / tours sessions -----------------------------------------------
BOOKING_SESSION_SECRET=CHANGE_ME_STRONG_BOOKING_SESSION_SECRET
TOURS_SESSION_SECRET=CHANGE_ME_STRONG_TOURS_SESSION_SECRET
SESSION_COOKIE_DOMAIN=
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=0

# --- Admin-Hauptbenutzer (wird beim Start automatisch angelegt/aktualisiert) --
# Bestehende admin_users-Eintraege erhalten nur Stammdaten-Updates.
# Passwortaenderungen bitte direkt in admin_users oder ueber das Admin-Tool.
ADMIN_USER=janez
ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD
ADMIN_EMAIL=js@propus.ch
ADMIN_NAME=Janez
ADMIN_ROLE=super_admin

# --- Einmaliger Setup-Endpunkt (nach Setup auf "" setzen!) ------------------
# POST https://admin-booking.propus.ch/api/admin/first-setup
# Body: { "token": "<ADMIN_SETUP_TOKEN>", ... }
ADMIN_SETUP_TOKEN=

# --- URLs behind Cloudflare -------------------------------------------------
FRONTEND_URL=https://booking.propus.ch
ADMIN_PANEL_URL=https://admin-booking.propus.ch

# --- Mail / Microsoft Graph -------------------------------------------------
MAIL_FROM=
OFFICE_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# --- Business integrations --------------------------------------------------
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net

# --- Payrexx (Online-Zahlung für Tour-Reaktivierungen) ----------------------
PAYREXX_INSTANCE=
PAYREXX_API_SECRET=
PAYREXX_WEBHOOK_SECRET=
# PAYREXX_PAYMENT_METHODS=curated

# --- Matterport / Google ---------------------------------------------------
MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=
GOOGLE_PLACES_API_KEY=
GOOGLE_REVIEWS_PLACE_ID=

# --- Propus Website (www.propus.ch / Astro) ---------------------------------
WEBSITE_PORT=4343
WEBSITE_SUPABASE_URL=
WEBSITE_SUPABASE_SERVICE_ROLE_KEY=
WEBSITE_ADMIN_USER=admin
WEBSITE_ADMIN_PASSWORD=
WEBSITE_ADMIN_SECRET=

# --- Upload / backup paths on the VPS --------------------------------------
BOOKING_UPLOAD_REQUIRE_MOUNT=true
BOOKING_UPLOAD_STAGING_HOST_PATH=/opt/propus-upload-staging
BOOKING_UPLOAD_CUSTOMER_HOST_PATH=/mnt/propus-nas-customers
BOOKING_UPLOAD_RAW_HOST_PATH=/mnt/propus-nas-raw

# --- Nextcloud-Integration (automatische Freigabelinks für Kundenordner) ----
# Entspricht dem Nextcloud-Pfad, der auf BOOKING_UPLOAD_CUSTOMER_HOST_PATH zeigt
NEXTCLOUD_URL=https://cloud.propus.ch
NEXTCLOUD_USER=Janez
NEXTCLOUD_PASS=
NEXTCLOUD_CUSTOMER_FOLDER_PATH=/Immobilien Fotografie Propusimmo/Kunden
BACKUP_RESTORE_TARGET=/opt/propus-platform
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_VOLUMES=0
BACKUP_VOLUME_PATHS=/data/state:/app/logs:/upload_staging
BACKUP_NAS_TARGET=/volume1/backup/propus-platform/data
BACKUP_NAS_LOG_PATH=/data/backups/.nas-sync.log
BACKUP_NAS_SCHEDULE=0 2 * * *

# --- Runtime / logging ------------------------------------------------------
TIMEZONE=Europe/Zurich
WORK_START=08:00
WORK_END=18:00
LOG_LEVEL=info
LOG_PRETTY=false
LOG_REDACT=true
LOG_CONSOLE_ENABLED=false
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs/platform.log
LOG_RETENTION_DAYS=30
FRONTEND_LOG_RATE_LIMIT_PER_MIN=120

NEXT_PUBLIC_PICDROP_URL=https://admin-booking.propus.ch/selekto/bilder-auswahl
VITE_PICDROP_NOTIFY_EMAIL=office@propus.ch
