# ---------------------------------------------------------------------------
# Propus Platform - VPS production environment
# Copy to ".env.vps" on the VPS and fill in the real values.
# Reuse the productive credentials from the old "/opt/buchungstool/.env.prod"
# where noted below so mail flow, admin access and external integrations survive
# the clean install.
# ---------------------------------------------------------------------------

# --- VPS / deploy metadata --------------------------------------------------
VPS_IP=87.106.24.107
VPS_USER=propus
VPS_PROJECT_ROOT=/opt/propus-platform
VPS_COMPOSE_PROJECT=propus-platform
VPS_ENV_FILE=/opt/propus-platform/.env.vps

# --- Cloudflare -------------------------------------------------------------
CF_ZONE=
CF_EMAIL=
CF_KEY=
CF_TUNNEL_TOKEN=

# --- Platform ports (bound to 127.0.0.1 on the VPS) ------------------------
PLATFORM_PORT=3100
PROPUS_PG_PORT=5435
LOGTO_PG_PORT=5436
LOGTO_PORT=3301
LOGTO_ADMIN_PORT=3302

# --- Main PostgreSQL --------------------------------------------------------
POSTGRES_USER=propus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_MAIN_DB_PASSWORD
POSTGRES_DB=propus

# --- Logto PostgreSQL -------------------------------------------------------
LOGTO_DB_USER=logto
LOGTO_DB_PASSWORD=CHANGE_ME_STRONG_LOGTO_DB_PASSWORD
LOGTO_DB=logto

# --- Logto public endpoints -------------------------------------------------
# Start with localhost-only endpoints so the services boot cleanly.
# Once Cloudflare routes for Logto exist, switch these to the public hostnames.
# Suggested later setup:
#   LOGTO_ENDPOINT=https://auth.propus.ch
#   LOGTO_ADMIN_ENDPOINT=https://auth-admin.propus.ch
LOGTO_ENDPOINT=http://127.0.0.1:3301
LOGTO_ADMIN_ENDPOINT=http://127.0.0.1:3302

# Existing app credentials can be copied in later after Logto setup.
PROPUS_BOOKING_LOGTO_APP_ID=
PROPUS_BOOKING_LOGTO_APP_SECRET=
PROPUS_TOURS_ADMIN_LOGTO_APP_ID=
PROPUS_TOURS_ADMIN_LOGTO_APP_SECRET=
PROPUS_TOURS_PORTAL_LOGTO_APP_ID=
PROPUS_TOURS_PORTAL_LOGTO_APP_SECRET=
PROPUS_MANAGEMENT_LOGTO_APP_ID=
PROPUS_MANAGEMENT_LOGTO_APP_SECRET=

# Optional helper vars for infra/setup-logto.js once the management app exists.
M2M_ID=
M2M_SECRET=

# --- Booking / tours sessions ----------------------------------------------
BOOKING_SESSION_SECRET=CHANGE_ME_STRONG_BOOKING_SESSION_SECRET
TOURS_SESSION_SECRET=CHANGE_ME_STRONG_TOURS_SESSION_SECRET
SESSION_COOKIE_DOMAIN=
PROPUS_ENABLE_LEGACY_CUSTOMER_LOGIN=0

# --- Legacy admin access (reuse from old .env.prod) ------------------------
ADMIN_USER=admin
ADMIN_PASS=
ADMIN_BOOTSTRAP_SYNC_PASSWORD=true
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- URLs behind Cloudflare -------------------------------------------------
FRONTEND_URL=https://booking.propus.ch
ADMIN_PANEL_URL=https://admin-booking.propus.ch

# --- Mail / Microsoft Graph (reuse from old .env.prod) ---------------------
MAIL_FROM=
OFFICE_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Tours currently looks for the generic names as well.
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# --- Business integrations --------------------------------------------------
EXXAS_API_TOKEN=
EXXAS_BASE_URL=https://api.exxas.net

# --- Payrexx (Online-Zahlung für Tour-Reaktivierungen) ----------------------
# Ohne Konfiguration steht nur "QR-Rechnung" zur Verfügung.
# Optional fest auf dem VPS: gleiche Variablen in `.env.vps.secrets` (siehe .env.vps.secrets.example),
# wird bei Deploy nicht überschrieben.
# Instanzname aus der URL: https://<INSTANCE>.payrexx.com
PAYREXX_INSTANCE=
# Dashboard → Einstellungen → API → Key erstellen
PAYREXX_API_SECRET=
# Webhook-Signing-Key aus dem Payrexx-Dashboard (optional, Fallback auf API-Secret)
PAYREXX_WEBHOOK_SECRET=
# Optional: curated | all | visa,mastercard,twint,...
# PAYREXX_PAYMENT_METHODS=curated
# Matterport Model API: Token-ID + Secret aus «API-Token», nicht SDK-Schlüssel
MATTERPORT_TOKEN_ID=
MATTERPORT_TOKEN_SECRET=
GOOGLE_PLACES_API_KEY=
GOOGLE_REVIEWS_PLACE_ID=

# --- Propus Website (www.propus.ch / Astro) ---------------------------------
WEBSITE_PORT=4343
WEBSITE_SUPABASE_URL=
WEBSITE_SUPABASE_SERVICE_ROLE_KEY=
WEBSITE_ADMIN_USER=admin
WEBSITE_ADMIN_PASSWORD=
WEBSITE_ADMIN_SECRET=
# Optional: Branding-URLs (Supabase Storage public URLs)
# PUBLIC_SITE_LOGO_URL=
# PUBLIC_SITE_FAVICON_URL=
# PUBLIC_BOOKING_CATALOG_URL=
# PUBLIC_SUPABASE_IMG_TRANSFORM=

# --- Upload / backup paths on the VPS --------------------------------------
BOOKING_UPLOAD_REQUIRE_MOUNT=true
BOOKING_UPLOAD_STAGING_HOST_PATH=/opt/propus-upload-staging
BOOKING_UPLOAD_CUSTOMER_HOST_PATH=/mnt/propus-nas-customers
BOOKING_UPLOAD_RAW_HOST_PATH=/mnt/propus-nas-raw
BACKUP_RESTORE_TARGET=/opt/propus-platform

# --- Backup configuration ---------------------------------------------------
# Backups run daily at 02:00 via cron on the NAS (pull-based).
# The NAS script triggers a backup inside the platform container, then rsyncs
# the resulting files to /volume1/backup/propus-platform/data/ on the NAS.
# Retention: 30 days on both VPS and NAS.
# Daily NAS backups default to DB/config only.
# Full volume backups include only VPS-local restore paths (state, logs, upload staging), not external NAS mounts.
# Suggested weekly full backup on the NAS:
# 0 3 * * 0 BACKUP_NAS_INCLUDE_VOLUMES=1 RETENTION_DAYS=14 /volume1/backup/propus-platform/scripts/backup-nas-full-pull.sh >> /volume1/backup/propus-platform/logs/backup-full.log 2>&1
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_VOLUMES=0
BACKUP_VOLUME_PATHS=/data/state:/app/logs:/upload_staging
BACKUP_NAS_TARGET=/volume1/backup/propus-platform/data
BACKUP_NAS_LOG_PATH=/data/backups/.nas-sync.log
BACKUP_NAS_SCHEDULE=0 2 * * *

# --- Runtime / logging ------------------------------------------------------
TIMEZONE=Europe/Zurich
WORK_START=08:00
WORK_END=18:00
LOG_LEVEL=info
LOG_PRETTY=false
LOG_REDACT=true
LOG_CONSOLE_ENABLED=false
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs/platform.log
LOG_RETENTION_DAYS=30
FRONTEND_LOG_RATE_LIMIT_PER_MIN=120
